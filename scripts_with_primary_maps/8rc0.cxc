# Lightweight ChimeraX script for 8RC0
# Models are downloaded directly by ChimeraX from the PDB.
# Primary maps, when requested, are downloaded directly from EMDB.
# Original deposited chain identifiers are used.

# Shared anchor frame: 8H6L
# Structure group: #411; target model: #411.1; RNA labels: #411.2.

open 8h6l id 411.9 name 8H6L_anchor
open 8rc0 id 411.1 name 8RC0
open emdb:19041 id 411.3.1 name 8RC0_EMD-19041_primary_map
rename #411 tri_snRNP_8rc0_structure

# Align on PRPF8.
matchmaker #411.1/A to #411.9/5B bring #411.3.1
close #411.9

# Remove implausibly long deposited covalent bonds before styling.
# Fetch and run the implausible-bond pruning helper from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/prune_implausible_bonds.py

hide atoms
cartoon
# Default display style.
style (protein|nucleic|solvent) & @@draw_mode=0 stick
cartoon style modeh def arrows t arrowshelix f arrowscale 3 wid 4 thick 3 sides 12 div 20
cartoon style ~(nucleic|strand) x round
cartoon style (nucleic|strand) x rect
cartoon style nucleic x round width 4 thick 4
lighting shadows false
lighting simple
camera ortho
lighting soft intensity 0.2 fillIntensity 0.5 ambientIntensity 1
lighting soft

# bg and model colors
set bgColor white
style nucleic stick
graphics silhouettes true
cartoon style arrowScale 1.5
color byhetero
# Subunit colors from color_code/subunit_color_code.csv.
# CD2BP2
color #411.1/F #FF4500
# U5-Sm SNRPE
color #411.1/l #B0C4DE
# U5-Sm SNRPF
color #411.1/m #B0C4DE
# U5-Sm SNRPG
color #411.1/n #B0C4DE
# U5-Sm SNRPD2
color #411.1/j #B0C4DE
# U5-Sm SNRPB
color #411.1/h #B0C4DE
# EFTUD2
color #411.1/C #6495ED
# PRPF8
color #411.1/A #BFC3E8
# U5 snRNA
color #411.1/5 #0000CD
# PRPF6
color #411.1/E #CFA785
# DDX23
color #411.1/D #CA9982
# PRP8BP
color #411.1/G #E2F3F4
# SNRNP200
color #411.1/B #AFEEEE
# U5-Sm SNRPD1
color #411.1/i #B0C4DE
# U5-Sm SNRPD3
color #411.1/k #B0C4DE
# Named selections for subcomplexes using original deposited chain IDs.
# U4/U6 snRNP
# selector_meta {"color":"#C3BA7A","family":"Protein/RNP groups","group":"U4/U6 groups","kind":"subcomplex"}
name pdb_8RC0_U4_U6_snRNP #411.1/D
# U5 Sm ring
# selector_meta {"color":"#BFC3E8","family":"Protein/RNP groups","group":"U5 snRNP groups","kind":"subcomplex"}
name pdb_8RC0_U5_Sm_ring #411.1/h,i,j,k,l,m,n
# U5 snRNP
# selector_meta {"color":"#0000CD","family":"Protein/RNP groups","group":"U5 snRNP groups","kind":"subcomplex"}
name pdb_8RC0_U5_snRNP #411.1/5,A,B,C,E,F,G
# Named selections for resolved snRNA functional regions.
# U5 snRNA loop I: residues 38, sequence-motif, medium confidence
# selector_meta {"color":"#1B3CD0","family":"RNA","feature":"U5_loop_I","group":"snRNA-pre-mRNA regions","group_key":"snRNA_pre_mRNA_regions","kind":"rna_feature"}
name U5_tri_snRNP_8RC0_U5_loop_I #411.1/5:38
# RNA feature nucleotide display.
select #411.1 & nucleic
nucleotides sel atoms
select clear
# U5 loop I: residues 38
color #411.1/5:38 #1B3CD0
select #411.1/5:38
nucleotides sel fill
select clear
# RNA feature 3D residue labels.
# Labels are created as independent grouped models under #411.2.
# Fetch and run the self-contained RNA label script from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/label_scripts/8rc0_rna_labels.py
# Searchable named selection browser.
# In GUI ChimeraX this opens a small panel for selecting, zooming, and toggling RNA labels.
# Fetch and open the self-contained named selection browser from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/selection_browser_scripts/8rc0_selection_browser.py
view
show nucleic
