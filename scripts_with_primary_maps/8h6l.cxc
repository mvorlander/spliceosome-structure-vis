# Lightweight ChimeraX script for 8H6L
# Models are downloaded directly by ChimeraX from the PDB.
# Primary maps, when requested, are downloaded directly from EMDB.
# Original deposited chain identifiers are used.

# Shared anchor frame: 8H6L
# Structure group: #382; target model: #382.1; RNA labels: #382.2.

open 8h6l id 382.1 name 8H6L
open emdb:34508 id 382.3.1 name 8H6L_EMD-34508_primary_map
rename #382 B_8h6l_structure

hide atoms
cartoon
# Default display style.
style (protein|nucleic|solvent) & @@draw_mode=0 stick
cartoon style modeh def arrows t arrowshelix f arrowscale 3 wid 4 thick 3 sides 12 div 20
cartoon style ~(nucleic|strand) x round
cartoon style (nucleic|strand) x rect
cartoon style nucleic x round width 4 thick 4
lighting shadows false
lighting simple
camera ortho
lighting soft intensity 0.2 fillIntensity 0.5 ambientIntensity 1
lighting soft
# window
# windowsize 800 800

# bg and model colors
set bgColor white
style nucleic stick
graphics silhouettes true
cartoon style arrowScale 1.5
color byhetero
# Subunit colors from color_code/subunit_color_code.csv.
# pre-mRNA
color #382.1/A #303030
# U2-Sm SNRPF
color #382.1/2d #D5F5E3
# U4-Sm SNRPF
color #382.1/4d #F7F0A6
# U5-Sm SNRPF
color #382.1/5d #B0C4DE
# U2-Sm SNRPE
color #382.1/2e #D5F5E3
# U4-Sm SNRPE
color #382.1/4e #F7F0A6
# U5-Sm SNRPE
color #382.1/5e #B0C4DE
# U2-Sm SNRPG
color #382.1/2f #D5F5E3
# U4-Sm SNRPG
color #382.1/4f #F7F0A6
# U5-Sm SNRPG
color #382.1/5f #B0C4DE
