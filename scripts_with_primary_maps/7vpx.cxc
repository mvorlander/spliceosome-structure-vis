# Lightweight ChimeraX script for 7VPX
# Models are downloaded directly by ChimeraX from the PDB.
# Primary maps, when requested, are downloaded directly from EMDB.
# Original deposited chain identifiers are used.

# Shared anchor frame: 8H6L
# Structure group: #373; target model: #373.1; RNA labels: #373.2.

open 8h6l id 373.9 name 8H6L_anchor
open 7vpx id 373.1 name 7VPX
open emdb:32074 id 373.3.1 name 7VPX_EMD-32074_primary_map
rename #373 U2_pre_A_A_7vpx_structure

# Align on SF3B1.
matchmaker #373.1/1 to #373.9/2G bring #373.3.1
close #373.9

hide atoms
cartoon
# Default display style.
style (protein|nucleic|solvent) & @@draw_mode=0 stick
cartoon style modeh def arrows t arrowshelix f arrowscale 3 wid 4 thick 3 sides 12 div 20
cartoon style ~(nucleic|strand) x round
cartoon style (nucleic|strand) x rect
cartoon style nucleic x round width 4 thick 4
lighting shadows false
lighting simple
camera ortho
lighting soft intensity 0.2 fillIntensity 0.5 ambientIntensity 1
lighting soft
# window
# windowsize 800 800

# bg and model colors
set bgColor white
style nucleic stick
graphics silhouettes true
cartoon style arrowScale 1.5
color byhetero
# Subunit colors from color_code/subunit_color_code.csv.
# SF3A2
color #373.1/B #75A074
# SF3A1
color #373.1/A #55947F
# SF3A3
color #373.1/C #9BCF91
# DDX46
color #373.1/E #5BAE8A
# SNRPA1
color #373.1/F #58D68D
# SNRPB2
color #373.1/G #DAF7A6
# U2-Sm SNRPD2
color #373.1/a #D5F5E3
# U1-Sm SNRPD2
color #373.1/i #EAD7E8
# U2-Sm SNRPF
color #373.1/b #D5F5E3
# U1-Sm SNRPF
color #373.1/m #EAD7E8
# U2-Sm SNRPE
color #373.1/c #D5F5E3
# U1-Sm SNRPE
color #373.1/l #EAD7E8
# U2-Sm SNRPG
color #373.1/d #D5F5E3
# U1-Sm SNRPG
color #373.1/n #EAD7E8
# U2-Sm SNRPD3
color #373.1/e #D5F5E3
# U1-Sm SNRPD3
color #373.1/j #EAD7E8
# SF1
color #373.1/D #BA4F9A
# U2-Sm SNRPB
color #373.1/f #D5F5E3
# U1-Sm SNRPB
color #373.1/k #EAD7E8
# U2-Sm SNRPD1
color #373.1/g #D5F5E3
# U1-Sm SNRPD1
color #373.1/h #EAD7E8
# pre-mRNA
color #373.1/I #303030
# pre-mRNA
color #373.1/K #303030
# U1 snRNA
color #373.1/L #B66AAE
# SNRNP70
color #373.1/O #8C3D78
# SNRPA
color #373.1/M #C07AB6
# SNRPC
color #373.1/N #D7A3CF
# PHF5A
color #373.1/6 #375A40
# DNAJC8
color #373.1/J #6E86A6
# U2 snRNA
color #373.1/H #006400
# SF3B1
color #373.1/1 #487957
# SF3B2
color #373.1/2 #49926C
# SF3B3
color #373.1/3 #6A9064
# SF3B4
color #373.1/4 #77B088
# SF3B5
color #373.1/5 #92BB8F
# Named selections for subcomplexes using original deposited chain IDs.
# RNA/substrate
# selector_meta {"color":"#303030","family":"RNA","group":"pre-mRNA features","kind":"subcomplex"}
name pdb_7VPX_RNA_substrate #373.1/I,K
# U1 Sm ring
# selector_meta {"color":"#B66AAE","family":"Protein/RNP groups","group":"U1 snRNP groups","kind":"subcomplex"}
name pdb_7VPX_U1_Sm_ring #373.1/h,i,j,k,l,m,n
# U1 snRNP
# selector_meta {"color":"#B66AAE","family":"Protein/RNP groups","group":"U1 snRNP groups","kind":"subcomplex"}
name pdb_7VPX_U1_snRNP #373.1/L,M,N,O
# U2 Sm ring
# selector_meta {"color":"#BFE6BF","family":"Protein/RNP groups","group":"U2/SF3B groups","kind":"subcomplex"}
name pdb_7VPX_U2_Sm_ring #373.1/a,b,c,d,e,f,g
# U2 snRNP
# selector_meta {"color":"#2F8B4D","family":"Protein/RNP groups","group":"U2/SF3B groups","kind":"subcomplex"}
name pdb_7VPX_U2_snRNP #373.1/E,F,G,H
# U2/SF3B
# selector_meta {"color":"#6DBE70","family":"Protein/RNP groups","group":"U2/SF3B groups","kind":"subcomplex"}
name pdb_7VPX_U2_SF3B #373.1/1,2,3,4,5,6,A,B,C
# other
# selector_meta {"color":"#9CA3AF","family":"Protein/RNP groups","group":"other protein/RNP groups","kind":"subcomplex"}
name pdb_7VPX_other #373.1/D,J
# Named selections for resolved substrate RNA features.
# 5' exon: residues -1-0; 27-41, five-ss-inference, medium confidence, validation not_applicable
# selector_meta {"color":"#FF8C00","family":"RNA","feature":"exon_5","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name E_complex_7VPX_5exon #373.1/I:27-41|#373.1/K:-1-0
# substrate RNA: residues -1-8; 27-41, component, medium confidence, validation not_applicable
# selector_meta {"color":"#303030","family":"RNA","feature":"substrate","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name E_complex_7VPX_substrate #373.1/I:27-41|#373.1/K:-1-8
# 5' splice site: residues -1-8; 1-6, component-name/network-scored-motif, high/medium confidence, validation uncertain/validated uncertain validation
# selector_meta {"color":"#303030","family":"RNA","feature":"five_prime_splice_site","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name E_complex_7VPX_5SS #373.1/K:-1-8|#373.1/K:1-6
# intron from 5' splice site: residues 1-8, five-ss-inference, low confidence, validation not_applicable
# selector_meta {"color":"#303030","family":"RNA","feature":"intron","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name E_complex_7VPX_intron #373.1/K:1-8
# Named selections for resolved snRNA functional regions.
# U1 snRNA 5' splice-site recognition region: residues 1-10, review-region, medium confidence
# selector_meta {"color":"#B66AAE","family":"RNA","feature":"U1_5prime_5SS_recognition","group":"snRNA-pre-mRNA regions","group_key":"snRNA_pre_mRNA_regions","kind":"rna_feature"}
name E_complex_7VPX_U1_5_5SS_recognition #373.1/L:1-10
# U1 snRNA stem-loop 1: residues 11-45, review-region, low confidence
# selector_meta {"color":"#BF72B7","family":"RNA","feature":"U1_SL1","group":"internal stem loops","group_key":"internal_stem_loops","kind":"rna_feature"}
name E_complex_7VPX_U1_SL1 #373.1/L:11-45
# U1 snRNA stem-loop 2: residues 46-95, review-region, low confidence
# selector_meta {"color":"#AD62A6","family":"RNA","feature":"U1_SL2","group":"internal stem loops","group_key":"internal_stem_loops","kind":"rna_feature"}
name E_complex_7VPX_U1_SL2 #373.1/L:46-95
# U2 snRNA branchpoint pairing region: residues 34-41, sequence-motif-neighborhood, medium confidence
# selector_meta {"color":"#0B6E2D","family":"RNA","feature":"U2_branchpoint_pairing_region","group":"snRNA-pre-mRNA regions","group_key":"snRNA_pre_mRNA_regions","kind":"rna_feature"}
name E_complex_7VPX_U2_branchpoint_pairing_region #373.1/H:34-41
# U2 snRNA stem IIa: residues 46-65;69-73;81-82, review-region, low confidence
# selector_meta {"color":"#167A38","family":"RNA","feature":"U2_stem_IIa","group":"internal stem loops","group_key":"internal_stem_loops","kind":"rna_feature"}
name E_complex_7VPX_U2_stem_IIa #373.1/H:46-65,69-73,81-82
# U2 snRNA Sm site: residues 99-105, sequence-motif, medium confidence
# selector_meta {"color":"#2F8B4D","family":"RNA","feature":"U2_Sm_site","group":"other snRNA regions","group_key":"other_snRNA_regions","kind":"rna_feature"}
name E_complex_7VPX_U2_Sm_site #373.1/H:99-105
# RNA feature nucleotide display.
select #373.1 & nucleic
nucleotides sel atoms
select clear
# 5' exon: residues -1-0; 27-41
color #373.1/I:27-41|#373.1/K:-1-0 #FF8C00
select #373.1/I:27-41|#373.1/K:-1-0
nucleotides sel fill
select clear
# 5'SS: residues -1-8; 1-6
# intron: residues 1-8
# U1 5'SS recog.: residues 1-10
color #373.1/L:1-10 #B66AAE
select #373.1/L:1-10
nucleotides sel fill
select clear
# U1 SL1: residues 11-45
color #373.1/L:11-45 #BF72B7
select #373.1/L:11-45
nucleotides sel fill
select clear
# U1 SL2: residues 46-95
color #373.1/L:46-95 #AD62A6
select #373.1/L:46-95
nucleotides sel fill
select clear
# U2 BP pairing: residues 34-41
color #373.1/H:34-41 #0B6E2D
select #373.1/H:34-41
nucleotides sel fill
select clear
# U2 stem IIa: residues 46-65;69-73;81-82
color #373.1/H:46-65,69-73,81-82 #167A38
select #373.1/H:46-65,69-73,81-82
nucleotides sel fill
select clear
# RNA feature 3D residue labels.
# Labels are created as independent grouped models under #373.2.
# Fetch and run the self-contained RNA label script from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/label_scripts/7vpx_rna_labels.py
# Searchable named selection browser.
# In GUI ChimeraX this opens a small panel for selecting, zooming, and toggling RNA labels.
# Fetch and open the self-contained named selection browser from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/selection_browser_scripts/7vpx_selection_browser.py
view
show nucleic
