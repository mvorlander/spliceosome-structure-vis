color #405.1/2B #DAF7A6
# U2-Sm SNRPF
color #405.1/2f #D5F5E3
# U4-Sm SNRPF
color #405.1/4f #F7F0A6
# U5-Sm SNRPF
color #405.1/5f #B0C4DE
# U2-Sm SNRPB
color #405.1/2b #D5F5E3
# U2-Sm SNRPD3
color #405.1/23 #D5F5E3
# U4-Sm SNRPD3
color #405.1/43 #F7F0A6
# U5-Sm SNRPD3
