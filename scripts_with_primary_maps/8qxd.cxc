# Lightweight ChimeraX script for 8QXD
# Models are downloaded directly by ChimeraX from the PDB.
# Primary maps, when requested, are downloaded directly from EMDB.
# Original deposited chain identifiers are used.

# Shared anchor frame: 8H6L
# Structure group: #405; target model: #405.1; RNA labels: #405.2.

open 8h6l id 405.9 name 8H6L_anchor
open 8qxd id 405.1 name 8QXD
open emdb:18718 id 405.3.1 name 8QXD_EMD-18718_primary_map
rename #405 pre_B_8qxd_structure

# Align on PRPF8.
matchmaker #405.1/A to #405.9/5B bring #405.3.1
close #405.9

hide atoms
cartoon
# Default display style.
style (protein|nucleic|solvent) & @@draw_mode=0 stick
cartoon style modeh def arrows t arrowshelix f arrowscale 3 wid 4 thick 3 sides 12 div 20
cartoon style ~(nucleic|strand) x round
cartoon style (nucleic|strand) x rect
cartoon style nucleic x round width 4 thick 4
lighting shadows false
lighting simple
camera ortho
lighting soft intensity 0.2 fillIntensity 0.5 ambientIntensity 1
lighting soft
# window
# windowsize 800 800

# bg and model colors
set bgColor white
style nucleic stick
graphics silhouettes true
cartoon style arrowScale 1.5
color byhetero
# Subunit colors from color_code/subunit_color_code.csv.
# PRPF8
color #405.1/A #BFC3E8
# TXNL4A
color #405.1/D #C3BA7A
# PRP8BP
color #405.1/E #E2F3F4
# PRPF4
color #405.1/F #E2C496
# NHP2L1
color #405.1/M #A89264
# RBM42
color #405.1/R #44A0A7
# USP39
color #405.1/U #B37E6A
# SNRNP27
color #405.1/X #F4E7D2
# pre-mRNA
color #405.1/Z #303030
# SART1
color #405.1/S #D6937B
# PRPF3
color #405.1/J #E1DD1B
# SNRNP200
color #405.1/B #AFEEEE
# PRPF4
color #405.1/K #E2C496
# PRPF6
color #405.1/N #CFA785
