select #323.1/H:46-65,68-74,78-80
nucleotides sel fill
select clear
# U5 loop I: residues 38-42
color #323.1/B:38-42 #1B3CD0
select #323.1/B:38-42
nucleotides sel fill
select clear
# U6 5' terminal SL: residues 1-30
color #323.1/F:1-30 #DC143C
select #323.1/F:1-30
nucleotides sel fill
select clear
# U2/U6 helix I: residues 35-60
color #323.1/F:35-60 #D0183C
select #323.1/F:35-60
nucleotides sel fill
select clear
# U6 5'SS contact: residues 38-49
color #323.1/F:38-49 #E01842
select #323.1/F:38-49
nucleotides sel fill
select clear
# U6 ACAGAGA: residues 41-47
color #323.1/F:41-47 #DC143C
select #323.1/F:41-47
nucleotides sel fill
select clear
# U6 ISL: residues 79;84-97
color #323.1/F:79,84-97 #D61A3D
select #323.1/F:79,84-97
nucleotides sel fill
select clear
# U6 AGC triad: residues 92-94
color #323.1/F:92-94 #C91236
select #323.1/F:92-94
nucleotides sel fill
select clear
# RNA feature 3D residue labels.
# Labels are created as independent grouped models under #323.2.
# Fetch and run the self-contained RNA label script from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/label_scripts/5z56_rna_labels.py
# Searchable named selection browser.
# In GUI ChimeraX this opens a small panel for selecting, zooming, and toggling RNA labels.
# Fetch and open the self-contained named selection browser from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/selection_browser_scripts/5z56_selection_browser.py
view
show nucleic
