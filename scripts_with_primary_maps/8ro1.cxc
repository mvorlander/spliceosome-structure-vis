# Lightweight ChimeraX script for 8RO1
# Models are downloaded directly by ChimeraX from the PDB.
# Primary maps, when requested, are downloaded directly from EMDB.
# Original deposited chain identifiers are used.

# Shared anchor frame: 8H6L
# Structure group: #414; target model: #414.1; RNA labels: #414.2.

open 8h6l id 414.9 name 8H6L_anchor
open 8ro1 id 414.1 name 8RO1
open emdb:19398 id 414.3.1 name 8RO1_EMD-19398_primary_map
rename #414 ILS_8ro1_structure

# Align on PRPF8.
matchmaker #414.1/A to #414.9/5B bring #414.3.1
close #414.9

hide atoms
cartoon
# Default display style.
style (protein|nucleic|solvent) & @@draw_mode=0 stick
cartoon style modeh def arrows t arrowshelix f arrowscale 3 wid 4 thick 3 sides 12 div 20
cartoon style ~(nucleic|strand) x round
cartoon style (nucleic|strand) x rect
cartoon style nucleic x round width 4 thick 4
lighting shadows false
lighting simple
camera ortho
lighting soft intensity 0.2 fillIntensity 0.5 ambientIntensity 1
lighting soft
# window
# windowsize 800 800

# bg and model colors
set bgColor white
style nucleic stick
graphics silhouettes true
cartoon style arrowScale 1.5
color byhetero
# Subunit colors from color_code/subunit_color_code.csv.
# U2 snRNA
color #414.1/2 #006400
# INTRON
color #414.1/IN #303030
# CRNKL1
color #414.1/J #FFC388
# BCAS2
color #414.1/K #FFDAB9
# CDC5L
color #414.1/L #DAA520
# CWF19L1
color #414.1/L1 #DDA0DD
# CWF19L2
color #414.1/L2 #8B008B
# SYF2
color #414.1/M #FF8C00
# BUD31
color #414.1/N #FFF584
# RBM22
color #414.1/O #DE9A52
# CWC15
color #414.1/P #FFDEAD
# U5 snRNA
color #414.1/5 #0000CD
# PAXBP1
color #414.1/PX #FFC0CB
# AQR
color #414.1/Q #FFDAB9
# SNW1
color #414.1/R #D49F96
# PPIL1
color #414.1/S #EEE8AA
# PLRG1
color #414.1/T #F4A460
# TFIP11
color #414.1/TF #FF69B4
# PRPF17
color #414.1/W #FFF7C9
# SDE2
color #414.1/X #FFFF00
# CCDC12
color #414.1/Z #FAEBD7
# U5-Sm SNRPD3
color #414.1/a #B0C4DE
# U2-Sm SNRPD3
color #414.1/h #D5F5E3
# U6 snRNA
color #414.1/6 #DC143C
# U5-Sm SNRPB
color #414.1/b #B0C4DE
# U2-Sm SNRPB
color #414.1/i #D5F5E3
# U5-Sm SNRPD1
color #414.1/c #B0C4DE
# U2-Sm SNRPD1
color #414.1/j #D5F5E3
# U5-Sm SNRPD2
color #414.1/d #B0C4DE
# U2-Sm SNRPD2
color #414.1/k #D5F5E3
# U5-Sm SNRPE
color #414.1/e #B0C4DE
# U2-Sm SNRPE
color #414.1/l #D5F5E3
# U5-Sm SNRPF
color #414.1/f #B0C4DE
# U2-Sm SNRPF
color #414.1/m #D5F5E3
# U5-Sm SNRPG
color #414.1/g #B0C4DE
# U2-Sm SNRPG
color #414.1/n #D5F5E3
# SNRPA1
color #414.1/o #58D68D
# SNRPB2
color #414.1/p #DAF7A6
# PRPF19
color #414.1/q #FFFFAB
# PRPF19
color #414.1/r #FFFFAB
# PRPF19
color #414.1/s #FFFFAB
# PRPF19
color #414.1/t #FFFFAB
# PPIE
color #414.1/y #FFFFE0
# PRPF8
color #414.1/A #BFC3E8
# EFTUD2
color #414.1/C #6495ED
# ISY1
color #414.1/D #FFEF8C
# DHX15
color #414.1/DX #663399
# PRP8BP
color #414.1/E #E2F3F4
# SYF1
color #414.1/I #FF957B
# Named selections for subcomplexes using original deposited chain IDs.
# Disassembly factors
# selector_meta {"color":"#FF69B4","family":"Protein/RNP groups","group":"disassembly factors","kind":"subcomplex"}
name pdb_8RO1_Disassembly_factors #414.1/PX,TF
# NTC/NTR related
# selector_meta {"color":"#F4BF67","family":"Protein/RNP groups","group":"NTC/NTR groups","kind":"subcomplex"}
name pdb_8RO1_NTC_NTR_related #414.1/D,I,J,L2,M,N,O,Q,R,S,y
# NTC/PRP19
# selector_meta {"color":"#F4BF67","family":"Protein/RNP groups","group":"NTC/NTR groups","kind":"subcomplex"}
name pdb_8RO1_NTC_PRP19 #414.1/K,L,P,T,q,r,s,t
# RNA/substrate
# selector_meta {"color":"#303030","family":"RNA","group":"pre-mRNA features","kind":"subcomplex"}
name pdb_8RO1_RNA_substrate #414.1/IN
# Second step factors
# selector_meta {"color":"#9CA3AF","family":"Protein/RNP groups","group":"other protein/RNP groups","kind":"subcomplex"}
name pdb_8RO1_Second_step_factors #414.1/W
# U2 Sm ring
# selector_meta {"color":"#BFE6BF","family":"Protein/RNP groups","group":"U2/SF3B groups","kind":"subcomplex"}
name pdb_8RO1_U2_Sm_ring #414.1/h,i,j,k,l,m,n
# U2 snRNP
# selector_meta {"color":"#2F8B4D","family":"Protein/RNP groups","group":"U2/SF3B groups","kind":"subcomplex"}
name pdb_8RO1_U2_snRNP #414.1/2,DX,o,p
# U5 Sm ring
# selector_meta {"color":"#BFC3E8","family":"Protein/RNP groups","group":"U5 snRNP groups","kind":"subcomplex"}
name pdb_8RO1_U5_Sm_ring #414.1/a,b,c,d,e,f,g
# U5 snRNP
# selector_meta {"color":"#0000CD","family":"Protein/RNP groups","group":"U5 snRNP groups","kind":"subcomplex"}
name pdb_8RO1_U5_snRNP #414.1/5,A,C,E
# U6 snRNP
# selector_meta {"color":"#DC143C","family":"Protein/RNP groups","group":"U6 snRNP groups","kind":"subcomplex"}
name pdb_8RO1_U6_snRNP #414.1/6
# other
# selector_meta {"color":"#9CA3AF","family":"Protein/RNP groups","group":"other protein/RNP groups","kind":"subcomplex"}
name pdb_8RO1_other #414.1/L1,X,Z
# Named selections for resolved substrate RNA features.
# intron: residues 1-2;10-28;40-51, component-name, high confidence, validation not_applicable
# selector_meta {"color":"#303030","family":"RNA","feature":"intron","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name ILS_disassembly_8RO1_intron #414.1/IN:1-2,10-28,40-51
# intron lariat: residues 1-2;10-28;40-51, component-name, high confidence, validation not_applicable
# selector_meta {"color":"#303030","family":"RNA","feature":"intron_lariat","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name ILS_disassembly_8RO1_intron_lariat #414.1/IN:1-2,10-28,40-51
# substrate RNA: residues 1-2;10-28;40-51, component, medium confidence, validation not_applicable
# selector_meta {"color":"#303030","family":"RNA","feature":"substrate","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name ILS_disassembly_8RO1_substrate #414.1/IN:1-2,10-28,40-51
# Named selections for resolved snRNA functional regions.
# U2 snRNA U2/U6 helix I partner: residues 26-30, review-region, high confidence
# selector_meta {"color":"#047857","family":"RNA","feature":"U2_U6_helix_I_partner","group":"snRNA-snRNA interacting regions","group_key":"snRNA_snRNA_regions","kind":"rna_feature"}
name ILS_disassembly_8RO1_U2_U6_helix_I_partner #414.1/2:26-30
# U2 snRNA branchpoint pairing region: residues 34-42, sequence-motif-neighborhood, medium confidence
# selector_meta {"color":"#0B6E2D","family":"RNA","feature":"U2_branchpoint_pairing_region","group":"snRNA-pre-mRNA regions","group_key":"snRNA_pre_mRNA_regions","kind":"rna_feature"}
name ILS_disassembly_8RO1_U2_branchpoint_pairing_region #414.1/2:34-42
# U5 snRNA loop I: residues 41-45, sequence-motif, medium confidence
# selector_meta {"color":"#1B3CD0","family":"RNA","feature":"U5_loop_I","group":"snRNA-pre-mRNA regions","group_key":"snRNA_pre_mRNA_regions","kind":"rna_feature"}
name ILS_disassembly_8RO1_U5_loop_I #414.1/5:41-45
# U5 snRNA Sm site: residues 93-99, sequence-motif, medium confidence
# selector_meta {"color":"#9CA3AF","family":"RNA","feature":"U5_Sm_site","group":"other snRNA regions","group_key":"other_snRNA_regions","kind":"rna_feature"}
name ILS_disassembly_8RO1_U5_Sm_site #414.1/5:93-99
# U6 snRNA U2/U6 helix I partner: residues 30-55, motif-neighborhood, medium confidence
# selector_meta {"color":"#D0183C","family":"RNA","feature":"U6_U2_helix_I_partner","group":"snRNA-snRNA interacting regions","group_key":"snRNA_snRNA_regions","kind":"rna_feature"}
name ILS_disassembly_8RO1_U6_U2_helix_I_partner #414.1/6:30-55
# U6 snRNA 5' splice-site upstream contact: residues 33-44, motif-neighborhood, medium confidence
# selector_meta {"color":"#E01842","family":"RNA","feature":"U6_5SS_upstream_contact","group":"other snRNA regions","group_key":"other_snRNA_regions","kind":"rna_feature"}
name ILS_disassembly_8RO1_U6_5SS_upstream_contact #414.1/6:33-44
# U6 snRNA ACAGAGA box: residues 36-42, sequence-motif, high confidence
# selector_meta {"color":"#DC143C","family":"RNA","feature":"U6_ACAGAGA_box","group":"other snRNA regions","group_key":"other_snRNA_regions","kind":"rna_feature"}
name ILS_disassembly_8RO1_U6_ACAGAGA_box #414.1/6:36-42
# U6 snRNA internal stem-loop: residues 74-101, motif-neighborhood, low confidence
# selector_meta {"color":"#D61A3D","family":"RNA","feature":"U6_ISL","group":"internal stem loops","group_key":"internal_stem_loops","kind":"rna_feature"}
name ILS_disassembly_8RO1_U6_ISL #414.1/6:74-101
# U6 snRNA AGC catalytic triad: residues 87-89, sequence-motif, medium confidence
# selector_meta {"color":"#C91236","family":"RNA","feature":"U6_AGC_catalytic_triad","group":"catalytic core regions","group_key":"catalytic_core_regions","kind":"rna_feature"}
name ILS_disassembly_8RO1_U6_AGC_catalytic_triad #414.1/6:87-89
# U6 snRNA LSm site: residues 92-101, terminal-region, low confidence
# selector_meta {"color":"#E33A55","family":"RNA","feature":"U6_LSm_site","group":"other snRNA regions","group_key":"other_snRNA_regions","kind":"rna_feature"}
name ILS_disassembly_8RO1_U6_LSm_site #414.1/6:92-101
# RNA feature nucleotide display.
select #414.1 & nucleic
nucleotides sel atoms
select clear
# intron: residues 1-2;10-28;40-51
# lariat: residues 1-2;10-28;40-51
# U2/U6 helix I: residues 26-30
color #414.1/2:26-30 #047857
select #414.1/2:26-30
nucleotides sel fill
select clear
# U2 BP pairing: residues 34-42
color #414.1/2:34-42 #0B6E2D
select #414.1/2:34-42
nucleotides sel fill
select clear
# U5 loop I: residues 41-45
color #414.1/5:41-45 #1B3CD0
select #414.1/5:41-45
nucleotides sel fill
select clear
# Sm site: residues 93-99
color #414.1/5:93-99 #F97316
select #414.1/5:93-99
nucleotides sel fill
select clear
# U2/U6 helix I: residues 30-55
color #414.1/6:30-55 #D0183C
select #414.1/6:30-55
nucleotides sel fill
select clear
# U6 5'SS contact: residues 33-44
color #414.1/6:33-44 #E01842
select #414.1/6:33-44
nucleotides sel fill
select clear
# U6 ACAGAGA: residues 36-42
color #414.1/6:36-42 #DC143C
select #414.1/6:36-42
nucleotides sel fill
select clear
# U6 ISL: residues 74-101
color #414.1/6:74-101 #D61A3D
select #414.1/6:74-101
nucleotides sel fill
select clear
# U6 AGC triad: residues 87-89
color #414.1/6:87-89 #C91236
select #414.1/6:87-89
nucleotides sel fill
select clear
# RNA feature 3D residue labels.
# Labels are created as independent grouped models under #414.2.
# Fetch and run the self-contained RNA label script from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/label_scripts/8ro1_rna_labels.py
# Searchable named selection browser.
# In GUI ChimeraX this opens a small panel for selecting and zooming named selections.
# Fetch and open the self-contained named selection browser from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/selection_browser_scripts/8ro1_selection_browser.py
view
show nucleic
