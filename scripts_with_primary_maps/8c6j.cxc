# U5-Sm SNRPD2
color #377.1/a #B0C4DE
# U2-Sm SNRPD2
color #377.1/m #D5F5E3
# U6 snRNA
color #377.1/6 #DC143C
# U5-Sm SNRPB
color #377.1/b #B0C4DE
# U2-Sm SNRPB
color #377.1/k #D5F5E3
