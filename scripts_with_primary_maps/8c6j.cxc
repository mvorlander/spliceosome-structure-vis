# Lightweight ChimeraX script for 8C6J
# Models are downloaded directly by ChimeraX from the PDB.
# Primary maps, when requested, are downloaded directly from EMDB.
# Original deposited chain identifiers are used.

# Shared anchor frame: 8H6L
# Structure group: #377; target model: #377.1; RNA labels: #377.2.

open 8h6l id 377.9 name 8H6L_anchor
open 8c6j id 377.1 name 8C6J
open emdb:16452 id 377.3.1 name 8C6J_EMD-16452_primary_map
rename #377 Cstar_8c6j_structure

# Align on PRPF8.
matchmaker #377.1/A to #377.9/5B bring #377.3.1
close #377.9

hide atoms
cartoon
# Default display style.
style (protein|nucleic|solvent) & @@draw_mode=0 stick
cartoon style modeh def arrows t arrowshelix f arrowscale 3 wid 4 thick 3 sides 12 div 20
cartoon style ~(nucleic|strand) x round
cartoon style (nucleic|strand) x rect
cartoon style nucleic x round width 4 thick 4
lighting shadows false
lighting simple
camera ortho
lighting soft intensity 0.2 fillIntensity 0.5 ambientIntensity 1
lighting soft
# window
# windowsize 800 800

# bg and model colors
set bgColor white
style nucleic stick
graphics silhouettes true
cartoon style arrowScale 1.5
color byhetero
# Subunit colors from color_code/subunit_color_code.csv.
# U2 snRNA
color #377.1/2 #006400
# EFTUD2
color #377.1/C #6495ED
# PPIL3
color #377.1/C3 #57389F
# DDX41
color #377.1/CD #EE82EE
# PPIE
color #377.1/CE #FFFFE0
# FAM50A
color #377.1/CF #CCCCFF
# ISY1
color #377.1/CI #FFEF8C
# NOSIP
color #377.1/CN #6987A9
# C9orf78
color #377.1/CT #D9CCFF
# PRKRIP1
color #377.1/D #B39C7B
# pre-mRNA
color #377.1/E #303030
# ESS2
color #377.1/4 #6669B0
# CACTIN
color #377.1/F #E3C2CF
