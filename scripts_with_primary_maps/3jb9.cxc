# Lightweight ChimeraX script for 3JB9
# Models are downloaded directly by ChimeraX from the PDB.
# Primary maps, when requested, are downloaded directly from EMDB.
# Original deposited chain identifiers are used.

# Shared anchor frame: 8H6L
# Structure group: #301; target model: #301.1; RNA labels: #301.2.

open 8h6l id 301.9 name 8H6L_anchor
open 3jb9 id 301.1 name 3JB9
open emdb:6413 id 301.3.1 name 3JB9_EMD-6413_primary_map
rename #301 ILS_3jb9_structure

# Align on PRPF8.
matchmaker #301.1/A to #301.9/5B bring #301.3.1
close #301.9

# Remove implausibly long deposited covalent bonds before styling.
# Fetch and run the implausible-bond pruning helper from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/prune_implausible_bonds.py

hide atoms
cartoon
# Default display style.
style (protein|nucleic|solvent) & @@draw_mode=0 stick
cartoon style modeh def arrows t arrowshelix f arrowscale 3 wid 4 thick 3 sides 12 div 20
cartoon style ~(nucleic|strand) x round
cartoon style (nucleic|strand) x rect
cartoon style nucleic x round width 4 thick 4
lighting shadows false
lighting simple
camera ortho
lighting soft intensity 0.2 fillIntensity 0.5 ambientIntensity 1
lighting soft

# bg and model colors
set bgColor white
style nucleic stick
graphics silhouettes true
cartoon style arrowScale 1.5
color byhetero
# Subunit colors from color_code/subunit_color_code.csv.
# PRPF8
color #301.1/A #BFC3E8
# EFTUD2
color #301.1/B #6495ED
# U5 snRNA
color #301.1/C #4F9FD3
# U5-Sm SNRPD3
color #301.1/D #B0C4DE
# U2-Sm SNRPD3
color #301.1/Z #D5F5E3
# U5-Sm SNRPB
color #301.1/E #B0C4DE
# U2-Sm SNRPB
color #301.1/b #D5F5E3
# U5-Sm SNRPD1
color #301.1/F #B0C4DE
# U2-Sm SNRPD1
color #301.1/f #D5F5E3
# U5-Sm SNRPD2
color #301.1/G #B0C4DE
# U2-Sm SNRPD2
color #301.1/l #D5F5E3
# U5-Sm SNRPE
color #301.1/H #B0C4DE
# U2-Sm SNRPE
color #301.1/m #D5F5E3
# U5-Sm SNRPF
color #301.1/I #B0C4DE
# U2-Sm SNRPF
color #301.1/n #D5F5E3
# U5-Sm SNRPG
color #301.1/J #B0C4DE
# U2-Sm SNRPG
color #301.1/o #D5F5E3
# DDX46
color #301.1/K #5BAE8A
# PRP8BP
color #301.1/L #E2F3F4
# SNW1
color #301.1/M #D49F96
# U6 snRNA
color #301.1/N #EF4444
# mRNA
color #301.1/O #303030
# mRNA
color #301.1/Q #303030
# U2 snRNA
color #301.1/P #71C562
# PRPF19
color #301.1/S #FFFFAB
# PRPF19
color #301.1/T #FFFFAB
# PRPF19
color #301.1/U #FFFFAB
# PRPF19
color #301.1/V #FFFFAB
# CDC5L
color #301.1/W #DAA520
# PRPF3
color #301.1/Y #E1DD1B
# RBM22
color #301.1/a #DE9A52
# CWF19L2
color #301.1/c #8B008B
# PPIL1
color #301.1/d #EEE8AA
# BUD31
color #301.1/e #FFF584
# PRPF17
color #301.1/g #FFF7C9
# CWC15
color #301.1/h #FFDEAD
# BCAS2
color #301.1/i #FFDAB9
# CRNKL1
color #301.1/R #FFC388
# SYF1
color #301.1/r #FF957B
# AQR
color #301.1/X #FFDAB9
# SNRPA1
color #301.1/j #58D68D
# SNRPB2
color #301.1/k #DAF7A6
# Named selections for subcomplexes using original deposited chain IDs.
# NTC/NTR related
# selector_meta {"color":"#F4BF67","family":"Protein/RNP groups","group":"NTC/NTR groups","kind":"subcomplex"}
name pdb_3JB9_NTC_NTR_related #301.1/M,R,X,a,c,d,e,r
# NTC/PRP19
# selector_meta {"color":"#F4BF67","family":"Protein/RNP groups","group":"NTC/NTR groups","kind":"subcomplex"}
name pdb_3JB9_NTC_PRP19 #301.1/S,T,U,V,W,h,i
# RNA/substrate
# selector_meta {"color":"#303030","family":"RNA","group":"pre-mRNA features","kind":"subcomplex"}
name pdb_3JB9_RNA_substrate #301.1/O,Q
# Second step factors
# selector_meta {"color":"#9CA3AF","family":"Protein/RNP groups","group":"other protein/RNP groups","kind":"subcomplex"}
name pdb_3JB9_Second_step_factors #301.1/g
# U2 Sm ring
# selector_meta {"color":"#BFE6BF","family":"Protein/RNP groups","group":"U2/SF3B groups","kind":"subcomplex"}
name pdb_3JB9_U2_Sm_ring #301.1/Z,b,f,l,m,n,o
# U2 snRNP
# selector_meta {"color":"#2F8B4D","family":"Protein/RNP groups","group":"U2/SF3B groups","kind":"subcomplex"}
name pdb_3JB9_U2_snRNP #301.1/K,P,j,k
# U4/U6 snRNP
# selector_meta {"color":"#C3BA7A","family":"Protein/RNP groups","group":"U4/U6 groups","kind":"subcomplex"}
name pdb_3JB9_U4_U6_snRNP #301.1/Y
# U5 Sm ring
# selector_meta {"color":"#BFC3E8","family":"Protein/RNP groups","group":"U5 snRNP groups","kind":"subcomplex"}
name pdb_3JB9_U5_Sm_ring #301.1/D,E,F,G,H,I,J
# U5 snRNP
# selector_meta {"color":"#0000CD","family":"Protein/RNP groups","group":"U5 snRNP groups","kind":"subcomplex"}
name pdb_3JB9_U5_snRNP #301.1/A,B,C,L
# U6 snRNP
# selector_meta {"color":"#DC143C","family":"Protein/RNP groups","group":"U6 snRNP groups","kind":"subcomplex"}
name pdb_3JB9_U6_snRNP #301.1/N
# other
# selector_meta {"color":"#9CA3AF","family":"Protein/RNP groups","group":"other protein/RNP groups","kind":"subcomplex"}
name pdb_3JB9_other #301.1/x
# Named selections for resolved substrate RNA features.
# 5' splice site: residues 100-105, network-scored-motif, medium confidence, validation uncertain uncertain validation
# selector_meta {"color":"#303030","family":"RNA","feature":"five_prime_splice_site","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name ILS_disassembly_3JB9_5SS #301.1/O:100-105
# intron from 5' splice site: residues 100-107, five-ss-inference, low confidence, validation not_applicable
# selector_meta {"color":"#303030","family":"RNA","feature":"intron","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name ILS_disassembly_3JB9_intron #301.1/O:100-107
# substrate RNA: residues 100-107; 492-504, component, medium confidence, validation not_applicable
# selector_meta {"color":"#303030","family":"RNA","feature":"substrate","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name ILS_disassembly_3JB9_substrate #301.1/O:100-107|#301.1/Q:492-504
# Named selections for resolved snRNA functional regions.
# U2 snRNA U2/U6 helix I partner: residues 26-30, review-region, high confidence
# selector_meta {"color":"#047857","family":"RNA","feature":"U2_U6_helix_I_partner","group":"snRNA-snRNA interacting regions","group_key":"snRNA_snRNA_regions","kind":"rna_feature"}
name ILS_disassembly_3JB9_U2_U6_helix_I_partner #301.1/P:26-30
# U2 snRNA branchpoint pairing region: residues 32-41, sequence-motif-neighborhood, medium confidence
# selector_meta {"color":"#0B6E2D","family":"RNA","feature":"U2_branchpoint_pairing_region","group":"snRNA-pre-mRNA regions","group_key":"snRNA_pre_mRNA_regions","kind":"rna_feature"}
name ILS_disassembly_3JB9_U2_branchpoint_pairing_region #301.1/P:32-41
# U5 snRNA loop I: residues 47-51, sequence-motif, medium confidence
# selector_meta {"color":"#1B3CD0","family":"RNA","feature":"U5_loop_I","group":"snRNA-pre-mRNA regions","group_key":"snRNA_pre_mRNA_regions","kind":"rna_feature"}
name ILS_disassembly_3JB9_U5_loop_I #301.1/C:47-51
# U6 snRNA U2/U6 helix I partner: residues 29-54, motif-neighborhood, medium confidence
# selector_meta {"color":"#D0183C","family":"RNA","feature":"U6_U2_helix_I_partner","group":"snRNA-snRNA interacting regions","group_key":"snRNA_snRNA_regions","kind":"rna_feature"}
name ILS_disassembly_3JB9_U6_U2_helix_I_partner #301.1/N:29-54
# U6 snRNA 5' splice-site upstream contact: residues 32-43, motif-neighborhood, medium confidence
# selector_meta {"color":"#E01842","family":"RNA","feature":"U6_5SS_upstream_contact","group":"other snRNA regions","group_key":"other_snRNA_regions","kind":"rna_feature"}
name ILS_disassembly_3JB9_U6_5SS_upstream_contact #301.1/N:32-43
# U6 snRNA ACAGAGA box: residues 35-41, sequence-motif, high confidence
# selector_meta {"color":"#DC143C","family":"RNA","feature":"U6_ACAGAGA_box","group":"other snRNA regions","group_key":"other_snRNA_regions","kind":"rna_feature"}
name ILS_disassembly_3JB9_U6_ACAGAGA_box #301.1/N:35-41
# RNA feature nucleotide display.
select #301.1 & nucleic
nucleotides sel atoms
select clear
# 5'SS: residues 100-105
# intron: residues 100-107
# U2/U6 helix I: residues 26-30
color #301.1/P:26-30 #047857
select #301.1/P:26-30
nucleotides sel fill
select clear
# U2 BP pairing: residues 32-41
color #301.1/P:32-41 #0B6E2D
select #301.1/P:32-41
nucleotides sel fill
select clear
# U5 loop I: residues 47-51
color #301.1/C:47-51 #1B3CD0
select #301.1/C:47-51
nucleotides sel fill
select clear
# U2/U6 helix I: residues 29-54
color #301.1/N:29-54 #D0183C
select #301.1/N:29-54
nucleotides sel fill
select clear
# U6 5'SS contact: residues 32-43
color #301.1/N:32-43 #E01842
select #301.1/N:32-43
nucleotides sel fill
select clear
# U6 ACAGAGA: residues 35-41
color #301.1/N:35-41 #DC143C
select #301.1/N:35-41
nucleotides sel fill
select clear
# RNA feature 3D residue labels.
# Labels are created as independent grouped models under #301.2.
# Fetch and run the self-contained RNA label script from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/label_scripts/3jb9_rna_labels.py
# Searchable named selection browser.
# In GUI ChimeraX this opens a small panel for selecting, zooming, and toggling RNA labels.
# Fetch and open the self-contained named selection browser from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/selection_browser_scripts/3jb9_selection_browser.py
view
show nucleic
