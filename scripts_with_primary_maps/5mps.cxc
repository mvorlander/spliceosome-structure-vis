# Lightweight ChimeraX script for 5MPS
# Models are downloaded directly by ChimeraX from the PDB.
# Primary maps, when requested, are downloaded directly from EMDB.
# Original deposited chain identifiers are used.

# Shared anchor frame: 8H6L
# Structure group: #313; target model: #313.1; RNA labels: #313.2.

open 8h6l id 313.9 name 8H6L_anchor
open 5mps id 313.1 name 5MPS
open emdb:3539 id 313.3.1 name Cstar_5mps_EMD-3539_primary_map
rename #313 Cstar_5mps_structure

# Align on PRPF8.
matchmaker #313.1/A to #313.9/5B bring #313.3.1
close #313.9

# Remove implausibly long deposited covalent bonds before styling.
# Fetch and run the implausible-bond pruning helper from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/prune_implausible_bonds.py

hide atoms
cartoon
# Default display style.
style (protein|nucleic|solvent) & @@draw_mode=0 stick
cartoon style modeh def arrows t arrowshelix f arrowscale 3 wid 4 thick 3 sides 12 div 20
cartoon style ~(nucleic|strand) x round
cartoon style (nucleic|strand) x rect
cartoon style nucleic x round width 4 thick 4
lighting shadows false
lighting simple
camera ortho
lighting soft intensity 0.2 fillIntensity 0.5 ambientIntensity 1
lighting soft

# bg and model colors
set bgColor white
style nucleic stick
graphics silhouettes true
cartoon style arrowScale 1.5
color byhetero
# Subunit colors from color_code/subunit_color_code.csv.
# INTRON
color #313.1/I #303030
# EXON
color #313.1/E #303030
# U2 snRNA
color #313.1/2 #71C562
# U6 snRNA
color #313.1/6 #EF4444
# U5 snRNA
color #313.1/5 #4F9FD3
# PRPF8
color #313.1/A #BFC3E8
# EFTUD2
color #313.1/C #6495ED
# CWC22
color #313.1/H #2C54DD
# PLRG1
color #313.1/J #F4A460
# SNW1
color #313.1/K #D49F96
# BUD31
color #313.1/L #FFF584
# CWC2
color #313.1/M #E6B566
# RBM22
color #313.1/N #DE9A52
# CDC5L
color #313.1/O #DAA520
# CWC15
color #313.1/P #FFDEAD
# CRNKL1
color #313.1/S #FFC388
# SYF1
color #313.1/T #FF957B
# SLU7
color #313.1/c #5A338B
# PRPF17
color #313.1/o #FFF7C9
# SYF2
color #313.1/y #FF8C00
# U5-Sm SNRPB
color #313.1/b #B0C4DE
# U5-Sm SNRPD3
color #313.1/d #B0C4DE
# U5-Sm SNRPE
color #313.1/e #B0C4DE
# U5-Sm SNRPF
color #313.1/f #B0C4DE
# U5-Sm SNRPG
color #313.1/g #B0C4DE
# U5-Sm SNRPD1
color #313.1/h #B0C4DE
# U5-Sm SNRPD2
color #313.1/j #B0C4DE
# Named selections for subcomplexes using original deposited chain IDs.
# EJC/mRNP
# selector_meta {"color":"#EAA439","family":"Protein/RNP groups","group":"EJC/mRNP groups","kind":"subcomplex"}
name pdb_5MPS_EJC_mRNP #313.1/H
# NTC/NTR related
# selector_meta {"color":"#F4BF67","family":"Protein/RNP groups","group":"NTC/NTR groups","kind":"subcomplex"}
name pdb_5MPS_NTC_NTR_related #313.1/K,L,M,N,S,T,y
# NTC/PRP19
# selector_meta {"color":"#F4BF67","family":"Protein/RNP groups","group":"NTC/NTR groups","kind":"subcomplex"}
name pdb_5MPS_NTC_PRP19 #313.1/J,O,P
# RNA/substrate
# selector_meta {"color":"#303030","family":"RNA","group":"pre-mRNA features","kind":"subcomplex"}
name pdb_5MPS_RNA_substrate #313.1/E,I
# Second step factors
# selector_meta {"color":"#9CA3AF","family":"Protein/RNP groups","group":"other protein/RNP groups","kind":"subcomplex"}
name pdb_5MPS_Second_step_factors #313.1/c,o
# U2 snRNP
# selector_meta {"color":"#2F8B4D","family":"Protein/RNP groups","group":"U2/SF3B groups","kind":"subcomplex"}
name pdb_5MPS_U2_snRNP #313.1/2
# U5 Sm ring
# selector_meta {"color":"#BFC3E8","family":"Protein/RNP groups","group":"U5 snRNP groups","kind":"subcomplex"}
name pdb_5MPS_U5_Sm_ring #313.1/b,d,e,f,g,h,j
# U5 snRNP
# selector_meta {"color":"#0000CD","family":"Protein/RNP groups","group":"U5 snRNP groups","kind":"subcomplex"}
name pdb_5MPS_U5_snRNP #313.1/5,A,C
# U6 snRNP
# selector_meta {"color":"#DC143C","family":"Protein/RNP groups","group":"U6 snRNP groups","kind":"subcomplex"}
name pdb_5MPS_U6_snRNP #313.1/6
# other
# selector_meta {"color":"#9CA3AF","family":"Protein/RNP groups","group":"other protein/RNP groups","kind":"subcomplex"}
name pdb_5MPS_other #313.1/R,X,a
# Named selections for resolved substrate RNA features.
# 5' exon: residues -16--1, manual-chain-override, high confidence, validation not_applicable
# selector_meta {"color":"#FF8C00","family":"RNA","feature":"exon_5","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name Cstar_5MPS_5exon #313.1/E:-16--1
# substrate RNA: residues -16--1; 1-16;56-73, component, medium confidence, validation not_applicable
# selector_meta {"color":"#303030","family":"RNA","feature":"substrate","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name Cstar_5MPS_substrate #313.1/E:-16--1|#313.1/I:1-16,56-73
# 5' splice site: residues 1-6, network-scored-motif, medium confidence, validation validated
# selector_meta {"color":"#303030","family":"RNA","feature":"five_prime_splice_site","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name Cstar_5MPS_5SS #313.1/I:1-6
# intron: residues 1-16;56-73, manual-chain-override, high confidence, validation not_applicable
# selector_meta {"color":"#303030","family":"RNA","feature":"intron","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name Cstar_5MPS_intron #313.1/I:1-16,56-73
# branch point region: residues 62-72, network-scored-motif, high confidence, validation validated
# selector_meta {"color":"#303030","family":"RNA","feature":"branch_point_region","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name Cstar_5MPS_branch_region #313.1/I:62-72
# branch point adenosine: residues 70, network-scored-motif, high confidence, validation validated
# selector_meta {"color":"#303030","family":"RNA","feature":"branch_point_adenosine","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name Cstar_5MPS_branch_A #313.1/I:70
# Named selections for resolved snRNA functional regions.
# U2 snRNA U2/U6 helix I partner: residues 26-30, review-region, high confidence
# selector_meta {"color":"#047857","family":"RNA","feature":"U2_U6_helix_I_partner","group":"snRNA-snRNA interacting regions","group_key":"snRNA_snRNA_regions","kind":"rna_feature"}
name Cstar_5MPS_U2_U6_helix_I_partner #313.1/2:26-30
# U2 snRNA branchpoint pairing region: residues 33-42, sequence-motif-neighborhood, medium confidence
# selector_meta {"color":"#0B6E2D","family":"RNA","feature":"U2_branchpoint_pairing_region","group":"snRNA-pre-mRNA regions","group_key":"snRNA_pre_mRNA_regions","kind":"rna_feature"}
name Cstar_5MPS_U2_branchpoint_pairing_region #313.1/2:33-42
# U2 snRNA stem IIa: residues 46-49, review-region, low confidence
# selector_meta {"color":"#167A38","family":"RNA","feature":"U2_stem_IIa","group":"internal stem loops","group_key":"internal_stem_loops","kind":"rna_feature"}
name Cstar_5MPS_U2_stem_IIa #313.1/2:46-49
# U5 snRNA loop I: residues 53, sequence-motif, medium confidence
# selector_meta {"color":"#1B3CD0","family":"RNA","feature":"U5_loop_I","group":"snRNA-pre-mRNA regions","group_key":"snRNA_pre_mRNA_regions","kind":"rna_feature"}
name Cstar_5MPS_U5_loop_I #313.1/5:53
# U6 snRNA 5' terminal stem-loop: residues 1-10;16-30, reference-alignment, high confidence
# selector_meta {"color":"#DC143C","family":"RNA","feature":"U6_5prime_terminal_stem_loop","group":"internal stem loops","group_key":"internal_stem_loops","kind":"rna_feature"}
name Cstar_5MPS_U6_5_terminal_stem_loop #313.1/6:1-10,16-30
# U6 snRNA U2/U6 helix I partner: residues 41-66, motif-neighborhood, medium confidence
# selector_meta {"color":"#D0183C","family":"RNA","feature":"U6_U2_helix_I_partner","group":"snRNA-snRNA interacting regions","group_key":"snRNA_snRNA_regions","kind":"rna_feature"}
name Cstar_5MPS_U6_U2_helix_I_partner #313.1/6:41-66
# U6 snRNA 5' splice-site upstream contact: residues 44-55, motif-neighborhood, medium confidence
# selector_meta {"color":"#E01842","family":"RNA","feature":"U6_5SS_upstream_contact","group":"other snRNA regions","group_key":"other_snRNA_regions","kind":"rna_feature"}
name Cstar_5MPS_U6_5SS_upstream_contact #313.1/6:44-55
# U6 snRNA internal stem-loop: residues 46-73, motif-neighborhood, low confidence
# selector_meta {"color":"#D61A3D","family":"RNA","feature":"U6_ISL","group":"internal stem loops","group_key":"internal_stem_loops","kind":"rna_feature"}
name Cstar_5MPS_U6_ISL #313.1/6:46-73
# U6 snRNA ACAGAGA box: residues 47-53, sequence-motif, high confidence
# selector_meta {"color":"#DC143C","family":"RNA","feature":"U6_ACAGAGA_box","group":"other snRNA regions","group_key":"other_snRNA_regions","kind":"rna_feature"}
name Cstar_5MPS_U6_ACAGAGA_box #313.1/6:47-53
# U6 snRNA AGC catalytic triad: residues 59-61, sequence-motif, medium confidence
# selector_meta {"color":"#C91236","family":"RNA","feature":"U6_AGC_catalytic_triad","group":"catalytic core regions","group_key":"catalytic_core_regions","kind":"rna_feature"}
name Cstar_5MPS_U6_AGC_catalytic_triad #313.1/6:59-61
# U6 snRNA LSm site: residues 103-104, terminal-region, low confidence
# selector_meta {"color":"#E33A55","family":"RNA","feature":"U6_LSm_site","group":"other snRNA regions","group_key":"other_snRNA_regions","kind":"rna_feature"}
name Cstar_5MPS_U6_LSm_site #313.1/6:103-104
# RNA feature nucleotide display.
select #313.1 & nucleic
nucleotides sel atoms
select clear
# 5' exon: residues -16--1
color #313.1/E:-16--1 #FF8C00
select #313.1/E:-16--1
nucleotides sel fill
select clear
# 5'SS: residues 1-6
# intron: residues 1-16;56-73
# BP region: residues 62-72
# BP-A: residues 70
# U2/U6 helix I: residues 26-30
color #313.1/2:26-30 #047857
select #313.1/2:26-30
nucleotides sel fill
select clear
# U2 BP pairing: residues 33-42
color #313.1/2:33-42 #0B6E2D
select #313.1/2:33-42
nucleotides sel fill
select clear
# U2 stem IIa: residues 46-49
color #313.1/2:46-49 #167A38
select #313.1/2:46-49
nucleotides sel fill
select clear
# U5 loop I: residues 53
color #313.1/5:53 #1B3CD0
select #313.1/5:53
nucleotides sel fill
select clear
# U6 5' terminal SL: residues 1-10;16-30
color #313.1/6:1-10,16-30 #DC143C
select #313.1/6:1-10,16-30
nucleotides sel fill
select clear
# U2/U6 helix I: residues 41-66
color #313.1/6:41-66 #D0183C
select #313.1/6:41-66
nucleotides sel fill
select clear
# U6 5'SS contact: residues 44-55
color #313.1/6:44-55 #E01842
select #313.1/6:44-55
nucleotides sel fill
select clear
# U6 ISL: residues 46-73
color #313.1/6:46-73 #D61A3D
select #313.1/6:46-73
nucleotides sel fill
select clear
# U6 ACAGAGA: residues 47-53
color #313.1/6:47-53 #DC143C
select #313.1/6:47-53
nucleotides sel fill
select clear
# U6 AGC triad: residues 59-61
color #313.1/6:59-61 #C91236
select #313.1/6:59-61
nucleotides sel fill
select clear
# RNA feature 3D residue labels.
# Labels are created as independent grouped models under #313.2.
# Fetch and run the self-contained RNA label script from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/label_scripts/5mps_rna_labels.py
# Searchable named selection browser.
# In GUI ChimeraX this opens a small panel for selecting, zooming, and toggling RNA labels.
# Fetch and open the self-contained named selection browser from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/selection_browser_scripts/5mps_selection_browser.py
view
show nucleic
