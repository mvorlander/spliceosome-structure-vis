# Lightweight ChimeraX script for 8HK1
# Models are downloaded directly by ChimeraX from the PDB.
# Primary maps, when requested, are downloaded directly from EMDB.
# Original deposited chain identifiers are used.

# Shared anchor frame: 8H6L
# Structure group: #383; target model: #383.1.

open 8h6l id 383.9 name 8H6L_anchor
open 8hk1 id 383.1 name 8HK1
open emdb:34841 id 383.2.1 name 8HK1_EMD-34841_primary_map
rename #383 SF3B_U2_8hk1_structure

# Align on SF3B1.
matchmaker #383.1/1 to #383.9/2G bring #383.2.1
close #383.9

hide atoms
cartoon
# Default display style.
style (protein|nucleic|solvent) & @@draw_mode=0 stick
cartoon style modeh def arrows t arrowshelix f arrowscale 3 wid 4 thick 3 sides 12 div 20
cartoon style ~(nucleic|strand) x round
cartoon style (nucleic|strand) x rect
cartoon style nucleic x round width 4 thick 4
lighting shadows false
lighting simple
camera ortho
lighting soft intensity 0.2 fillIntensity 0.5 ambientIntensity 1
lighting soft
# window
# windowsize 800 800

# bg and model colors
set bgColor white
style nucleic stick
graphics silhouettes true
cartoon style arrowScale 1.5
color byhetero
# Subunit colors from color_code/subunit_color_code.csv.
# U2 snRNA
color #383.1/H #006400
# SF3A3
color #383.1/C #9BCF91
# HTATSF1
color #383.1/D #7DBF82
# DDX42
color #383.1/E #479061
# SNRPA1
color #383.1/F #58D68D
# SNRPB2
color #383.1/G #DAF7A6
# U2-Sm SNRPD2
color #383.1/a #D5F5E3
# U2-Sm SNRPF
color #383.1/b #D5F5E3
# U2-Sm SNRPE
color #383.1/c #D5F5E3
# U2-Sm SNRPG
color #383.1/d #D5F5E3
# U2-Sm SNRPD3
color #383.1/e #D5F5E3
# SF3B1
color #383.1/1 #487957
# U2-Sm SNRPB
color #383.1/f #D5F5E3
# U2-Sm SNRPD1
color #383.1/g #D5F5E3
# SF3B2
color #383.1/2 #49926C
# SF3B3
color #383.1/3 #6A9064
# SF3B4
color #383.1/4 #77B088
# SF3B5
color #383.1/5 #92BB8F
# PHF5A
color #383.1/6 #375A40
# SF3A1
color #383.1/A #55947F
# SF3A2
color #383.1/B #75A074
# Named selections for resolved snRNA functional regions.
# U2 snRNA U2/U6 helix I partner: residues 26-30, review-region, high confidence
name U2_snRNP_8HK1_U2_U6_helix_I_partner #383.1/H:26-30
# U2 snRNA branchpoint pairing region: residues 32-41, sequence-motif-neighborhood, medium confidence
name U2_snRNP_8HK1_U2_branchpoint_pairing_region #383.1/H:32-41
# U2 snRNA stem IIa: residues 46-65;69-73;81-82, review-region, low confidence
name U2_snRNP_8HK1_U2_stem_IIa #383.1/H:46-65,69-73,81-82
# U2 snRNA Sm site: residues 99-105, sequence-motif, medium confidence
name U2_snRNP_8HK1_U2_Sm_site #383.1/H:99-105
# RNA feature nucleotide display.
select #383.1 & nucleic
nucleotides sel atoms
select clear
# U2/U6 helix I: residues 26-30
color #383.1/H:26-30 #047857
select #383.1/H:26-30
nucleotides sel fill
select clear
# U2 BP pairing: residues 32-41
color #383.1/H:32-41 #0B6E2D
select #383.1/H:32-41
nucleotides sel fill
select clear
# U2 stem IIa: residues 46-65;69-73;81-82
color #383.1/H:46-65,69-73,81-82 #167A38
select #383.1/H:46-65,69-73,81-82
nucleotides sel fill
select clear
# RNA feature 3D residue labels.
# Each label is moved into #383.1.90 as an independently togglable model.
label #383.1/H:28 residues text "U2/U6 helix I 26-30" color #047857 height 3 bgColor white
rename #383.1.1 label_01_U2_U6_helix_I_26_30 id #383.1.90.1
rename #383.1.90 RNA_feature_labels
label #383.1/H:36 residues text "U2 BP pairing 32-41" color #0B6E2D height 3 bgColor white
rename #383.1.1 label_02_U2_BP_pairing_32_41 id #383.1.90.2
label #383.1/H:56 residues text "U2 stem IIa 46-65;69-73;81-82" color #167A38 height 3 bgColor white
rename #383.1.1 label_03_U2_stem_IIa_46_65_69_73_81_82 id #383.1.90.3
view
show nucleic
