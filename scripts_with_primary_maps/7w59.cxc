select #374.1/B:38-42
nucleotides sel fill
select clear
# U6 5' terminal SL: residues 1-30
color #374.1/F:1-30 #DC143C
select #374.1/F:1-30
nucleotides sel fill
select clear
# U2/U6 helix I: residues 35-60
color #374.1/F:35-60 #D0183C
select #374.1/F:35-60
nucleotides sel fill
select clear
# U6 5'SS contact: residues 38-49
color #374.1/F:38-49 #E01842
