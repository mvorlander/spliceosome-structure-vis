color #328.1/e #B0C4DE
# U2-Sm SNRPE
color #328.1/i #D5F5E3
# U4-Sm SNRPF
color #328.1/U #F7F0A6
# U5-Sm SNRPF
color #328.1/f #B0C4DE
# U2-Sm SNRPF
color #328.1/j #D5F5E3
# U4-Sm SNRPG
color #328.1/V #F7F0A6
# U5-Sm SNRPG
color #328.1/g #B0C4DE
# U2-Sm SNRPG
color #328.1/k #D5F5E3
# U4 snRNA
color #328.1/I #E6D900
# SNRNP200
color #328.1/D #AFEEEE
