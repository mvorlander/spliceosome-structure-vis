# Lightweight ChimeraX script for 5ZWO
# Models are downloaded directly by ChimeraX from the PDB.
# Primary maps, when requested, are downloaded directly from EMDB.
# Original deposited chain identifiers are used.

# Shared anchor frame: 8H6L
# Structure group: #328; target model: #328.1; RNA labels: #328.2.

open 8h6l id 328.9 name 8H6L_anchor
open 5zwo id 328.1 name 5ZWO
open emdb:6974 id 328.3.1 name 5ZWO_EMD-6974_primary_map
rename #328 B_5zwo_structure

# Align on PRPF8.
matchmaker #328.1/A to #328.9/5B bring #328.3.1
close #328.9

hide atoms
cartoon
# Default display style.
style (protein|nucleic|solvent) & @@draw_mode=0 stick
cartoon style modeh def arrows t arrowshelix f arrowscale 3 wid 4 thick 3 sides 12 div 20
cartoon style ~(nucleic|strand) x round
cartoon style (nucleic|strand) x rect
cartoon style nucleic x round width 4 thick 4
lighting shadows false
lighting simple
camera ortho
lighting soft intensity 0.2 fillIntensity 0.5 ambientIntensity 1
lighting soft
# window
# windowsize 800 800

# bg and model colors
set bgColor white
style nucleic stick
graphics silhouettes true
cartoon style arrowScale 1.5
color byhetero
# Subunit colors from color_code/subunit_color_code.csv.
# PRPF8
color #328.1/A #BFC3E8
# LSM2
color #328.1/q #F4A3A8
# LSM3
color #328.1/r #F4A3A8
# LSM6
color #328.1/x #F4A3A8
# LSM5
color #328.1/t #F4A3A8
# LSM7
color #328.1/y #F4A3A8
# LSM4
color #328.1/s #F4A3A8
# U6 snRNA
color #328.1/F #DC143C
# U5 snRNA
color #328.1/B #0000CD
# SART1
color #328.1/O #D6937B
# U4-Sm SNRPD3
color #328.1/S #F7F0A6
# U5-Sm SNRPD3
color #328.1/d #B0C4DE
# U2-Sm SNRPD3
color #328.1/l #D5F5E3
# PRPF4
color #328.1/K #E2C496
