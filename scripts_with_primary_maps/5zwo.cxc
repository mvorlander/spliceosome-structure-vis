# Named selections for resolved substrate RNA features.
# substrate RNA: residues 463-522, component, medium confidence, validation not_applicable
name B_5ZWO_substrate #328.1/G:463-522
# branch point region: residues 493-503, network-scored-motif, high confidence, validation validated
name B_5ZWO_branch_region #328.1/G:493-503
# branch point adenosine: residues 501, network-scored-motif, high confidence, validation validated
name B_5ZWO_branch_A #328.1/G:501
# Named selections for resolved snRNA functional regions.
# U2 snRNA branchpoint pairing region: residues 33-42, sequence-motif-neighborhood, medium confidence
name B_5ZWO_U2_branchpoint_pairing_region #328.1/H:33-42
# U2 snRNA stem IIa: residues 46-73;79-80, review-region, low confidence
name B_5ZWO_U2_stem_IIa #328.1/H:46-73,79-80
# U4 snRNA U4/U6 stem I partner: residues 1-18, reference-alignment, high confidence
name B_5ZWO_U4_U6_stem_I_partner #328.1/I:1-18
# U4 snRNA U4/U6 stem II partner: residues 57-64, reference-alignment, high confidence
name B_5ZWO_U4_U6_stem_II_partner #328.1/I:57-64
# U4 snRNA Brr2 loading region: residues 60-64;71-79;90-95, review-region, low confidence
name B_5ZWO_U4_Brr2_loading_region #328.1/I:60-64,71-79,90-95
# U4 snRNA Sm site: residues 144-150, sequence-motif, medium confidence
name B_5ZWO_U4_Sm_site #328.1/I:144-150
# U5 snRNA loop I: residues 53, sequence-motif, medium confidence
name B_5ZWO_U5_loop_I #328.1/B:53
# U6 snRNA 5' terminal stem-loop: residues 1-30, reference-alignment, high confidence
name B_5ZWO_U6_5_terminal_stem_loop #328.1/F:1-30
# U6 snRNA U2/U6 helix I partner: residues 41-51;56-66, motif-neighborhood, medium confidence
name B_5ZWO_U6_U2_helix_I_partner #328.1/F:41-51,56-66
# U6 snRNA 5' splice-site upstream contact: residues 44-51, motif-neighborhood, medium confidence
name B_5ZWO_U6_5SS_upstream_contact #328.1/F:44-51
# U6 snRNA internal stem-loop: residues 46-51;56-73, motif-neighborhood, low confidence
name B_5ZWO_U6_ISL #328.1/F:46-51,56-73
# U6 snRNA ACAGAGA box: residues 47-51, sequence-motif, high confidence
name B_5ZWO_U6_ACAGAGA_box #328.1/F:47-51
# U6 snRNA U4/U6 stem II partner: residues 56-68, reference-alignment, high confidence
name B_5ZWO_U6_U4_stem_II_partner #328.1/F:56-68
# U6 snRNA AGC catalytic triad: residues 59-61, sequence-motif, medium confidence
name B_5ZWO_U6_AGC_catalytic_triad #328.1/F:59-61
# U6 snRNA U4/U6 stem I partner: residues 70-80, reference-alignment, high confidence
name B_5ZWO_U6_U4_stem_I_partner #328.1/F:70-80
# U6 snRNA LSm site: residues 108-112, terminal-region, low confidence
name B_5ZWO_U6_LSm_site #328.1/F:108-112
# RNA feature nucleotide display.
select #328.1 & nucleic
nucleotides sel atoms
select clear
# BP region: residues 493-503
# BP-A: residues 501
# U2 BP pairing: residues 33-42
color #328.1/H:33-42 #0B6E2D
select #328.1/H:33-42
nucleotides sel fill
select clear
# U2 stem IIa: residues 46-73;79-80
color #328.1/H:46-73,79-80 #167A38
select #328.1/H:46-73,79-80
nucleotides sel fill
select clear
# U4/U6 stem I: residues 1-18
color #328.1/I:1-18 #D8C800
select #328.1/I:1-18
nucleotides sel fill
select clear
# U4/U6 stem II: residues 57-64
color #328.1/I:57-64 #E0CF1A
select #328.1/I:57-64
nucleotides sel fill
select clear
# U4 Brr2 region: residues 60-64;71-79;90-95
color #328.1/I:60-64,71-79,90-95 #F0DF2E
select #328.1/I:60-64,71-79,90-95
nucleotides sel fill
select clear
# U5 loop I: residues 53
color #328.1/B:53 #1B3CD0
select #328.1/B:53
nucleotides sel fill
select clear
# U6 5' terminal SL: residues 1-30
color #328.1/F:1-30 #DC143C
select #328.1/F:1-30
nucleotides sel fill
select clear
# U2/U6 helix I: residues 41-51;56-66
color #328.1/F:41-51,56-66 #D0183C
select #328.1/F:41-51,56-66
nucleotides sel fill
select clear
# U6 5'SS contact: residues 44-51
color #328.1/F:44-51 #E01842
select #328.1/F:44-51
nucleotides sel fill
select clear
# U6 ISL: residues 46-51;56-73
color #328.1/F:46-51,56-73 #D61A3D
select #328.1/F:46-51,56-73
nucleotides sel fill
select clear
# U6 ACAGAGA: residues 47-51
color #328.1/F:47-51 #DC143C
select #328.1/F:47-51
nucleotides sel fill
select clear
# U4/U6 stem II: residues 56-68
color #328.1/F:56-68 #E01842
select #328.1/F:56-68
nucleotides sel fill
select clear
# U6 AGC triad: residues 59-61
color #328.1/F:59-61 #C91236
select #328.1/F:59-61
nucleotides sel fill
select clear
# U4/U6 stem I: residues 70-80
color #328.1/F:70-80 #D9183E
select #328.1/F:70-80
nucleotides sel fill
select clear
# RNA feature 3D residue labels.
# Labels are created as independent grouped models under #328.2.
# Fetch and run the self-contained RNA label script from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/label_scripts/5zwo_rna_labels.py
view
show nucleic
