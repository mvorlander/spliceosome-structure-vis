# Lightweight ChimeraX script for 6N7R
# Models are downloaded directly by ChimeraX from the PDB.
# Primary maps, when requested, are downloaded directly from EMDB.
# Original deposited chain identifiers are used.

# Shared anchor frame: 8H6L
# Structure group: #345; target model: #345.1; RNA labels: #345.2.

open 8h6l id 345.9 name 8H6L_anchor
open 6n7r id 345.1 name 6N7R
open emdb:0361 id 345.3.1 name 6N7R_EMD-0361_primary_map
rename #345 spliceosome_6n7r_structure

# No PRPF8 or SF3B1 chain was detected; anchor is closed without alignment.
close #345.9

# Remove implausibly long deposited covalent bonds before styling.
# Fetch and run the implausible-bond pruning helper from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/prune_implausible_bonds.py

hide atoms
cartoon
# Default display style.
style (protein|nucleic|solvent) & @@draw_mode=0 stick
cartoon style modeh def arrows t arrowshelix f arrowscale 3 wid 4 thick 3 sides 12 div 20
cartoon style ~(nucleic|strand) x round
cartoon style (nucleic|strand) x rect
cartoon style nucleic x round width 4 thick 4
lighting shadows false
lighting simple
camera ortho
lighting soft intensity 0.2 fillIntensity 0.5 ambientIntensity 1
lighting soft

# bg and model colors
set bgColor white
style nucleic stick
graphics silhouettes true
cartoon style arrowScale 1.5
color byhetero
# Subunit colors from color_code/subunit_color_code.csv.
# SNRNP70
color #345.1/A #8C3D78
# SNRPC
color #345.1/B #D7A3CF
# SNRPA
color #345.1/C #C07AB6
# PRP42
color #345.1/D #7F5BA6
# PRPF39
color #345.1/E #E1B8D9
# NAM8
color #345.1/F #C7A6BE
# SNU56
color #345.1/G #D65B96
# SNU71
color #345.1/H #A95A9B
# LUC7L
color #345.1/I #B03372
# U1-Sm SNRPB
color #345.1/K #EAD7E8
# U1-Sm SNRPD1
color #345.1/L #EAD7E8
# U1-Sm SNRPD2
color #345.1/M #EAD7E8
# U1-Sm SNRPD3
color #345.1/N #EAD7E8
# U1-Sm SNRPE
color #345.1/O #EAD7E8
# U1-Sm SNRPF
color #345.1/P #EAD7E8
# U1-Sm SNRPG
color #345.1/Q #EAD7E8
# U1 snRNA
color #345.1/R #D46BB8
# mRNA
color #345.1/r #303030
# Named selections for subcomplexes using original deposited chain IDs.
# RNA/substrate
# selector_meta {"color":"#303030","family":"RNA","group":"pre-mRNA features","kind":"subcomplex"}
name pdb_6N7R_RNA_substrate #345.1/r
# U1 Sm ring
# selector_meta {"color":"#B66AAE","family":"Protein/RNP groups","group":"U1 snRNP groups","kind":"subcomplex"}
name pdb_6N7R_U1_Sm_ring #345.1/K,L,M,N,O,P,Q
# U1 snRNP
# selector_meta {"color":"#B66AAE","family":"Protein/RNP groups","group":"U1 snRNP groups","kind":"subcomplex"}
name pdb_6N7R_U1_snRNP #345.1/A,B,C,D,E,F,G,H,I,R
# Named selections for resolved substrate RNA features.
# 5' exon: residues -2--1, five-ss-inference, medium confidence, validation not_applicable
# selector_meta {"color":"#FF8C00","family":"RNA","feature":"exon_5","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name E_complex_6N7R_5exon #345.1/r:-2--1
# substrate RNA: residues -2,-1,1,2,3,4,5,6,7,8,103,104,105,106,107,108,109,110,111,112,113,114,115,116,117,118,119,120,121,122,123,124,125,126,127,128,130,131,132,133,134,135,136,137,138,139,140,141,142,143,144,145,146,147,148,149,150,151,152,153,154,155,156, component, medium confidence, validation not_applicable
# selector_meta {"color":"#303030","family":"RNA","feature":"substrate","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name E_complex_6N7R_substrate #345.1/r:-2,-1,1,2,3,4,5,6,7,8,103,104,105,106,107,108,109,110,111,112,113,114,115,116,117,118,119,120,121,122,123,124,125,126,127,128,130,131,132,133,134,135,136,137,138,139,140,141,142,143,144,145,146,147,148,149,150,151,152,153,154,155,156
# 5' splice site: residues 1-6, network-scored-motif, high confidence, validation validated
# selector_meta {"color":"#303030","family":"RNA","feature":"five_prime_splice_site","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name E_complex_6N7R_5SS #345.1/r:1-6
# intron from 5' splice site: residues 1,2,3,4,5,6,7,8,103,104,105,106,107,108,109,110,111,112,113,114,115,116,117,118,119,120,121,122,123,124,125,126,127,128,130,131,132,133,134,135,136,137,138,139,140,141,142,143,144,145,146,147,148,149,150,151,152,153,154,155,156, five-ss-inference, low confidence, validation not_applicable
# selector_meta {"color":"#303030","family":"RNA","feature":"intron","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name E_complex_6N7R_intron #345.1/r:1,2,3,4,5,6,7,8,103,104,105,106,107,108,109,110,111,112,113,114,115,116,117,118,119,120,121,122,123,124,125,126,127,128,130,131,132,133,134,135,136,137,138,139,140,141,142,143,144,145,146,147,148,149,150,151,152,153,154,155,156
# Named selections for resolved snRNA functional regions.
# U1 snRNA 5' splice-site recognition region: residues 1-10, review-region, medium confidence
# selector_meta {"color":"#B66AAE","family":"RNA","feature":"U1_5prime_5SS_recognition","group":"snRNA-pre-mRNA regions","group_key":"snRNA_pre_mRNA_regions","kind":"rna_feature"}
name E_complex_6N7R_U1_5_5SS_recognition #345.1/R:1-10
# U1 snRNA stem-loop 1: residues 11-25;33-45, review-region, low confidence
# selector_meta {"color":"#BF72B7","family":"RNA","feature":"U1_SL1","group":"internal stem loops","group_key":"internal_stem_loops","kind":"rna_feature"}
name E_complex_6N7R_U1_SL1 #345.1/R:11-25,33-45
# U1 snRNA stem-loop 2: residues 46-95, review-region, low confidence
# selector_meta {"color":"#AD62A6","family":"RNA","feature":"U1_SL2","group":"internal stem loops","group_key":"internal_stem_loops","kind":"rna_feature"}
name E_complex_6N7R_U1_SL2 #345.1/R:46-95
# U1 snRNA Sm site: residues 224-230; 241-247; 553-559, sequence-motif, medium confidence
# selector_meta {"color":"#C783BF","family":"RNA","feature":"U1_Sm_site","group":"other snRNA regions","group_key":"other_snRNA_regions","kind":"rna_feature"}
name E_complex_6N7R_U1_Sm_site #345.1/R:224-230|#345.1/R:241-247|#345.1/R:553-559
# RNA feature nucleotide display.
select #345.1 & nucleic
nucleotides sel atoms
select clear
# 5' exon: residues -2--1
color #345.1/r:-2--1 #FF8C00
select #345.1/r:-2--1
nucleotides sel fill
select clear
# 5'SS: residues 1-6
# intron: residues 1,2,3,4,5,6,7,8,103,104,105,106,107,108,109,110,111,112,113,114,115,116,117,118,119,120,121,122,123,124,125,126,127,128,130,131,132,133,134,135,136,137,138,139,140,141,142,143,144,145,146,147,148,149,150,151,152,153,154,155,156
# U1 5'SS recog.: residues 1-10
color #345.1/R:1-10 #B66AAE
select #345.1/R:1-10
nucleotides sel fill
select clear
# U1 SL1: residues 11-25;33-45
color #345.1/R:11-25,33-45 #BF72B7
select #345.1/R:11-25,33-45
nucleotides sel fill
select clear
# U1 SL2: residues 46-95
color #345.1/R:46-95 #AD62A6
select #345.1/R:46-95
nucleotides sel fill
select clear
# U1 Sm site: residues 224-230; 241-247; 553-559
color #345.1/R:224-230|#345.1/R:241-247|#345.1/R:553-559 #C783BF
select #345.1/R:224-230|#345.1/R:241-247|#345.1/R:553-559
nucleotides sel fill
select clear
# RNA feature 3D residue labels.
# Labels are created as independent grouped models under #345.2.
# Fetch and run the self-contained RNA label script from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/label_scripts/6n7r_rna_labels.py
# Searchable named selection browser.
# In GUI ChimeraX this opens a small panel for selecting, zooming, and toggling RNA labels.
# Fetch and open the self-contained named selection browser from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/selection_browser_scripts/6n7r_selection_browser.py
view
show nucleic
