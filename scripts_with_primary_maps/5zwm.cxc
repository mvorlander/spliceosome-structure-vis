# other
# selector_meta {"color":"#9CA3AF","family":"Protein/RNP groups","group":"other protein/RNP groups","kind":"subcomplex"}
name pdb_5ZWM_other #326.1/X,Y,Z
# Named selections for resolved substrate RNA features.
# substrate RNA: residues 479-522, component, medium confidence, validation not_applicable
# selector_meta {"color":"#303030","family":"RNA","feature":"substrate","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name pre_B_5ZWM_substrate #326.1/G:479-522
# branch point region: residues 493-503, network-scored-motif, high confidence, validation validated
# selector_meta {"color":"#303030","family":"RNA","feature":"branch_point_region","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name pre_B_5ZWM_branch_region #326.1/G:493-503
# branch point adenosine: residues 501, network-scored-motif, high confidence, validation validated
# selector_meta {"color":"#303030","family":"RNA","feature":"branch_point_adenosine","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name pre_B_5ZWM_branch_A #326.1/G:501
# Named selections for resolved snRNA functional regions.
# U2 snRNA branchpoint pairing region: residues 33-42, sequence-motif-neighborhood, medium confidence
# selector_meta {"color":"#0B6E2D","family":"RNA","feature":"U2_branchpoint_pairing_region","group":"snRNA-pre-mRNA regions","group_key":"snRNA_pre_mRNA_regions","kind":"rna_feature"}
name pre_B_5ZWM_U2_branchpoint_pairing_region #326.1/H:33-42
# U2 snRNA stem IIa: residues 46-73;79-80, review-region, low confidence
# selector_meta {"color":"#167A38","family":"RNA","feature":"U2_stem_IIa","group":"internal stem loops","group_key":"internal_stem_loops","kind":"rna_feature"}
name pre_B_5ZWM_U2_stem_IIa #326.1/H:46-73,79-80
# U4 snRNA U4/U6 stem I partner: residues 1-18, reference-alignment, high confidence
# selector_meta {"color":"#D8C800","family":"RNA","feature":"U4_U6_stem_I_partner","group":"snRNA-snRNA interacting regions","group_key":"snRNA_snRNA_regions","kind":"rna_feature"}
name pre_B_5ZWM_U4_U6_stem_I_partner #326.1/I:1-18
# U4 snRNA U4/U6 stem II partner: residues 57-64, reference-alignment, high confidence
# selector_meta {"color":"#E0CF1A","family":"RNA","feature":"U4_U6_stem_II_partner","group":"snRNA-snRNA interacting regions","group_key":"snRNA_snRNA_regions","kind":"rna_feature"}
