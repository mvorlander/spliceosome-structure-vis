# Named selections for resolved substrate RNA features.
# upstream intron: residues 7-48, exon-definition-inference, medium confidence, validation not_applicable
name pre_B_8H6J_intron #380.1/A:7-48
# substrate RNA: residues 7-48, component, medium confidence, validation not_applicable
name pre_B_8H6J_substrate #380.1/A:7-48
# branch point region: residues 24-30, network-scored-motif, high confidence, validation validated
name pre_B_8H6J_branch_region #380.1/A:24-30
# branch point adenosine: residues 29, network-scored-motif, high confidence, validation validated
name pre_B_8H6J_branch_A #380.1/A:29
# polypyrimidine tract: residues 35-48, sequence-motif, medium confidence, validation validated
name pre_B_8H6J_PPT #380.1/A:35-48
# Named selections for resolved snRNA functional regions.
# U2 snRNA U2/U6 helix I partner: residues 30, review-region, high confidence
name pre_B_8H6J_U2_U6_helix_I_partner #380.1/2A:30
# U2 snRNA branchpoint pairing region: residues 32-41, sequence-motif-neighborhood, medium confidence
name pre_B_8H6J_U2_branchpoint_pairing_region #380.1/2A:32-41
# U2 snRNA stem IIa: residues 46-65, review-region, low confidence
name pre_B_8H6J_U2_stem_IIa #380.1/2A:46-65
# U2 snRNA Sm site: residues 99-105, sequence-motif, medium confidence
name pre_B_8H6J_U2_Sm_site #380.1/2A:99-105
# U4 snRNA U4/U6 stem I partner: residues 1-18, reference-alignment, high confidence
name pre_B_8H6J_U4_U6_stem_I_partner #380.1/4A:1-18
# U4 snRNA U4/U6 stem II partner: residues 56-64, reference-alignment, high confidence
name pre_B_8H6J_U4_U6_stem_II_partner #380.1/4A:56-64
# U4 snRNA Brr2 loading region: residues 60-70;73-80;85-95, review-region, low confidence
name pre_B_8H6J_U4_Brr2_loading_region #380.1/4A:60-70,73-80,85-95
# U4 snRNA Sm site: residues 119-125, sequence-motif, medium confidence
name pre_B_8H6J_U4_Sm_site #380.1/4A:119-125
# U5 snRNA loop I: residues 38-42, sequence-motif, medium confidence
name pre_B_8H6J_U5_loop_I #380.1/5A:38-42
# U6 snRNA U2/U6 helix I partner: residues 35-36;47-60, motif-neighborhood, medium confidence
name pre_B_8H6J_U6_U2_helix_I_partner #380.1/6A:35-36,47-60
# U6 snRNA 5' splice-site upstream contact: residues 47-49, motif-neighborhood, medium confidence
name pre_B_8H6J_U6_5SS_upstream_contact #380.1/6A:47-49
# U6 snRNA ACAGAGA box: residues 47, sequence-motif, high confidence
name pre_B_8H6J_U6_ACAGAGA_box #380.1/6A:47
# U6 snRNA U4/U6 stem II partner: residues 52-61, reference-alignment, high confidence
name pre_B_8H6J_U6_U4_stem_II_partner #380.1/6A:52-61
# U6 snRNA U4/U6 stem I partner: residues 63-74, reference-alignment, high confidence
name pre_B_8H6J_U6_U4_stem_I_partner #380.1/6A:63-74
# U6 snRNA internal stem-loop: residues 85-96;102-105, motif-neighborhood, low confidence
name pre_B_8H6J_U6_ISL #380.1/6A:85-96,102-105
# U6 snRNA AGC catalytic triad: residues 92-94, sequence-motif, medium confidence
name pre_B_8H6J_U6_AGC_catalytic_triad #380.1/6A:92-94
# U6 snRNA LSm site: residues 102-105, terminal-region, low confidence
name pre_B_8H6J_U6_LSm_site #380.1/6A:102-105
# RNA feature nucleotide display.
select #380.1 & nucleic
nucleotides sel atoms
select clear
# intron: residues 7-48
# BP region: residues 24-30
# BP-A: residues 29
# PPT: residues 35-48
# U2/U6 helix I: residues 30
color #380.1/2A:30 #047857
select #380.1/2A:30
nucleotides sel fill
select clear
# U2 BP pairing: residues 32-41
color #380.1/2A:32-41 #0B6E2D
select #380.1/2A:32-41
nucleotides sel fill
select clear
