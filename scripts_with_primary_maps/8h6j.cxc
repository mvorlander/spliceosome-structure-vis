# RNA feature 3D residue labels.
# Each label is moved into #380.1.90 as an independently togglable model.
label #380.1/A:28 residues text "intron 7-48" color #303030 height 3 bgColor white
rename #380.1.1 label_01_intron_7_48 id #380.1.90.1
rename #380.1.90 RNA_feature_labels
