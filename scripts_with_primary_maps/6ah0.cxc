color #330.1/I #E6D900
# DDX23
color #330.1/X #CA9982
# PRPF8
color #330.1/A #BFC3E8
# EFTUD2
color #330.1/C #6495ED
# U4-Sm SNRPF
color #330.1/Q #F7F0A6
# U5-Sm SNRPF
color #330.1/b #B0C4DE
# U2-Sm SNRPF
color #330.1/m #D5F5E3
