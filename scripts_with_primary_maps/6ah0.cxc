# Lightweight ChimeraX script for 6AH0
# Models are downloaded directly by ChimeraX from the PDB.
# Primary maps, when requested, are downloaded directly from EMDB.
# Original deposited chain identifiers are used.

# Shared anchor frame: 8H6L
# Structure group: #330; target model: #330.1; RNA labels: #330.2.

open 8h6l id 330.9 name 8H6L_anchor
open 6ah0 id 330.1 name 6AH0
open emdb:9621 id 330.3.1 name 6AH0_EMD-9621_primary_map
rename #330 pre_B_6ah0_structure

# Align on PRPF8.
matchmaker #330.1/A to #330.9/5B bring #330.3.1
close #330.9

hide atoms
cartoon
# Default display style.
style (protein|nucleic|solvent) & @@draw_mode=0 stick
cartoon style modeh def arrows t arrowshelix f arrowscale 3 wid 4 thick 3 sides 12 div 20
cartoon style ~(nucleic|strand) x round
cartoon style (nucleic|strand) x rect
cartoon style nucleic x round width 4 thick 4
lighting shadows false
lighting simple
camera ortho
lighting soft intensity 0.2 fillIntensity 0.5 ambientIntensity 1
lighting soft
# window
# windowsize 800 800

# bg and model colors
set bgColor white
style nucleic stick
graphics silhouettes true
cartoon style arrowScale 1.5
color byhetero
# Subunit colors from color_code/subunit_color_code.csv.
# U5 snRNA
color #330.1/B #0000CD
# U4-Sm SNRPD1
color #330.1/V #F7F0A6
# U5-Sm SNRPD1
color #330.1/g #B0C4DE
# U2-Sm SNRPD1
color #330.1/j #D5F5E3
# U6 snRNA
color #330.1/F #DC143C
# LSM2
color #330.1/q #F4A3A8
# LSM3
color #330.1/r #F4A3A8
# LSM4
color #330.1/s #F4A3A8
# LSM5
color #330.1/t #F4A3A8
# LSM6
color #330.1/x #F4A3A8
# LSM7
color #330.1/y #F4A3A8
# LSM8
color #330.1/z #F4A3A8
# pre-mRNA
color #330.1/G #303030
# SNRNP200
color #330.1/D #AFEEEE
# U2 snRNA
color #330.1/H #006400
# SNRPA1
color #330.1/o #58D68D
# SNRPB2
color #330.1/p #DAF7A6
# SF3A1
color #330.1/u #55947F
# SF3A2
color #330.1/v #75A074
# SF3A3
color #330.1/w #9BCF91
