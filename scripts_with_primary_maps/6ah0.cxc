color #330.1/1 #487957
# SF3B2
color #330.1/2 #49926C
# SF3B3
color #330.1/3 #6A9064
# SF3B4
color #330.1/4 #77B088
# PRP8BP
color #330.1/E #E2F3F4
# SF3B6
color #330.1/5 #ADCEA0
# PHF5A
color #330.1/6 #375A40
# SF3B5
color #330.1/7 #92BB8F
# PRPF3
color #330.1/J #E1DD1B
# PRPF4
color #330.1/K #E2C496
# PRPF6
color #330.1/N #CFA785
# PRPF31
color #330.1/L #DFD570
# NHP2L1
color #330.1/M #A89264
# TXNL4A
color #330.1/O #C3BA7A
# USP39
color #330.1/W #B37E6A
# U4-Sm SNRPD2
color #330.1/P #F7F0A6
# U5-Sm SNRPD2
color #330.1/a #B0C4DE
# U2-Sm SNRPD2
color #330.1/k #D5F5E3
