# Lightweight ChimeraX script for 8QPE
# Models are downloaded directly by ChimeraX from the PDB.
# Primary maps, when requested, are downloaded directly from EMDB.
# Original deposited chain identifiers are used.

# Shared anchor frame: 8H6L
# Structure group: #403; target model: #403.1; RNA labels: #403.2.

open 8h6l id 403.9 name 8H6L_anchor
open 8qpe id 403.1 name 8QPE
open emdb:18548 id 403.3.1 name 8QPE_EMD-18548_primary_map
rename #403 pre_B_8qpe_structure

# Align on PRPF8.
matchmaker #403.1/A to #403.9/5B bring #403.3.1
close #403.9

hide atoms
cartoon
# Default display style.
style (protein|nucleic|solvent) & @@draw_mode=0 stick
cartoon style modeh def arrows t arrowshelix f arrowscale 3 wid 4 thick 3 sides 12 div 20
cartoon style ~(nucleic|strand) x round
cartoon style (nucleic|strand) x rect
cartoon style nucleic x round width 4 thick 4
lighting shadows false
lighting simple
camera ortho
lighting soft intensity 0.2 fillIntensity 0.5 ambientIntensity 1
lighting soft
# window
# windowsize 800 800

# bg and model colors
set bgColor white
style nucleic stick
graphics silhouettes true
cartoon style arrowScale 1.5
color byhetero
# Subunit colors from color_code/subunit_color_code.csv.
# U4 snRNA
color #403.1/4 #E6D900
# USP39
color #403.1/U #B37E6A
# FBP21
color #403.1/X #B03B66
# ZMAT2
color #403.1/r #FFB6C1
# pre-mRNA
color #403.1/z1 #303030
# pre-mRNA
color #403.1/z2 #303030
# PRPF3
color #403.1/J #E1DD1B
# PRPF31
color #403.1/L #DFD570
# PRPF4
color #403.1/F #E2C496
# PRPF6
color #403.1/N #CFA785
# PRPF8
color #403.1/A #BFC3E8
# U5 snRNA
color #403.1/5 #0000CD
# SART1
color #403.1/S #D6937B
# U6 snRNA
color #403.1/6 #DC143C
# SF3A1
color #403.1/7 #55947F
# EFTUD2
color #403.1/C #6495ED
# TXNL4A
color #403.1/D #C3BA7A
# PRPF38A
color #403.1/I #F88379
# MFAP1
color #403.1/K #CD5C5C
# NHP2L1
color #403.1/M #A89264
# Named selections for subcomplexes using original deposited chain IDs.
# RNA/substrate
# selector_meta {"color":"#303030","family":"RNA","group":"pre-mRNA features","kind":"subcomplex"}
name pdb_8QPE_RNA_substrate #403.1/z1,z2
# U2/SF3B
# selector_meta {"color":"#6DBE70","family":"Protein/RNP groups","group":"U2/SF3B groups","kind":"subcomplex"}
name pdb_8QPE_U2_SF3B #403.1/7
# U4 snRNP
# selector_meta {"color":"#D8C800","family":"Protein/RNP groups","group":"U4 snRNP groups","kind":"subcomplex"}
name pdb_8QPE_U4_snRNP #403.1/4
# U4/U6 snRNP
# selector_meta {"color":"#C3BA7A","family":"Protein/RNP groups","group":"U4/U6 groups","kind":"subcomplex"}
name pdb_8QPE_U4_U6_snRNP #403.1/D,F,J,L,M,U
# U5 snRNP
# selector_meta {"color":"#0000CD","family":"Protein/RNP groups","group":"U5 snRNP groups","kind":"subcomplex"}
name pdb_8QPE_U5_snRNP #403.1/5,A,C,N,S
# U6 snRNP
# selector_meta {"color":"#DC143C","family":"Protein/RNP groups","group":"U6 snRNP groups","kind":"subcomplex"}
name pdb_8QPE_U6_snRNP #403.1/6
# other
# selector_meta {"color":"#9CA3AF","family":"Protein/RNP groups","group":"other protein/RNP groups","kind":"subcomplex"}
name pdb_8QPE_other #403.1/I,K,X,r
# Named selections for resolved substrate RNA features.
# 5' exon: residues -3--1, five-ss-inference, medium confidence, validation not_applicable
# selector_meta {"color":"#FF8C00","family":"RNA","feature":"exon_5","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name pre_B_8QPE_5exon #403.1/z1:-3--1
# substrate RNA: residues -3,-2,-1,1; -3,-2,-1,1,2,3,4,5,6,7,8, component, medium confidence, validation not_applicable
# selector_meta {"color":"#303030","family":"RNA","feature":"substrate","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name pre_B_8QPE_substrate #403.1/z1:-3,-2,-1,1,2,3,4,5,6,7,8|#403.1/z2:-3,-2,-1,1
# 5' splice site: residues 1-6, network-scored-motif, medium confidence, validation uncertain uncertain validation
# selector_meta {"color":"#303030","family":"RNA","feature":"five_prime_splice_site","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name pre_B_8QPE_5SS #403.1/z1:1-6
# intron from 5' splice site: residues 1-8, five-ss-inference, low confidence, validation not_applicable
# selector_meta {"color":"#303030","family":"RNA","feature":"intron","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name pre_B_8QPE_intron #403.1/z1:1-8
# Named selections for resolved snRNA functional regions.
# U4 snRNA U4/U6 stem I partner: residues 1-18, reference-alignment, high confidence
# selector_meta {"color":"#D8C800","family":"RNA","feature":"U4_U6_stem_I_partner","group":"snRNA-snRNA interacting regions","group_key":"snRNA_snRNA_regions","kind":"rna_feature"}
name pre_B_8QPE_U4_U6_stem_I_partner #403.1/4:1-18
# U4 snRNA U4/U6 stem II partner: residues 56-63, reference-alignment, high confidence
# selector_meta {"color":"#E0CF1A","family":"RNA","feature":"U4_U6_stem_II_partner","group":"snRNA-snRNA interacting regions","group_key":"snRNA_snRNA_regions","kind":"rna_feature"}
name pre_B_8QPE_U4_U6_stem_II_partner #403.1/4:56-63
# U4 snRNA Brr2 loading region: residues 60-63, review-region, low confidence
# selector_meta {"color":"#F0DF2E","family":"RNA","feature":"U4_Brr2_loading_region","group":"other snRNA regions","group_key":"other_snRNA_regions","kind":"rna_feature"}
name pre_B_8QPE_U4_Brr2_loading_region #403.1/4:60-63
# U5 snRNA loop I: residues 38-42, sequence-motif, medium confidence
# selector_meta {"color":"#1B3CD0","family":"RNA","feature":"U5_loop_I","group":"snRNA-pre-mRNA regions","group_key":"snRNA_pre_mRNA_regions","kind":"rna_feature"}
name pre_B_8QPE_U5_loop_I #403.1/5:38-42
# U6 snRNA U2/U6 helix I partner: residues 36-60, motif-neighborhood, medium confidence
# selector_meta {"color":"#D0183C","family":"RNA","feature":"U6_U2_helix_I_partner","group":"snRNA-snRNA interacting regions","group_key":"snRNA_snRNA_regions","kind":"rna_feature"}
name pre_B_8QPE_U6_U2_helix_I_partner #403.1/6:36-60
# U6 snRNA 5' splice-site upstream contact: residues 38-49, motif-neighborhood, medium confidence
# selector_meta {"color":"#E01842","family":"RNA","feature":"U6_5SS_upstream_contact","group":"other snRNA regions","group_key":"other_snRNA_regions","kind":"rna_feature"}
name pre_B_8QPE_U6_5SS_upstream_contact #403.1/6:38-49
# U6 snRNA ACAGAGA box: residues 41-47, sequence-motif, high confidence
# selector_meta {"color":"#DC143C","family":"RNA","feature":"U6_ACAGAGA_box","group":"other snRNA regions","group_key":"other_snRNA_regions","kind":"rna_feature"}
name pre_B_8QPE_U6_ACAGAGA_box #403.1/6:41-47
# U6 snRNA U4/U6 stem II partner: residues 52-61, reference-alignment, high confidence
# selector_meta {"color":"#E01842","family":"RNA","feature":"U6_U4_stem_II_partner","group":"other snRNA regions","group_key":"other_snRNA_regions","kind":"rna_feature"}
name pre_B_8QPE_U6_U4_stem_II_partner #403.1/6:52-61
# U6 snRNA U4/U6 stem I partner: residues 63-74, reference-alignment, high confidence
# selector_meta {"color":"#D9183E","family":"RNA","feature":"U6_U4_stem_I_partner","group":"other snRNA regions","group_key":"other_snRNA_regions","kind":"rna_feature"}
name pre_B_8QPE_U6_U4_stem_I_partner #403.1/6:63-74
# RNA feature nucleotide display.
select #403.1 & nucleic
nucleotides sel atoms
select clear
# 5' exon: residues -3--1
color #403.1/z1:-3--1 #FF8C00
select #403.1/z1:-3--1
nucleotides sel fill
select clear
# 5'SS: residues 1-6
# intron: residues 1-8
# U4/U6 stem I: residues 1-18
color #403.1/4:1-18 #D8C800
select #403.1/4:1-18
nucleotides sel fill
select clear
# U4/U6 stem II: residues 56-63
color #403.1/4:56-63 #E0CF1A
select #403.1/4:56-63
nucleotides sel fill
select clear
# U4 Brr2 region: residues 60-63
color #403.1/4:60-63 #F0DF2E
select #403.1/4:60-63
nucleotides sel fill
select clear
# U5 loop I: residues 38-42
color #403.1/5:38-42 #1B3CD0
select #403.1/5:38-42
nucleotides sel fill
select clear
# U2/U6 helix I: residues 36-60
color #403.1/6:36-60 #D0183C
select #403.1/6:36-60
nucleotides sel fill
select clear
# U6 5'SS contact: residues 38-49
color #403.1/6:38-49 #E01842
select #403.1/6:38-49
nucleotides sel fill
select clear
# U6 ACAGAGA: residues 41-47
color #403.1/6:41-47 #DC143C
select #403.1/6:41-47
nucleotides sel fill
select clear
# U4/U6 stem II: residues 52-61
color #403.1/6:52-61 #E01842
select #403.1/6:52-61
nucleotides sel fill
select clear
# U4/U6 stem I: residues 63-74
color #403.1/6:63-74 #D9183E
select #403.1/6:63-74
nucleotides sel fill
select clear
# RNA feature 3D residue labels.
# Labels are created as independent grouped models under #403.2.
# Fetch and run the self-contained RNA label script from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/label_scripts/8qpe_rna_labels.py
# Searchable named selection browser.
# In GUI ChimeraX this opens a small panel for selecting, zooming, and toggling RNA labels.
# Fetch and open the self-contained named selection browser from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/selection_browser_scripts/8qpe_selection_browser.py
view
show nucleic
