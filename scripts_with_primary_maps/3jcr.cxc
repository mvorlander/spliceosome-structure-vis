# Lightweight ChimeraX script for 3JCR
# Models are downloaded directly by ChimeraX from the PDB.
# Primary maps, when requested, are downloaded directly from EMDB.
# Original deposited chain identifiers are used.

# Shared anchor frame: 8H6L
# Structure group: #303; target model: #303.1; RNA labels: #303.2.

open 8h6l id 303.9 name 8H6L_anchor
open 3jcr id 303.1 name 3JCR
open emdb:6581 id 303.3.1 name 3JCR_EMD-6581_primary_map
rename #303 P_3jcr_structure

# Align on PRPF8.
matchmaker #303.1/A to #303.9/5B bring #303.3.1
close #303.9

hide atoms
cartoon
# Default display style.
style (protein|nucleic|solvent) & @@draw_mode=0 stick
cartoon style modeh def arrows t arrowshelix f arrowscale 3 wid 4 thick 3 sides 12 div 20
cartoon style ~(nucleic|strand) x round
cartoon style (nucleic|strand) x rect
cartoon style nucleic x round width 4 thick 4
lighting shadows false
lighting simple
camera ortho
lighting soft intensity 0.2 fillIntensity 0.5 ambientIntensity 1
lighting soft
# window
# windowsize 800 800

# bg and model colors
set bgColor white
style nucleic stick
graphics silhouettes true
cartoon style arrowScale 1.5
color byhetero
# Subunit colors from color_code/subunit_color_code.csv.
# PRPF6
color #303.1/G #CFA785
# U5-Sm SNRPD2
color #303.1/Q #B0C4DE
# U4-Sm SNRPD2
color #303.1/q #F7F0A6
# U5-Sm SNRPD3
color #303.1/R #B0C4DE
# U4-Sm SNRPD3
color #303.1/r #F7F0A6
# U5-Sm SNRPE
color #303.1/S #B0C4DE
# U4-Sm SNRPE
color #303.1/s #F7F0A6
# U5-Sm SNRPF
color #303.1/T #B0C4DE
# U4-Sm SNRPF
color #303.1/t #F7F0A6
# U5-Sm SNRPG
color #303.1/U #B0C4DE
# U4-Sm SNRPG
color #303.1/u #F7F0A6
# LSM8
color #303.1/8 #F4A3A8
# LSM6
color #303.1/6 #F4A3A8
# LSM5
color #303.1/5 #F4A3A8
# LSM4
color #303.1/4 #F4A3A8
# LSM3
color #303.1/3 #F4A3A8
# PRP8BP
color #303.1/D #E2F3F4
# LSM2
color #303.1/2 #F4A3A8
# LSM7
color #303.1/7 #F4A3A8
# PRPF3
color #303.1/K #E1DD1B
# PRPF4
color #303.1/L #E2C496
# PRPF31
color #303.1/J #DFD570
# NHP2L1
color #303.1/I #A89264
# USP39
color #303.1/V #B37E6A
# U4 snRNA
color #303.1/M #E6D900
# U6 snRNA
color #303.1/N #DC143C
# U5 snRNA
color #303.1/H #0000CD
# SNRNP200
color #303.1/C #AFEEEE
# TXNL4A
color #303.1/E #C3BA7A
# PRPF8
color #303.1/A #BFC3E8
# DDX23
color #303.1/F #CA9982
# EFTUD2
color #303.1/B #6495ED
# U5-Sm SNRPB
color #303.1/O #B0C4DE
# U4-Sm SNRPB
color #303.1/o #F7F0A6
# U5-Sm SNRPD1
color #303.1/P #B0C4DE
# U4-Sm SNRPD1
color #303.1/p #F7F0A6
# Named selections for subcomplexes using original deposited chain IDs.
# U4 Sm ring
# selector_meta {"color":"#F5E85A","family":"Protein/RNP groups","group":"U4 snRNP groups","kind":"subcomplex"}
name pdb_3JCR_U4_Sm_ring #303.1/o,p,q,r,s,t,u
# U4 snRNP
# selector_meta {"color":"#D8C800","family":"Protein/RNP groups","group":"U4 snRNP groups","kind":"subcomplex"}
name pdb_3JCR_U4_snRNP #303.1/M
# U4/U6 snRNP
# selector_meta {"color":"#C3BA7A","family":"Protein/RNP groups","group":"U4/U6 groups","kind":"subcomplex"}
name pdb_3JCR_U4_U6_snRNP #303.1/E,F,I,J,K,L,V
# U5 Sm ring
# selector_meta {"color":"#BFC3E8","family":"Protein/RNP groups","group":"U5 snRNP groups","kind":"subcomplex"}
name pdb_3JCR_U5_Sm_ring #303.1/O,P,Q,R,S,T,U
# U5 snRNP
# selector_meta {"color":"#0000CD","family":"Protein/RNP groups","group":"U5 snRNP groups","kind":"subcomplex"}
name pdb_3JCR_U5_snRNP #303.1/A,B,C,D,G,H
# U6 LSm
# selector_meta {"color":"#FECACA","family":"Protein/RNP groups","group":"U6 snRNP groups","kind":"subcomplex"}
name pdb_3JCR_U6_LSm #303.1/2,3,4,5,6,7,8
# U6 snRNP
# selector_meta {"color":"#DC143C","family":"Protein/RNP groups","group":"U6 snRNP groups","kind":"subcomplex"}
name pdb_3JCR_U6_snRNP #303.1/N
# Named selections for resolved snRNA functional regions.
# U4 snRNA U4/U6 stem I partner: residues 1-16, reference-alignment, high confidence
# selector_meta {"color":"#D8C800","family":"RNA","feature":"U4_U6_stem_I_partner","group":"snRNA-snRNA interacting regions","group_key":"snRNA_snRNA_regions","kind":"rna_feature"}
name U5_tri_snRNP_3JCR_U4_U6_stem_I_partner #303.1/M:1-16
# U4 snRNA U4/U6 stem II partner: residues 56-62, reference-alignment, high confidence
# selector_meta {"color":"#E0CF1A","family":"RNA","feature":"U4_U6_stem_II_partner","group":"snRNA-snRNA interacting regions","group_key":"snRNA_snRNA_regions","kind":"rna_feature"}
name U5_tri_snRNP_3JCR_U4_U6_stem_II_partner #303.1/M:56-62
# U4 snRNA Brr2 loading region: residues 60-62;86-88;89-95, review-region, low confidence
# selector_meta {"color":"#F0DF2E","family":"RNA","feature":"U4_Brr2_loading_region","group":"other snRNA regions","group_key":"other_snRNA_regions","kind":"rna_feature"}
name U5_tri_snRNP_3JCR_U4_Brr2_loading_region #303.1/M:60-62,86-88,89-95
# U4 snRNA Sm site: residues 119-125, sequence-motif, medium confidence
# selector_meta {"color":"#F5E85A","family":"RNA","feature":"U4_Sm_site","group":"other snRNA regions","group_key":"other_snRNA_regions","kind":"rna_feature"}
name U5_tri_snRNP_3JCR_U4_Sm_site #303.1/M:119-125
# U5 snRNA loop I: residues 38-42, sequence-motif, medium confidence
# selector_meta {"color":"#1B3CD0","family":"RNA","feature":"U5_loop_I","group":"snRNA-pre-mRNA regions","group_key":"snRNA_pre_mRNA_regions","kind":"rna_feature"}
name U5_tri_snRNP_3JCR_U5_loop_I #303.1/H:38-42
# U6 snRNA U2/U6 helix I partner: residues 50-56;59-60, motif-neighborhood, medium confidence
# selector_meta {"color":"#D0183C","family":"RNA","feature":"U6_U2_helix_I_partner","group":"snRNA-snRNA interacting regions","group_key":"snRNA_snRNA_regions","kind":"rna_feature"}
name U5_tri_snRNP_3JCR_U6_U2_helix_I_partner #303.1/N:50-56,59-60
# U6 snRNA U4/U6 stem II partner: residues 52-56;59-61, reference-alignment, high confidence
# selector_meta {"color":"#E01842","family":"RNA","feature":"U6_U4_stem_II_partner","group":"other snRNA regions","group_key":"other_snRNA_regions","kind":"rna_feature"}
name U5_tri_snRNP_3JCR_U6_U4_stem_II_partner #303.1/N:52-56,59-61
# U6 snRNA U4/U6 stem I partner: residues 63-74, reference-alignment, high confidence
# selector_meta {"color":"#D9183E","family":"RNA","feature":"U6_U4_stem_I_partner","group":"other snRNA regions","group_key":"other_snRNA_regions","kind":"rna_feature"}
name U5_tri_snRNP_3JCR_U6_U4_stem_I_partner #303.1/N:63-74
# U6 snRNA internal stem-loop: residues 79-84;103-106, motif-neighborhood, low confidence
# selector_meta {"color":"#D61A3D","family":"RNA","feature":"U6_ISL","group":"internal stem loops","group_key":"internal_stem_loops","kind":"rna_feature"}
name U5_tri_snRNP_3JCR_U6_ISL #303.1/N:79-84,103-106
# U6 snRNA LSm site: residues 103-106, terminal-region, low confidence
# selector_meta {"color":"#E33A55","family":"RNA","feature":"U6_LSm_site","group":"other snRNA regions","group_key":"other_snRNA_regions","kind":"rna_feature"}
name U5_tri_snRNP_3JCR_U6_LSm_site #303.1/N:103-106
# RNA feature nucleotide display.
select #303.1 & nucleic
nucleotides sel atoms
select clear
# U4/U6 stem I: residues 1-16
color #303.1/M:1-16 #D8C800
select #303.1/M:1-16
nucleotides sel fill
select clear
# U4/U6 stem II: residues 56-62
color #303.1/M:56-62 #E0CF1A
select #303.1/M:56-62
nucleotides sel fill
select clear
# U4 Brr2 region: residues 60-62;86-88;89-95
color #303.1/M:60-62,86-88,89-95 #F0DF2E
select #303.1/M:60-62,86-88,89-95
nucleotides sel fill
select clear
# U5 loop I: residues 38-42
color #303.1/H:38-42 #1B3CD0
select #303.1/H:38-42
nucleotides sel fill
select clear
# U2/U6 helix I: residues 50-56;59-60
color #303.1/N:50-56,59-60 #D0183C
select #303.1/N:50-56,59-60
nucleotides sel fill
select clear
# U4/U6 stem II: residues 52-56;59-61
color #303.1/N:52-56,59-61 #E01842
select #303.1/N:52-56,59-61
nucleotides sel fill
select clear
# U4/U6 stem I: residues 63-74
color #303.1/N:63-74 #D9183E
select #303.1/N:63-74
nucleotides sel fill
select clear
# U6 ISL: residues 79-84;103-106
color #303.1/N:79-84,103-106 #D61A3D
select #303.1/N:79-84,103-106
nucleotides sel fill
select clear
# RNA feature 3D residue labels.
# Labels are created as independent grouped models under #303.2.
# Fetch and run the self-contained RNA label script from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/label_scripts/3jcr_rna_labels.py
# Searchable named selection browser.
# In GUI ChimeraX this opens a small panel for selecting, zooming, and toggling RNA labels.
# Fetch and open the self-contained named selection browser from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/selection_browser_scripts/3jcr_selection_browser.py
view
show nucleic
