# Lightweight ChimeraX script for 8RO2
# Models are downloaded directly by ChimeraX from the PDB.
# Primary maps, when requested, are downloaded directly from EMDB.
# Original deposited chain identifiers are used.

# Shared anchor frame: 8H6L
# Structure group: #415; target model: #415.1; RNA labels: #415.2.

open 8h6l id 415.9 name 8H6L_anchor
open 8ro2 id 415.1 name 8RO2
open emdb:19399 id 415.3.1 name 8RO2_EMD-19399_primary_map
rename #415 ILS_8ro2_structure

# Align on PRPF8.
matchmaker #415.1/A to #415.9/5B bring #415.3.1
close #415.9

# Remove implausibly long deposited covalent bonds before styling.
# Fetch and run the implausible-bond pruning helper from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/prune_implausible_bonds.py

hide atoms
cartoon
# Default display style.
style (protein|nucleic|solvent) & @@draw_mode=0 stick
cartoon style modeh def arrows t arrowshelix f arrowscale 3 wid 4 thick 3 sides 12 div 20
cartoon style ~(nucleic|strand) x round
cartoon style (nucleic|strand) x rect
cartoon style nucleic x round width 4 thick 4
lighting shadows false
lighting simple
camera ortho
lighting soft intensity 0.2 fillIntensity 0.5 ambientIntensity 1
lighting soft

# bg and model colors
set bgColor white
style nucleic stick
graphics silhouettes true
cartoon style arrowScale 1.5
color byhetero
# Subunit colors from color_code/subunit_color_code.csv.
# U2 snRNA
color #415.1/2 #71C562
# U6 snRNA
color #415.1/6 #EF4444
# EFTUD2
color #415.1/C #6495ED
# ISY1
color #415.1/D #FFEF8C
# DHX15
color #415.1/DX #663399
# PRP8BP
color #415.1/E #E2F3F4
# CRNKL1
color #415.1/J #FFC388
# BCAS2
color #415.1/K #FFDAB9
# CWF19L1
color #415.1/L1 #DDA0DD
# BUD31
color #415.1/N #FFF584
# RBM22
color #415.1/O #DE9A52
# AQR
color #415.1/Q #FFDAB9
# SNW1
color #415.1/R #D49F96
# PPIL1
color #415.1/S #EEE8AA
# PRPF17
color #415.1/W #FFF7C9
# CCDC12
color #415.1/Z #FAEBD7
# U5-Sm SNRPD3
color #415.1/a #B0C4DE
# U5-Sm SNRPD1
color #415.1/c #B0C4DE
# U5-Sm SNRPD2
color #415.1/d #B0C4DE
# U5-Sm SNRPE
color #415.1/e #B0C4DE
# U5-Sm SNRPF
color #415.1/f #B0C4DE
# U5-Sm SNRPG
color #415.1/g #B0C4DE
# PRPF19
color #415.1/q #FFFFAB
# PRPF19
color #415.1/r #FFFFAB
# PRPF19
color #415.1/s #FFFFAB
# PRPF19
color #415.1/t #FFFFAB
# SDE2
color #415.1/z #FFFF00
# ESS2
color #415.1/3 #6669B0
# U5 snRNA
color #415.1/5 #4F9FD3
# PRPF8
color #415.1/A #BFC3E8
# SYF1
color #415.1/I #FF957B
# INTRON
color #415.1/IN #303030
# CDC5L
color #415.1/L #DAA520
# CWF19L2
color #415.1/L2 #8B008B
# SYF2
color #415.1/M #FF8C00
# CWC15
color #415.1/P #FFDEAD
# PAXBP1
color #415.1/PX #FFC0CB
# PLRG1
color #415.1/T #F4A460
# TFIP11
color #415.1/TF #FF69B4
# U5-Sm SNRPB
color #415.1/b #B0C4DE
# Named selections for subcomplexes using original deposited chain IDs.
# Disassembly factors
# selector_meta {"color":"#FF69B4","family":"Protein/RNP groups","group":"disassembly factors","kind":"subcomplex"}
name pdb_8RO2_Disassembly_factors #415.1/PX,TF
# NTC/NTR related
# selector_meta {"color":"#F4BF67","family":"Protein/RNP groups","group":"NTC/NTR groups","kind":"subcomplex"}
name pdb_8RO2_NTC_NTR_related #415.1/D,I,J,L2,M,N,O,Q,R,S
# NTC/PRP19
# selector_meta {"color":"#F4BF67","family":"Protein/RNP groups","group":"NTC/NTR groups","kind":"subcomplex"}
name pdb_8RO2_NTC_PRP19 #415.1/K,L,P,T,q,r,s,t
# RNA/substrate
# selector_meta {"color":"#303030","family":"RNA","group":"pre-mRNA features","kind":"subcomplex"}
name pdb_8RO2_RNA_substrate #415.1/IN
# Second step factors
# selector_meta {"color":"#9CA3AF","family":"Protein/RNP groups","group":"other protein/RNP groups","kind":"subcomplex"}
name pdb_8RO2_Second_step_factors #415.1/W
# U2 snRNP
# selector_meta {"color":"#2F8B4D","family":"Protein/RNP groups","group":"U2/SF3B groups","kind":"subcomplex"}
name pdb_8RO2_U2_snRNP #415.1/2,DX
# U5 Sm ring
# selector_meta {"color":"#BFC3E8","family":"Protein/RNP groups","group":"U5 snRNP groups","kind":"subcomplex"}
name pdb_8RO2_U5_Sm_ring #415.1/a,b,c,d,e,f,g
# U5 snRNP
# selector_meta {"color":"#0000CD","family":"Protein/RNP groups","group":"U5 snRNP groups","kind":"subcomplex"}
name pdb_8RO2_U5_snRNP #415.1/5,A,C,E
# U6 snRNP
# selector_meta {"color":"#DC143C","family":"Protein/RNP groups","group":"U6 snRNP groups","kind":"subcomplex"}
name pdb_8RO2_U6_snRNP #415.1/6
# other
# selector_meta {"color":"#9CA3AF","family":"Protein/RNP groups","group":"other protein/RNP groups","kind":"subcomplex"}
name pdb_8RO2_other #415.1/3,L1,Z,z
# Named selections for resolved substrate RNA features.
# intron: residues 1-24;138-154, component-name, high confidence, validation not_applicable
# selector_meta {"color":"#303030","family":"RNA","feature":"intron","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name ILS_disassembly_8RO2_intron #415.1/IN:1-24,138-154
# substrate RNA: residues 1-24;138-154, component, medium confidence, validation not_applicable
# selector_meta {"color":"#303030","family":"RNA","feature":"substrate","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name ILS_disassembly_8RO2_substrate #415.1/IN:1-24,138-154
# Named selections for resolved snRNA functional regions.
# U2 snRNA U2/U6 helix I partner: residues 26-30, review-region, high confidence
# selector_meta {"color":"#047857","family":"RNA","feature":"U2_U6_helix_I_partner","group":"snRNA-snRNA interacting regions","group_key":"snRNA_snRNA_regions","kind":"rna_feature"}
name ILS_disassembly_8RO2_U2_U6_helix_I_partner #415.1/2:26-30
# U2 snRNA branchpoint pairing region: residues 32-39, sequence-motif-neighborhood, medium confidence
# selector_meta {"color":"#0B6E2D","family":"RNA","feature":"U2_branchpoint_pairing_region","group":"snRNA-pre-mRNA regions","group_key":"snRNA_pre_mRNA_regions","kind":"rna_feature"}
name ILS_disassembly_8RO2_U2_branchpoint_pairing_region #415.1/2:32-39
# U5 snRNA loop I: residues 38-42, sequence-motif, medium confidence
# selector_meta {"color":"#1B3CD0","family":"RNA","feature":"U5_loop_I","group":"snRNA-pre-mRNA regions","group_key":"snRNA_pre_mRNA_regions","kind":"rna_feature"}
name ILS_disassembly_8RO2_U5_loop_I #415.1/5:38-42
# U6 snRNA 5' terminal stem-loop: residues 1-30, reference-alignment, high confidence
# selector_meta {"color":"#DC143C","family":"RNA","feature":"U6_5prime_terminal_stem_loop","group":"internal stem loops","group_key":"internal_stem_loops","kind":"rna_feature"}
name ILS_disassembly_8RO2_U6_5_terminal_stem_loop #415.1/6:1-30
# U6 snRNA U2/U6 helix I partner: residues 35-60, motif-neighborhood, medium confidence
# selector_meta {"color":"#D0183C","family":"RNA","feature":"U6_U2_helix_I_partner","group":"snRNA-snRNA interacting regions","group_key":"snRNA_snRNA_regions","kind":"rna_feature"}
name ILS_disassembly_8RO2_U6_U2_helix_I_partner #415.1/6:35-60
# U6 snRNA 5' splice-site upstream contact: residues 38-49, motif-neighborhood, medium confidence
# selector_meta {"color":"#E01842","family":"RNA","feature":"U6_5SS_upstream_contact","group":"other snRNA regions","group_key":"other_snRNA_regions","kind":"rna_feature"}
name ILS_disassembly_8RO2_U6_5SS_upstream_contact #415.1/6:38-49
# U6 snRNA ACAGAGA box: residues 41-47, sequence-motif, high confidence
# selector_meta {"color":"#DC143C","family":"RNA","feature":"U6_ACAGAGA_box","group":"other snRNA regions","group_key":"other_snRNA_regions","kind":"rna_feature"}
name ILS_disassembly_8RO2_U6_ACAGAGA_box #415.1/6:41-47
# U6 snRNA internal stem-loop: residues 79-97, motif-neighborhood, low confidence
# selector_meta {"color":"#D61A3D","family":"RNA","feature":"U6_ISL","group":"internal stem loops","group_key":"internal_stem_loops","kind":"rna_feature"}
name ILS_disassembly_8RO2_U6_ISL #415.1/6:79-97
# U6 snRNA AGC catalytic triad: residues 92-94, sequence-motif, medium confidence
# selector_meta {"color":"#C91236","family":"RNA","feature":"U6_AGC_catalytic_triad","group":"catalytic core regions","group_key":"catalytic_core_regions","kind":"rna_feature"}
name ILS_disassembly_8RO2_U6_AGC_catalytic_triad #415.1/6:92-94
# U6 snRNA LSm site: residues 97, terminal-region, low confidence
# selector_meta {"color":"#E33A55","family":"RNA","feature":"U6_LSm_site","group":"other snRNA regions","group_key":"other_snRNA_regions","kind":"rna_feature"}
name ILS_disassembly_8RO2_U6_LSm_site #415.1/6:97
# RNA feature nucleotide display.
select #415.1 & nucleic
nucleotides sel atoms
select clear
# intron: residues 1-24;138-154
# U2/U6 helix I: residues 26-30
color #415.1/2:26-30 #047857
select #415.1/2:26-30
nucleotides sel fill
select clear
# U2 BP pairing: residues 32-39
color #415.1/2:32-39 #0B6E2D
select #415.1/2:32-39
nucleotides sel fill
select clear
# U5 loop I: residues 38-42
color #415.1/5:38-42 #1B3CD0
select #415.1/5:38-42
nucleotides sel fill
select clear
# U6 5' terminal SL: residues 1-30
color #415.1/6:1-30 #DC143C
select #415.1/6:1-30
nucleotides sel fill
select clear
# U2/U6 helix I: residues 35-60
color #415.1/6:35-60 #D0183C
select #415.1/6:35-60
nucleotides sel fill
select clear
# U6 5'SS contact: residues 38-49
color #415.1/6:38-49 #E01842
select #415.1/6:38-49
nucleotides sel fill
select clear
# U6 ACAGAGA: residues 41-47
color #415.1/6:41-47 #DC143C
select #415.1/6:41-47
nucleotides sel fill
select clear
# U6 ISL: residues 79-97
color #415.1/6:79-97 #D61A3D
select #415.1/6:79-97
nucleotides sel fill
select clear
# U6 AGC triad: residues 92-94
color #415.1/6:92-94 #C91236
select #415.1/6:92-94
nucleotides sel fill
select clear
# RNA feature 3D residue labels.
# Labels are created as independent grouped models under #415.2.
# Fetch and run the self-contained RNA label script from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/label_scripts/8ro2_rna_labels.py
# Searchable named selection browser.
# In GUI ChimeraX this opens a small panel for selecting, zooming, and toggling RNA labels.
# Fetch and open the self-contained named selection browser from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/selection_browser_scripts/8ro2_selection_browser.py
view
show nucleic
