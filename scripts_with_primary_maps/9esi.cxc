# Lightweight ChimeraX script for 9ESI
# Models are downloaded directly by ChimeraX from the PDB.
# Primary maps, when requested, are downloaded directly from EMDB.
# Original deposited chain identifiers are used.

# Shared anchor frame: 8H6L
# Structure group: #420; target model: #420.1; RNA labels: #420.2.

open 8h6l id 420.9 name 8H6L_anchor
open 9esi id 420.1 name 9ESI
open emdb:19942 id 420.3.1 name spliceosome_9esi_EMD-19942_primary_map
rename #420 spliceosome_9esi_structure

# Align on PRPF8.
matchmaker #420.1/A to #420.9/5B bring #420.3.1
close #420.9

# Remove implausibly long deposited covalent bonds before styling.
# Fetch and run the implausible-bond pruning helper from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/prune_implausible_bonds.py

hide atoms
cartoon
# Default display style.
style (protein|nucleic|solvent) & @@draw_mode=0 stick
cartoon style modeh def arrows t arrowshelix f arrowscale 3 wid 4 thick 3 sides 12 div 20
cartoon style ~(nucleic|strand) x round
cartoon style (nucleic|strand) x rect
cartoon style nucleic x round width 4 thick 4
lighting shadows false
lighting simple
camera ortho
lighting soft intensity 0.2 fillIntensity 0.5 ambientIntensity 1
lighting soft

# bg and model colors
set bgColor white
style nucleic stick
graphics silhouettes true
cartoon style arrowScale 1.5
color byhetero
# Subunit colors from color_code/subunit_color_code.csv.
# CCDC94
color #420.1/p #CE4678
# U2 snRNA
color #420.1/2 #71C562
# U5 snRNA
color #420.1/5 #4F9FD3
# PRPF8
color #420.1/A #BFC3E8
# EFTUD2
color #420.1/B #6495ED
# PRP8BP
color #420.1/C #E2F3F4
# U5-Sm SNRPD3
color #420.1/D #B0C4DE
# U5-Sm SNRPB
color #420.1/E #B0C4DE
# U5-Sm SNRPD1
color #420.1/F #B0C4DE
# U5-Sm SNRPD2
color #420.1/G #B0C4DE
# U5-Sm SNRPE
color #420.1/H #B0C4DE
# U5-Sm SNRPF
color #420.1/I #B0C4DE
# U5-Sm SNRPG
color #420.1/J #B0C4DE
# DDX46
color #420.1/K #5BAE8A
# SNW1
color #420.1/L #D49F96
# RBM22
color #420.1/M #DE9A52
# AQR
color #420.1/N #FFDAB9
# BUD31
color #420.1/O #FFF584
# PRPF3
color #420.1/P #E1DD1B
# CWC15
color #420.1/Q #FFDEAD
# CRNKL1
color #420.1/R #FFC388
# PRPF19
color #420.1/S #FFFFAB
# PRPF19
color #420.1/T #FFFFAB
# PRPF19
color #420.1/U #FFFFAB
# PRPF19
color #420.1/V #FFFFAB
# CDC5L
color #420.1/W #DAA520
# SYF1
color #420.1/X #FF957B
# U2-Sm SNRPF
color #420.1/Y #D5F5E3
# BCAS2
color #420.1/Z #FFDAB9
# PRPF17
color #420.1/a #FFF7C9
# CWC22
color #420.1/c #2C54DD
# PPIL1
color #420.1/d #EEE8AA
# TFIP11
color #420.1/m #FF69B4
# U6 snRNA
color #420.1/6 #EF4444
# mRNA
color #420.1/1 #303030
# Named selections for subcomplexes using original deposited chain IDs.
# Disassembly factors
# selector_meta {"color":"#FF69B4","family":"Protein/RNP groups","group":"disassembly factors","kind":"subcomplex"}
name pdb_9ESI_Disassembly_factors #420.1/m
# EJC/mRNP
# selector_meta {"color":"#EAA439","family":"Protein/RNP groups","group":"EJC/mRNP groups","kind":"subcomplex"}
name pdb_9ESI_EJC_mRNP #420.1/c
# NTC/NTR related
# selector_meta {"color":"#F4BF67","family":"Protein/RNP groups","group":"NTC/NTR groups","kind":"subcomplex"}
name pdb_9ESI_NTC_NTR_related #420.1/L,M,N,O,R,X,d
# NTC/PRP19
# selector_meta {"color":"#F4BF67","family":"Protein/RNP groups","group":"NTC/NTR groups","kind":"subcomplex"}
name pdb_9ESI_NTC_PRP19 #420.1/Q,S,T,U,V,W,Z
# RNA/substrate
# selector_meta {"color":"#303030","family":"RNA","group":"pre-mRNA features","kind":"subcomplex"}
name pdb_9ESI_RNA_substrate #420.1/1
# Second step factors
# selector_meta {"color":"#9CA3AF","family":"Protein/RNP groups","group":"other protein/RNP groups","kind":"subcomplex"}
name pdb_9ESI_Second_step_factors #420.1/a
# U2 Sm ring
# selector_meta {"color":"#BFE6BF","family":"Protein/RNP groups","group":"U2/SF3B groups","kind":"subcomplex"}
name pdb_9ESI_U2_Sm_ring #420.1/Y
# U2 snRNP
# selector_meta {"color":"#2F8B4D","family":"Protein/RNP groups","group":"U2/SF3B groups","kind":"subcomplex"}
name pdb_9ESI_U2_snRNP #420.1/2,K,p
# U4/U6 snRNP
# selector_meta {"color":"#C3BA7A","family":"Protein/RNP groups","group":"U4/U6 groups","kind":"subcomplex"}
name pdb_9ESI_U4_U6_snRNP #420.1/P
# U5 Sm ring
# selector_meta {"color":"#BFC3E8","family":"Protein/RNP groups","group":"U5 snRNP groups","kind":"subcomplex"}
name pdb_9ESI_U5_Sm_ring #420.1/D,E,F,G,H,I,J
# U5 snRNP
# selector_meta {"color":"#0000CD","family":"Protein/RNP groups","group":"U5 snRNP groups","kind":"subcomplex"}
name pdb_9ESI_U5_snRNP #420.1/5,A,B,C
# U6 snRNP
# selector_meta {"color":"#DC143C","family":"Protein/RNP groups","group":"U6 snRNP groups","kind":"subcomplex"}
name pdb_9ESI_U6_snRNP #420.1/6
# other
# selector_meta {"color":"#9CA3AF","family":"Protein/RNP groups","group":"other protein/RNP groups","kind":"subcomplex"}
name pdb_9ESI_other #420.1/b,e,f,n,q,r,y,z
# Named selections for resolved substrate RNA features.
# 5' exon: residues -15-0, five-ss-inference, medium confidence, validation not_applicable
# selector_meta {"color":"#FF8C00","family":"RNA","feature":"exon_5","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name B_9ESI_5exon #420.1/1:-15-0
# substrate RNA: residues -15-13, component, medium confidence, validation not_applicable
# selector_meta {"color":"#303030","family":"RNA","feature":"substrate","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name B_9ESI_substrate #420.1/1:-15-13
# 5' splice site: residues 1-6, network-scored-motif, high confidence, validation validated
# selector_meta {"color":"#303030","family":"RNA","feature":"five_prime_splice_site","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name B_9ESI_5SS #420.1/1:1-6
# intron from 5' splice site: residues 1-13, five-ss-inference, low confidence, validation not_applicable
# selector_meta {"color":"#303030","family":"RNA","feature":"intron","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name B_9ESI_intron #420.1/1:1-13
# Named selections for resolved snRNA functional regions.
# U2 snRNA U2/U6 helix I partner: residues 26-30, review-region, high confidence
# selector_meta {"color":"#047857","family":"RNA","feature":"U2_U6_helix_I_partner","group":"snRNA-snRNA interacting regions","group_key":"snRNA_snRNA_regions","kind":"rna_feature"}
name B_9ESI_U2_U6_helix_I_partner #420.1/2:26-30
# U5 snRNA loop I: residues 47-51, sequence-motif, medium confidence
# selector_meta {"color":"#1B3CD0","family":"RNA","feature":"U5_loop_I","group":"snRNA-pre-mRNA regions","group_key":"snRNA_pre_mRNA_regions","kind":"rna_feature"}
name B_9ESI_U5_loop_I #420.1/5:47-51
# U6 snRNA U2/U6 helix I partner: residues 29-54, motif-neighborhood, medium confidence
# selector_meta {"color":"#D0183C","family":"RNA","feature":"U6_U2_helix_I_partner","group":"snRNA-snRNA interacting regions","group_key":"snRNA_snRNA_regions","kind":"rna_feature"}
name B_9ESI_U6_U2_helix_I_partner #420.1/6:29-54
# U6 snRNA 5' splice-site upstream contact: residues 32-43, motif-neighborhood, medium confidence
# selector_meta {"color":"#E01842","family":"RNA","feature":"U6_5SS_upstream_contact","group":"other snRNA regions","group_key":"other_snRNA_regions","kind":"rna_feature"}
name B_9ESI_U6_5SS_upstream_contact #420.1/6:32-43
# U6 snRNA ACAGAGA box: residues 35-41, sequence-motif, high confidence
# selector_meta {"color":"#DC143C","family":"RNA","feature":"U6_ACAGAGA_box","group":"other snRNA regions","group_key":"other_snRNA_regions","kind":"rna_feature"}
name B_9ESI_U6_ACAGAGA_box #420.1/6:35-41
# RNA feature nucleotide display.
select #420.1 & nucleic
nucleotides sel atoms
select clear
# 5' exon: residues -15-0
color #420.1/1:-15-0 #FF8C00
select #420.1/1:-15-0
nucleotides sel fill
select clear
# 5'SS: residues 1-6
# intron: residues 1-13
# U2/U6 helix I: residues 26-30
color #420.1/2:26-30 #047857
select #420.1/2:26-30
nucleotides sel fill
select clear
# U5 loop I: residues 47-51
color #420.1/5:47-51 #1B3CD0
select #420.1/5:47-51
nucleotides sel fill
select clear
# U2/U6 helix I: residues 29-54
color #420.1/6:29-54 #D0183C
select #420.1/6:29-54
nucleotides sel fill
select clear
# U6 5'SS contact: residues 32-43
color #420.1/6:32-43 #E01842
select #420.1/6:32-43
nucleotides sel fill
select clear
# U6 ACAGAGA: residues 35-41
color #420.1/6:35-41 #DC143C
select #420.1/6:35-41
nucleotides sel fill
select clear
# RNA feature 3D residue labels.
# Labels are created as independent grouped models under #420.2.
# Fetch and run the self-contained RNA label script from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/label_scripts/9esi_rna_labels.py
# Searchable named selection browser.
# In GUI ChimeraX this opens a small panel for selecting, zooming, and toggling RNA labels.
# Fetch and open the self-contained named selection browser from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/selection_browser_scripts/9esi_selection_browser.py
view
show nucleic
