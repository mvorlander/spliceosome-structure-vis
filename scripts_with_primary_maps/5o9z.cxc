color #317.1/4 #E6D900
# U5 snRNA
color #317.1/5 #0000CD
# U6 snRNA
color #317.1/6 #DC143C
# PRPF3
color #317.1/E #E1DD1B
# PRPF4
color #317.1/F #E2C496
# PRPF6
color #317.1/G #CFA785
# PRPF31
color #317.1/H #DFD570
# PRPF38A
color #317.1/I #F88379
# Named selections for resolved substrate RNA features.
# 5' exon: residues 49-58, splice-site-inference, medium confidence, validation not_applicable
name B_5O9Z_5exon #317.1/Y:49-58
# substrate RNA: residues 49-75;142-160, component, medium confidence, validation not_applicable
name B_5O9Z_substrate #317.1/Y:49-75,142-160
# 5' splice site: residues 59-64, sequence-motif, medium confidence, validation uncertain uncertain validation
name B_5O9Z_5SS #317.1/Y:59-64
# intron: residues 59-75;142-160, splice-site-inference, medium confidence, validation not_applicable
name B_5O9Z_intron #317.1/Y:59-75,142-160
# Named selections for resolved snRNA functional regions.
# U2 snRNA branchpoint pairing region: residues 32-41, sequence-motif-neighborhood, medium confidence
name B_5O9Z_U2_branchpoint_pairing_region #317.1/2:32-41
# U2 snRNA stem IIa: residues 46, review-region, low confidence
name B_5O9Z_U2_stem_IIa #317.1/2:46
# U2 snRNA Sm site: residues 99-105, sequence-motif, medium confidence
name B_5O9Z_U2_Sm_site #317.1/2:99-105
# U4 snRNA U4/U6 stem I partner: residues 1-18, reference-alignment, high confidence
name B_5O9Z_U4_U6_stem_I_partner #317.1/4:1-18
# U4 snRNA U4/U6 stem II partner: residues 56-63, reference-alignment, high confidence
name B_5O9Z_U4_U6_stem_II_partner #317.1/4:56-63
# U4 snRNA Brr2 loading region: residues 60-63;68-95, review-region, low confidence
name B_5O9Z_U4_Brr2_loading_region #317.1/4:60-63,68-95
# U4 snRNA Sm site: residues 119-125, sequence-motif, medium confidence
name B_5O9Z_U4_Sm_site #317.1/4:119-125
# U5 snRNA loop I: residues 38-42, sequence-motif, medium confidence
name B_5O9Z_U5_loop_I #317.1/5:38-42
# U6 snRNA 5' terminal stem-loop: residues 1-30, reference-alignment, high confidence
name B_5O9Z_U6_5_terminal_stem_loop #317.1/6:1-30
# U6 snRNA U2/U6 helix I partner: residues 35-60, motif-neighborhood, medium confidence
name B_5O9Z_U6_U2_helix_I_partner #317.1/6:35-60
# U6 snRNA 5' splice-site upstream contact: residues 38-49, motif-neighborhood, medium confidence
name B_5O9Z_U6_5SS_upstream_contact #317.1/6:38-49
# U6 snRNA ACAGAGA box: residues 41-47, sequence-motif, high confidence
name B_5O9Z_U6_ACAGAGA_box #317.1/6:41-47
# U6 snRNA U4/U6 stem II partner: residues 52-61, reference-alignment, high confidence
name B_5O9Z_U6_U4_stem_II_partner #317.1/6:52-61
# U6 snRNA U4/U6 stem I partner: residues 63-74, reference-alignment, high confidence
name B_5O9Z_U6_U4_stem_I_partner #317.1/6:63-74
# U6 snRNA internal stem-loop: residues 85-96, motif-neighborhood, low confidence
name B_5O9Z_U6_ISL #317.1/6:85-96
# U6 snRNA AGC catalytic triad: residues 92-94, sequence-motif, medium confidence
name B_5O9Z_U6_AGC_catalytic_triad #317.1/6:92-94
# RNA feature nucleotide display.
select #317.1 & nucleic
nucleotides sel atoms
select clear
# 5' exon: residues 49-58
color #317.1/Y:49-58 #FF8C00
select #317.1/Y:49-58
nucleotides sel fill
select clear
# 5'SS: residues 59-64
# intron: residues 59-75;142-160
# U2 BP pairing: residues 32-41
color #317.1/2:32-41 #0B6E2D
select #317.1/2:32-41
nucleotides sel fill
select clear
# U2 stem IIa: residues 46
color #317.1/2:46 #167A38
select #317.1/2:46
nucleotides sel fill
select clear
# U4/U6 stem I: residues 1-18
color #317.1/4:1-18 #D8C800
select #317.1/4:1-18
nucleotides sel fill
select clear
# U4/U6 stem II: residues 56-63
color #317.1/4:56-63 #E0CF1A
select #317.1/4:56-63
nucleotides sel fill
select clear
# U4 Brr2 region: residues 60-63;68-95
color #317.1/4:60-63,68-95 #F0DF2E
select #317.1/4:60-63,68-95
nucleotides sel fill
select clear
# U5 loop I: residues 38-42
color #317.1/5:38-42 #1B3CD0
select #317.1/5:38-42
nucleotides sel fill
select clear
# U6 5' terminal SL: residues 1-30
color #317.1/6:1-30 #DC143C
select #317.1/6:1-30
nucleotides sel fill
select clear
# U2/U6 helix I: residues 35-60
color #317.1/6:35-60 #D0183C
select #317.1/6:35-60
nucleotides sel fill
select clear
# U6 5'SS contact: residues 38-49
color #317.1/6:38-49 #E01842
select #317.1/6:38-49
nucleotides sel fill
select clear
# U6 ACAGAGA: residues 41-47
color #317.1/6:41-47 #DC143C
select #317.1/6:41-47
nucleotides sel fill
select clear
# U4/U6 stem II: residues 52-61
color #317.1/6:52-61 #E01842
select #317.1/6:52-61
nucleotides sel fill
select clear
# U4/U6 stem I: residues 63-74
color #317.1/6:63-74 #D9183E
select #317.1/6:63-74
nucleotides sel fill
select clear
# U6 ISL: residues 85-96
color #317.1/6:85-96 #D61A3D
select #317.1/6:85-96
nucleotides sel fill
select clear
# U6 AGC triad: residues 92-94
color #317.1/6:92-94 #C91236
select #317.1/6:92-94
nucleotides sel fill
select clear
# RNA feature 3D residue labels.
# Labels are created as independent grouped models under #317.2.
runscript "rna_feature_label_models.py" args "label_specs/5o9z_rna_labels.json"
view
show nucleic
