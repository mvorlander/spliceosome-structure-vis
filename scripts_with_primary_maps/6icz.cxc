color #337.1/h #D5F5E3
# EIF4A3
color #337.1/u #F1D8BC
# U5-Sm SNRPB
color #337.1/b #B0C4DE
# U2-Sm SNRPB
color #337.1/i #D5F5E3
# U5-Sm SNRPD1
color #337.1/c #B0C4DE
# U2-Sm SNRPD1
color #337.1/j #D5F5E3
# U5-Sm SNRPD2
color #337.1/d #B0C4DE
# U2-Sm SNRPD2
color #337.1/k #D5F5E3
# U5-Sm SNRPF
color #337.1/f #B0C4DE
# U2-Sm SNRPF
color #337.1/m #D5F5E3
# U5-Sm SNRPE
color #337.1/e #B0C4DE
# U2-Sm SNRPE
color #337.1/l #D5F5E3
# U5-Sm SNRPG
color #337.1/g #B0C4DE
# U2-Sm SNRPG
color #337.1/n #D5F5E3
# SNRPA1
color #337.1/o #58D68D
# SNRPB2
color #337.1/p #DAF7A6
# DHX8
color #337.1/Y #900C3F
# BCAS2
color #337.1/K #FFDAB9
# CASC3
color #337.1/x #CB8548
# PRPF19
color #337.1/q #FFFFAB
# PRPF19
color #337.1/r #FFFFAB
# PRPF19
color #337.1/s #FFFFAB
# PRPF19
color #337.1/t #FFFFAB
# SNRNP200
color #337.1/D #AFEEEE
# PRPF8
color #337.1/A #BFC3E8
# U5 snRNA
color #337.1/B #0000CD
