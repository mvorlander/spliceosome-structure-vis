# Lightweight ChimeraX script for 9R3D
# Models are downloaded directly by ChimeraX from the PDB.
# Primary maps, when requested, are downloaded directly from EMDB.
# Original deposited chain identifiers are used.

# Shared anchor frame: 8H6L
# Structure group: #428; target model: #428.1; RNA labels: #428.2.

open 8h6l id 428.9 name 8H6L_anchor
open 9r3d id 428.1 name 9R3D
open emdb:53554 id 428.3.1 name 9R3D_EMD-53554_primary_map
rename #428 pre_Bact_9r3d_structure

# Align on PRPF8.
matchmaker #428.1/A to #428.9/5B bring #428.3.1
close #428.9

hide atoms
cartoon
# Default display style.
style (protein|nucleic|solvent) & @@draw_mode=0 stick
cartoon style modeh def arrows t arrowshelix f arrowscale 3 wid 4 thick 3 sides 12 div 20
cartoon style ~(nucleic|strand) x round
cartoon style (nucleic|strand) x rect
cartoon style nucleic x round width 4 thick 4
lighting shadows false
lighting simple
camera ortho
lighting soft intensity 0.2 fillIntensity 0.5 ambientIntensity 1
lighting soft
# window
# windowsize 800 800

# bg and model colors
set bgColor white
style nucleic stick
graphics silhouettes true
cartoon style arrowScale 1.5
color byhetero
# Subunit colors from color_code/subunit_color_code.csv.
# U5 snRNA
color #428.1/5 #0000CD
# pre-mRNA
color #428.1/Z #303030
# UBL5
color #428.1/q #DB7093
# ZMAT2
color #428.1/r #FFB6C1
# PRPF17
color #428.1/P7 #FFF7C9
# PRPF8
color #428.1/A #BFC3E8
# RBM22
color #428.1/P #DE9A52
# PPIL2
color #428.1/t #B12F50
# SNW1
color #428.1/S1 #D49F96
# U6 snRNA
color #428.1/6 #DC143C
# SNRNP200
color #428.1/B #AFEEEE
# EFTUD2
color #428.1/C #6495ED
# PRPF38A
color #428.1/I #F88379
# MFAP1
color #428.1/K #CD5C5C
# BUD31
color #428.1/Q #FFF584
# CA150
color #428.1/T #A2B8CD
# NPWBP
color #428.1/X #D8944F
# Named selections for subcomplexes using original deposited chain IDs.
# NTC/NTR related
# selector_meta {"color":"#F4BF67","family":"Protein/RNP groups","group":"NTC/NTR groups","kind":"subcomplex"}
name pdb_9R3D_NTC_NTR_related #428.1/P,Q,S1
# RNA/substrate
# selector_meta {"color":"#303030","family":"RNA","group":"pre-mRNA features","kind":"subcomplex"}
name pdb_9R3D_RNA_substrate #428.1/Z
# Second step factors
# selector_meta {"color":"#9CA3AF","family":"Protein/RNP groups","group":"other protein/RNP groups","kind":"subcomplex"}
name pdb_9R3D_Second_step_factors #428.1/P7
# U5 snRNP
# selector_meta {"color":"#0000CD","family":"Protein/RNP groups","group":"U5 snRNP groups","kind":"subcomplex"}
name pdb_9R3D_U5_snRNP #428.1/5,A,B,C
# U6 snRNP
# selector_meta {"color":"#DC143C","family":"Protein/RNP groups","group":"U6 snRNP groups","kind":"subcomplex"}
name pdb_9R3D_U6_snRNP #428.1/6
# other
# selector_meta {"color":"#9CA3AF","family":"Protein/RNP groups","group":"other protein/RNP groups","kind":"subcomplex"}
name pdb_9R3D_other #428.1/I,K,T,X,q,r,t
# Named selections for resolved substrate RNA features.
# 5' exon: residues 50-58, five-ss-inference, medium confidence, validation not_applicable
# selector_meta {"color":"#FF8C00","family":"RNA","feature":"exon_5","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name pre_Bact_9R3D_5exon #428.1/Z:50-58
# substrate RNA: residues 50-78, component, medium confidence, validation not_applicable
# selector_meta {"color":"#303030","family":"RNA","feature":"substrate","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name pre_Bact_9R3D_substrate #428.1/Z:50-78
# 5' splice site: residues 59-64, network-scored-motif, high confidence, validation validated
# selector_meta {"color":"#303030","family":"RNA","feature":"five_prime_splice_site","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name pre_Bact_9R3D_5SS #428.1/Z:59-64
# intron from 5' splice site: residues 59-78, five-ss-inference, low confidence, validation not_applicable
# selector_meta {"color":"#303030","family":"RNA","feature":"intron","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name pre_Bact_9R3D_intron #428.1/Z:59-78
# Named selections for resolved snRNA functional regions.
# U5 snRNA loop I: residues 38-42, sequence-motif, medium confidence
# selector_meta {"color":"#1B3CD0","family":"RNA","feature":"U5_loop_I","group":"snRNA-pre-mRNA regions","group_key":"snRNA_pre_mRNA_regions","kind":"rna_feature"}
name pre_Bact_9R3D_U5_loop_I #428.1/5:38-42
# U6 snRNA 5' terminal stem-loop: residues 1-30, reference-alignment, high confidence
# selector_meta {"color":"#DC143C","family":"RNA","feature":"U6_5prime_terminal_stem_loop","group":"internal stem loops","group_key":"internal_stem_loops","kind":"rna_feature"}
name pre_Bact_9R3D_U6_5_terminal_stem_loop #428.1/6:1-30
# U6 snRNA U2/U6 helix I partner: residues 35-60, motif-neighborhood, medium confidence
# selector_meta {"color":"#D0183C","family":"RNA","feature":"U6_U2_helix_I_partner","group":"snRNA-snRNA interacting regions","group_key":"snRNA_snRNA_regions","kind":"rna_feature"}
name pre_Bact_9R3D_U6_U2_helix_I_partner #428.1/6:35-60
# U6 snRNA 5' splice-site upstream contact: residues 38-49, motif-neighborhood, medium confidence
# selector_meta {"color":"#E01842","family":"RNA","feature":"U6_5SS_upstream_contact","group":"other snRNA regions","group_key":"other_snRNA_regions","kind":"rna_feature"}
name pre_Bact_9R3D_U6_5SS_upstream_contact #428.1/6:38-49
# U6 snRNA ACAGAGA box: residues 41-47, sequence-motif, high confidence
# selector_meta {"color":"#DC143C","family":"RNA","feature":"U6_ACAGAGA_box","group":"other snRNA regions","group_key":"other_snRNA_regions","kind":"rna_feature"}
name pre_Bact_9R3D_U6_ACAGAGA_box #428.1/6:41-47
# RNA feature nucleotide display.
select #428.1 & nucleic
nucleotides sel atoms
select clear
# 5' exon: residues 50-58
color #428.1/Z:50-58 #FF8C00
select #428.1/Z:50-58
nucleotides sel fill
select clear
# 5'SS: residues 59-64
# intron: residues 59-78
# U5 loop I: residues 38-42
color #428.1/5:38-42 #1B3CD0
select #428.1/5:38-42
nucleotides sel fill
select clear
# U6 5' terminal SL: residues 1-30
color #428.1/6:1-30 #DC143C
select #428.1/6:1-30
nucleotides sel fill
select clear
# U2/U6 helix I: residues 35-60
color #428.1/6:35-60 #D0183C
select #428.1/6:35-60
nucleotides sel fill
select clear
# U6 5'SS contact: residues 38-49
color #428.1/6:38-49 #E01842
select #428.1/6:38-49
nucleotides sel fill
select clear
# U6 ACAGAGA: residues 41-47
color #428.1/6:41-47 #DC143C
select #428.1/6:41-47
nucleotides sel fill
select clear
# RNA feature 3D residue labels.
# Labels are created as independent grouped models under #428.2.
# Fetch and run the self-contained RNA label script from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/label_scripts/9r3d_rna_labels.py
# Searchable named selection browser.
# In GUI ChimeraX this opens a small panel for selecting, zooming, and toggling RNA labels.
# Fetch and open the self-contained named selection browser from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/selection_browser_scripts/9r3d_selection_browser.py
view
show nucleic
