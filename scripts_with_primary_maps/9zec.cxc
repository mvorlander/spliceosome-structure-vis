# Lightweight ChimeraX script for 9ZEC
# Models are downloaded directly by ChimeraX from the PDB.
# Primary maps, when requested, are downloaded directly from EMDB.
# Original deposited chain identifiers are used.

# Shared anchor frame: 8H6L
# Structure group: #435; target model: #435.1; RNA labels: #435.2.

open 8h6l id 435.9 name 8H6L_anchor
open 9zec id 435.1 name 9ZEC
open emdb:74099 id 435.3.1 name 9ZEC_EMD-74099_primary_map
rename #435 U2_pre_A_A_9zec_structure

# Align on SF3B1.
matchmaker #435.1/B1 to #435.9/2G bring #435.3.1
close #435.9

# Remove implausibly long deposited covalent bonds before styling.
# Fetch and run the implausible-bond pruning helper from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/prune_implausible_bonds.py

hide atoms
cartoon
# Default display style.
style (protein|nucleic|solvent) & @@draw_mode=0 stick
cartoon style modeh def arrows t arrowshelix f arrowscale 3 wid 4 thick 3 sides 12 div 20
cartoon style ~(nucleic|strand) x round
cartoon style (nucleic|strand) x rect
cartoon style nucleic x round width 4 thick 4
lighting shadows false
lighting simple
camera ortho
lighting soft intensity 0.2 fillIntensity 0.5 ambientIntensity 1
lighting soft

# bg and model colors
set bgColor white
style nucleic stick
graphics silhouettes true
cartoon style arrowScale 1.5
color byhetero
# Subunit colors from color_code/subunit_color_code.csv.
# U2 snRNA
color #435.1/2 #006400
# SF3B5
color #435.1/B5 #92BB8F
# SF3B6
color #435.1/B6 #ADCEA0
# PHF5A
color #435.1/H #375A40
# pre-mRNA
color #435.1/R #303030
# NAM8
color #435.1/A #C7A6BE
# SF3A1
color #435.1/A1 #55947F
# SF3A2
color #435.1/A2 #75A074
# SF3A3
color #435.1/A3 #9BCF91
# SF3B1
color #435.1/B1 #487957
# SF3B2
color #435.1/B2 #49926C
# SF3B3
color #435.1/B3 #6A9064
# SF3B4
color #435.1/B4 #77B088
# Named selections for subcomplexes using original deposited chain IDs.
# RNA/substrate
# selector_meta {"color":"#303030","family":"RNA","group":"pre-mRNA features","kind":"subcomplex"}
name pdb_9ZEC_RNA_substrate #435.1/R
# U1 snRNP
# selector_meta {"color":"#B66AAE","family":"Protein/RNP groups","group":"U1 snRNP groups","kind":"subcomplex"}
name pdb_9ZEC_U1_snRNP #435.1/A
# U2 snRNP
# selector_meta {"color":"#2F8B4D","family":"Protein/RNP groups","group":"U2/SF3B groups","kind":"subcomplex"}
name pdb_9ZEC_U2_snRNP #435.1/2
# U2/SF3B
# selector_meta {"color":"#6DBE70","family":"Protein/RNP groups","group":"U2/SF3B groups","kind":"subcomplex"}
name pdb_9ZEC_U2_SF3B #435.1/A1,A2,A3,B1,B2,B3,B4,B5,B6,H
# Named selections for resolved substrate RNA features.
# substrate RNA: residues -18-13, component, medium confidence, validation not_applicable
# selector_meta {"color":"#303030","family":"RNA","feature":"substrate","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name U2_snRNP_9ZEC_substrate #435.1/R:-18-13
# Named selections for resolved snRNA functional regions.
# U2 snRNA branchpoint pairing region: residues 32-41, sequence-motif-neighborhood, medium confidence
# selector_meta {"color":"#0B6E2D","family":"RNA","feature":"U2_branchpoint_pairing_region","group":"snRNA-pre-mRNA regions","group_key":"snRNA_pre_mRNA_regions","kind":"rna_feature"}
name U2_snRNP_9ZEC_U2_branchpoint_pairing_region #435.1/2:32-41
# RNA feature nucleotide display.
select #435.1 & nucleic
nucleotides sel atoms
select clear
# U2 BP pairing: residues 32-41
color #435.1/2:32-41 #0B6E2D
select #435.1/2:32-41
nucleotides sel fill
select clear
# RNA feature 3D residue labels.
# Labels are created as independent grouped models under #435.2.
# Fetch and run the self-contained RNA label script from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/label_scripts/9zec_rna_labels.py
# Searchable named selection browser.
# In GUI ChimeraX this opens a small panel for selecting, zooming, and toggling RNA labels.
# Fetch and open the self-contained named selection browser from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/selection_browser_scripts/9zec_selection_browser.py
view
show nucleic
