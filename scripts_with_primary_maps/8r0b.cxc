select #410.1/6:38-49
nucleotides sel fill
select clear
# U6 ACAGAGA: residues 41-47
color #410.1/6:41-47 #DC143C
select #410.1/6:41-47
nucleotides sel fill
select clear
# U4/U6 stem II: residues 52-61
color #410.1/6:52-61 #E01842
select #410.1/6:52-61
nucleotides sel fill
select clear
# U4/U6 stem I: residues 63-74
color #410.1/6:63-74 #D9183E
select #410.1/6:63-74
nucleotides sel fill
select clear
# U6 ISL: residues 85-96;102-106
color #410.1/6:85-96,102-106 #D61A3D
select #410.1/6:85-96,102-106
nucleotides sel fill
select clear
# U6 AGC triad: residues 92-94
color #410.1/6:92-94 #C91236
select #410.1/6:92-94
nucleotides sel fill
select clear
# RNA feature 3D residue labels.
# Labels are created as independent grouped models under #410.2.
# Fetch and run the self-contained RNA label script from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/label_scripts/8r0b_rna_labels.py
# Searchable named selection browser.
# In GUI ChimeraX this opens a small panel for selecting and zooming named selections.
# Fetch and open the self-contained named selection browser from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/selection_browser_scripts/8r0b_selection_browser.py
view
show nucleic
