# U6 snRNA LSm site: residues 102-106, terminal-region, low confidence
# selector_meta {"color":"#E33A55","family":"RNA","feature":"U6_LSm_site","group":"other snRNA regions","group_key":"other_snRNA_regions","kind":"rna_feature"}
name pre_B_8R0B_U6_LSm_site #410.1/6:102-106
# RNA feature nucleotide display.
select #410.1 & nucleic
nucleotides sel atoms
select clear
# intron: residues 1-8; 29-43
# BP region: residues 36-43
# BP-A: residues 41
# 5' exon: residues -5--1
color #410.1/z:-5--1 #FF8C00
select #410.1/z:-5--1
nucleotides sel fill
select clear
# 5'SS: residues 1-6
# U2/U6 helix I: residues 29-30
color #410.1/2:29-30 #047857
select #410.1/2:29-30
nucleotides sel fill
select clear
# U2 BP pairing: residues 32-41
color #410.1/2:32-41 #0B6E2D
