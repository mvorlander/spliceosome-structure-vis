# Lightweight ChimeraX script for 7A5P
# Models are downloaded directly by ChimeraX from the PDB.
# Primary maps, when requested, are downloaded directly from EMDB.
# Original deposited chain identifiers are used.

# Shared anchor frame: 8H6L
# Structure group: #353; target model: #353.1; RNA labels: #353.2.

open 8h6l id 353.9 name 8H6L_anchor
open 7a5p id 353.1 name 7A5P
rename #353 C_7a5p_structure

# Align on PRPF8.
matchmaker #353.1/A to #353.9/5B
close #353.9

hide atoms
cartoon
# Default display style.
style (protein|nucleic|solvent) & @@draw_mode=0 stick
cartoon style modeh def arrows t arrowshelix f arrowscale 3 wid 4 thick 3 sides 12 div 20
cartoon style ~(nucleic|strand) x round
cartoon style (nucleic|strand) x rect
cartoon style nucleic x round width 4 thick 4
lighting shadows false
lighting simple
camera ortho
lighting soft intensity 0.2 fillIntensity 0.5 ambientIntensity 1
lighting soft
# window
# windowsize 800 800

# bg and model colors
set bgColor white
style nucleic stick
graphics silhouettes true
cartoon style arrowScale 1.5
color byhetero
# Subunit colors from color_code/subunit_color_code.csv.
# U2 snRNA
color #353.1/2 #006400
# CDC5L
color #353.1/L #DAA520
# SYF1
color #353.1/M #FF957B
# SYF2
color #353.1/N #FF8C00
# CRNKL1
color #353.1/O #FFC388
# RBM22
color #353.1/P #DE9A52
# SRRM2
color #353.1/S #BDD6F0
# CWC22
color #353.1/T #2C54DD
# AQR
color #353.1/U #FFDAB9
# SNRPA1
color #353.1/W #58D68D
# SNRPB2
color #353.1/X #DAF7A6
# U5 snRNA
color #353.1/5 #0000CD
# pre-mRNA
color #353.1/Y #303030
# U5-Sm SNRPD3
color #353.1/a #B0C4DE
# U2-Sm SNRPD3
color #353.1/l #D5F5E3
# U5-Sm SNRPB
color #353.1/b #B0C4DE
# U2-Sm SNRPB
color #353.1/m #D5F5E3
# U5-Sm SNRPD1
color #353.1/c #B0C4DE
# U2-Sm SNRPD1
color #353.1/n #D5F5E3
# U5-Sm SNRPD2
color #353.1/d #B0C4DE
# U2-Sm SNRPD2
color #353.1/h #D5F5E3
# U5-Sm SNRPE
color #353.1/e #B0C4DE
# U2-Sm SNRPE
color #353.1/j #D5F5E3
# U5-Sm SNRPF
color #353.1/f #B0C4DE
# U2-Sm SNRPF
color #353.1/i #D5F5E3
# U5-Sm SNRPG
color #353.1/g #B0C4DE
# U2-Sm SNRPG
color #353.1/k #D5F5E3
# PPIE
color #353.1/o #FFFFE0
# WDR70
color #353.1/p #7363C5
# U6 snRNA
color #353.1/6 #DC143C
# SNRNP200
color #353.1/q #AFEEEE
# DDX38
color #353.1/r #5F2E8A
# ISY1
color #353.1/s #FFEF8C
# CCDC94
color #353.1/u #CE4678
# MAGOH
color #353.1/v #EAA439
# RBM8A
color #353.1/w #EB6841
# FRG1
color #353.1/x #CDA470
# EIF4A3
color #353.1/y #F1D8BC
# PPWD1
color #353.1/z #7352A2
# PRPF8
color #353.1/A #BFC3E8
# SNW1
color #353.1/C #D49F96
# PRPF17
color #353.1/E #FFF7C9
# PRPF19
color #353.1/G #FFFFAB
# PRPF19
color #353.1/H #FFFFAB
# PRPF19
color #353.1/I #FFFFAB
# PRPF19
color #353.1/J #FFFFAB
# BCAS2
color #353.1/K #FFDAB9
# Named selections for subcomplexes using original deposited chain IDs.
# EJC/mRNP
# selector_meta {"color":"#EAA439","family":"Protein/RNP groups","group":"EJC/mRNP groups","kind":"subcomplex"}
name pdb_7A5P_EJC_mRNP #353.1/T,v,w,y
# NTC/NTR related
# selector_meta {"color":"#F4BF67","family":"Protein/RNP groups","group":"NTC/NTR groups","kind":"subcomplex"}
name pdb_7A5P_NTC_NTR_related #353.1/C,M,N,O,P,U,o,s
# NTC/PRP19
# selector_meta {"color":"#F4BF67","family":"Protein/RNP groups","group":"NTC/NTR groups","kind":"subcomplex"}
name pdb_7A5P_NTC_PRP19 #353.1/G,H,I,J,K,L
# RNA/substrate
# selector_meta {"color":"#303030","family":"RNA","group":"pre-mRNA features","kind":"subcomplex"}
name pdb_7A5P_RNA_substrate #353.1/Y
# SR proteins
# selector_meta {"color":"#9CA3AF","family":"Protein/RNP groups","group":"other protein/RNP groups","kind":"subcomplex"}
name pdb_7A5P_SR_proteins #353.1/S
# Second step factors
# selector_meta {"color":"#9CA3AF","family":"Protein/RNP groups","group":"other protein/RNP groups","kind":"subcomplex"}
name pdb_7A5P_Second_step_factors #353.1/E
# U2 Sm ring
# selector_meta {"color":"#BFE6BF","family":"Protein/RNP groups","group":"U2/SF3B groups","kind":"subcomplex"}
name pdb_7A5P_U2_Sm_ring #353.1/h,i,j,k,l,m,n
# U2 snRNP
# selector_meta {"color":"#2F8B4D","family":"Protein/RNP groups","group":"U2/SF3B groups","kind":"subcomplex"}
name pdb_7A5P_U2_snRNP #353.1/2,W,X,u
# U5 Sm ring
# selector_meta {"color":"#BFC3E8","family":"Protein/RNP groups","group":"U5 snRNP groups","kind":"subcomplex"}
name pdb_7A5P_U5_Sm_ring #353.1/a,b,c,d,e,f,g
# U5 snRNP
# selector_meta {"color":"#0000CD","family":"Protein/RNP groups","group":"U5 snRNP groups","kind":"subcomplex"}
name pdb_7A5P_U5_snRNP #353.1/5,A,q
# U6 snRNP
# selector_meta {"color":"#DC143C","family":"Protein/RNP groups","group":"U6 snRNP groups","kind":"subcomplex"}
name pdb_7A5P_U6_snRNP #353.1/6
# other
# selector_meta {"color":"#9CA3AF","family":"Protein/RNP groups","group":"other protein/RNP groups","kind":"subcomplex"}
name pdb_7A5P_other #353.1/8,p,r,x,z
# Named selections for resolved substrate RNA features.
# substrate RNA: residues 80-94;127-140, component, medium confidence, validation not_applicable
# selector_meta {"color":"#303030","family":"RNA","feature":"substrate","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name C_7A5P_substrate #353.1/Y:80-94,127-140
# intron: residues 80-94;127-140, splice-site-inference, medium confidence, validation not_applicable
# selector_meta {"color":"#303030","family":"RNA","feature":"intron","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name C_7A5P_intron #353.1/Y:80-94,127-140
# Named selections for resolved snRNA functional regions.
# U2 snRNA Sm site: residues 99-105, sequence-motif, medium confidence
# selector_meta {"color":"#2F8B4D","family":"RNA","feature":"U2_Sm_site","group":"other snRNA regions","group_key":"other_snRNA_regions","kind":"rna_feature"}
name C_7A5P_U2_Sm_site #353.1/2:99-105
# U6 snRNA internal stem-loop: residues 80-95, motif-neighborhood, low confidence
# selector_meta {"color":"#D61A3D","family":"RNA","feature":"U6_ISL","group":"internal stem loops","group_key":"internal_stem_loops","kind":"rna_feature"}
name C_7A5P_U6_ISL #353.1/6:80-95
# U6 snRNA AGC catalytic triad: residues 92-94, sequence-motif, medium confidence
# selector_meta {"color":"#C91236","family":"RNA","feature":"U6_AGC_catalytic_triad","group":"catalytic core regions","group_key":"catalytic_core_regions","kind":"rna_feature"}
name C_7A5P_U6_AGC_catalytic_triad #353.1/6:92-94
# RNA feature nucleotide display.
select #353.1 & nucleic
nucleotides sel atoms
select clear
# intron: residues 80-94;127-140
# U6 ISL: residues 80-95
color #353.1/6:80-95 #D61A3D
select #353.1/6:80-95
nucleotides sel fill
select clear
# U6 AGC triad: residues 92-94
color #353.1/6:92-94 #C91236
select #353.1/6:92-94
nucleotides sel fill
select clear
# RNA feature 3D residue labels.
# Labels are created as independent grouped models under #353.2.
# Fetch and run the self-contained RNA label script from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/label_scripts/7a5p_rna_labels.py
# Searchable named selection browser.
# In GUI ChimeraX this opens a small panel for selecting and zooming named selections.
# Fetch and open the self-contained named selection browser from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/selection_browser_scripts/7a5p_selection_browser.py
view
show nucleic
