# Lightweight ChimeraX script for 5YZG
# Models are downloaded directly by ChimeraX from the PDB.
# Primary maps, when requested, are downloaded directly from EMDB.
# Original deposited chain identifiers are used.

# Shared anchor frame: 8H6L
# Structure group: #322; target model: #322.1.

open 8h6l id 322.9 name 8H6L_anchor
open 5yzg id 322.1 name 5YZG
rename #322 C_5yzg_structure

# Align on PRPF8.
matchmaker #322.1/A to #322.9/5B
close #322.9

hide atoms
cartoon
# Default display style.
style (protein|nucleic|solvent) & @@draw_mode=0 stick
cartoon style modeh def arrows t arrowshelix f arrowscale 3 wid 4 thick 3 sides 12 div 20
cartoon style ~(nucleic|strand) x round
cartoon style (nucleic|strand) x rect
cartoon style nucleic x round width 4 thick 4
lighting shadows false
lighting simple
camera ortho
lighting soft intensity 0.2 fillIntensity 0.5 ambientIntensity 1
lighting soft
# window
# windowsize 800 800

# bg and model colors
set bgColor white
style nucleic stick
graphics silhouettes true
cartoon style arrowScale 1.5
color byhetero
# Subunit colors from color_code/subunit_color_code.csv.
# PRPF8
color #322.1/A #BFC3E8
# CRNKL1
color #322.1/J #FFC388
# BCAS2
color #322.1/K #FFDAB9
# CDC5L
color #322.1/L #DAA520
# ISY1
color #322.1/y #FFEF8C
# SYF2
color #322.1/M #FF8C00
# BUD31
color #322.1/N #FFF584
# RBM22
color #322.1/O #DE9A52
# CWC15
color #322.1/P #FFDEAD
# SNW1
color #322.1/R #D49F96
# PPIL1
color #322.1/S #EEE8AA
# U5 snRNA
color #322.1/B #0000CD
# PLRG1
color #322.1/T #F4A460
# AQR
color #322.1/Q #FFDAB9
# SRRM2
color #322.1/U #BDD6F0
