color #322.1/Z #5F2E8A
# PRPF19
color #322.1/q #FFFFAB
# PRPF19
color #322.1/r #FFFFAB
# PRPF19
color #322.1/s #FFFFAB
# PRPF19
color #322.1/t #FFFFAB
# EIF4A3
color #322.1/u #F1D8BC
# MAGOH2
color #322.1/v #EAA439
# RBM8A
color #322.1/w #EB6841
# CASC3
color #322.1/x #CB8548
# U5-Sm SNRPD3
color #322.1/a #B0C4DE
# U2-Sm SNRPD3
color #322.1/h #D5F5E3
# U5-Sm SNRPB
color #322.1/b #B0C4DE
# U2-Sm SNRPB
color #322.1/i #D5F5E3
# U5-Sm SNRPD1
color #322.1/c #B0C4DE
# U2-Sm SNRPD1
color #322.1/j #D5F5E3
# U5-Sm SNRPD2
color #322.1/d #B0C4DE
# U2-Sm SNRPD2
color #322.1/k #D5F5E3
# U5-Sm SNRPF
color #322.1/f #B0C4DE
# U2-Sm SNRPF
color #322.1/m #D5F5E3
# U5-Sm SNRPE
color #322.1/e #B0C4DE
# U2-Sm SNRPE
color #322.1/l #D5F5E3
