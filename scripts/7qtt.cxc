# U5 snRNA
color #372.1/e #0000CD
# U2 snRNA
color #372.1/f #006400
# pre-mRNA
color #372.1/g #303030
# U5-Sm SNRPF
color #372.1/h #B0C4DE
# U5-Sm SNRPE
color #372.1/i #B0C4DE
# SF3B1
color #372.1/C #487957
# U5-Sm SNRPD3
color #372.1/j #B0C4DE
# U5-Sm SNRPD1
color #372.1/k #B0C4DE
