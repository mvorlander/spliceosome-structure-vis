color #423.1/m #B0C4DE
# U5-Sm SNRPD1
color #423.1/o #B0C4DE
# U5-Sm SNRPB
color #423.1/p #B0C4DE
# U5-Sm SNRPD3
color #423.1/u #B0C4DE
# CWC22
color #423.1/Z #2C54DD
# PAXBP1
color #423.1/Ck #FFC0CB
# TFIP11
color #423.1/Cb #FF69B4
# pre-mRNA
color #423.1/8 #303030
show nucleic
view
show nucleic
