# Lightweight ChimeraX script for 9L5S
# Models are downloaded directly by ChimeraX from the PDB.
# Original deposited chain identifiers are used.

# Shared anchor frame: 8H6L
# Structure group: #423; target model: #423.1.

open 8h6l id 423.9 name 8H6L_anchor
open 9l5s id 423.1 name 9L5S
rename #423 Bstar_9l5s_structure

# Align on PRPF8.
matchmaker #423.1/A to #423.9/5B
close #423.9

hide atoms
cartoon
# Default display style.
style (protein|nucleic|solvent) & @@draw_mode=0 stick
cartoon style modeh def arrows t arrowshelix f arrowscale 3 wid 4 thick 3 sides 12 div 20
cartoon style ~(nucleic|strand) x round
cartoon style (nucleic|strand) x rect
cartoon style nucleic x round width 4 thick 4
lighting shadows false
lighting simple
camera ortho
lighting soft intensity 0.2 fillIntensity 0.5 ambientIntensity 1
lighting soft
# window
# windowsize 800 800

# bg and model colors
set bgColor white
style nucleic stick
graphics silhouettes true
cartoon style arrowScale 1.5
color byhetero
# Subunit colors from color_code/subunit_color_code.csv.
# U2 snRNA
color #423.1/2 #006400
# U5 snRNA
color #423.1/5 #0000CD
# U6 snRNA
color #423.1/6 #DC143C
# PRPF8
color #423.1/A #BFC3E8
# SYF2
color #423.1/B #FF8C00
# EFTUD2
color #423.1/C #6495ED
# PRP8BP
color #423.1/E #E2F3F4
# CCDC12
color #423.1/F #FAEBD7
# SYF1
color #423.1/I #FF957B
# CRNKL1
color #423.1/J #FFC388
# CDC5L
color #423.1/L #DAA520
# BCAS2
color #423.1/K #FFDAB9
# PRPF19
color #423.1/q #FFFFAB
# PRPF19
color #423.1/r #FFFFAB
# PRPF19
color #423.1/s #FFFFAB
# PRPF19
color #423.1/t #FFFFAB
