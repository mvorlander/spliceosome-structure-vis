# Lightweight ChimeraX script for 5Z57
# Models are downloaded directly by ChimeraX from the PDB.
# Primary maps, when requested, are downloaded directly from EMDB.
# Original deposited chain identifiers are used.

# Shared anchor frame: 8H6L
# Structure group: #324; target model: #324.1.

open 8h6l id 324.9 name 8H6L_anchor
open 5z57 id 324.1 name 5Z57
rename #324 Bact_5z57_structure

# Align on PRPF8.
matchmaker #324.1/A to #324.9/5B
close #324.9

hide atoms
cartoon
# Default display style.
style (protein|nucleic|solvent) & @@draw_mode=0 stick
cartoon style modeh def arrows t arrowshelix f arrowscale 3 wid 4 thick 3 sides 12 div 20
cartoon style ~(nucleic|strand) x round
cartoon style (nucleic|strand) x rect
cartoon style nucleic x round width 4 thick 4
lighting shadows false
lighting simple
camera ortho
lighting soft intensity 0.2 fillIntensity 0.5 ambientIntensity 1
lighting soft
# window
# windowsize 800 800

# bg and model colors
set bgColor white
style nucleic stick
graphics silhouettes true
cartoon style arrowScale 1.5
color byhetero
# Subunit colors from color_code/subunit_color_code.csv.
# PRPF8
color #324.1/A #BFC3E8
# U5-Sm SNRPF
color #324.1/f #B0C4DE
# U2-Sm SNRPF
color #324.1/m #D5F5E3
# U5-Sm SNRPE
color #324.1/e #B0C4DE
# U2-Sm SNRPE
color #324.1/l #D5F5E3
# U5-Sm SNRPG
color #324.1/g #B0C4DE
# U2-Sm SNRPG
color #324.1/n #D5F5E3
# U6 snRNA
color #324.1/F #DC143C
# pre-mRNA
color #324.1/G #303030
# U2 snRNA
color #324.1/H #006400
# SNRPA1
color #324.1/o #58D68D
# SNRPB2
color #324.1/p #DAF7A6
