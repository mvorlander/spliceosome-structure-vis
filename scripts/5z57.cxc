color #324.1/J #FFC388
# CDC5L
color #324.1/L #DAA520
# EFTUD2
color #324.1/C #6495ED
# PRPF19
color #324.1/q #FFFFAB
# PRPF19
color #324.1/r #FFFFAB
# PRPF19
color #324.1/s #FFFFAB
# PRPF19
color #324.1/t #FFFFAB
# BCAS2
color #324.1/K #FFDAB9
# SYF1
color #324.1/I #FF957B
# AQR
color #324.1/Q #FFDAB9
# BUD31
color #324.1/N #FFF584
# RBM22
color #324.1/O #DE9A52
# CWC15
color #324.1/P #FFDEAD
