# Lightweight ChimeraX script for 8Y6O
# Models are downloaded directly by ChimeraX from the PDB.
# Primary maps, when requested, are downloaded directly from EMDB.
# Original deposited chain identifiers are used.

# Shared anchor frame: 8H6L
# Structure group: #416; target model: #416.1; RNA labels: #416.2.

open 8h6l id 416.9 name 8H6L_anchor
open 8y6o id 416.1 name 8Y6O
rename #416 pre_B_8y6o_structure

# Align on PRPF8.
matchmaker #416.1/C to #416.9/5B
close #416.9

hide atoms
cartoon
# Default display style.
style (protein|nucleic|solvent) & @@draw_mode=0 stick
cartoon style modeh def arrows t arrowshelix f arrowscale 3 wid 4 thick 3 sides 12 div 20
cartoon style ~(nucleic|strand) x round
cartoon style (nucleic|strand) x rect
cartoon style nucleic x round width 4 thick 4
lighting shadows false
lighting simple
camera ortho
lighting soft intensity 0.2 fillIntensity 0.5 ambientIntensity 1
lighting soft
# window
# windowsize 800 800

# bg and model colors
set bgColor white
style nucleic stick
graphics silhouettes true
cartoon style arrowScale 1.5
color byhetero
# Subunit colors from color_code/subunit_color_code.csv.
# pre-mRNA
color #416.1/A #303030
# U5-Sm SNRPB
color #416.1/a #B0C4DE
# SNRPB
color #416.1/h #B0C4DE
# SNRPB
color #416.1/o #B0C4DE
# U5-Sm SNRPD1
color #416.1/b #B0C4DE
# SNRPD1
color #416.1/i #B0C4DE
# SNRPD1
color #416.1/p #B0C4DE
# U5-Sm SNRPD2
color #416.1/c #B0C4DE
# SNRPD2
color #416.1/j #B0C4DE
# SNRPD2
color #416.1/q #B0C4DE
# U5-Sm SNRPD3
color #416.1/d #B0C4DE
# SNRPD3
color #416.1/k #B0C4DE
# SNRPD3
color #416.1/r #B0C4DE
# U5-Sm SNRPE
color #416.1/e #B0C4DE
# SNRPE
color #416.1/l #B0C4DE
# SNRPE
color #416.1/s #B0C4DE
# U5-Sm SNRPF
color #416.1/f #B0C4DE
# SNRPF
color #416.1/m #B0C4DE
# SNRPF
color #416.1/t #B0C4DE
# U5-Sm SNRPG
color #416.1/g #B0C4DE
# SNRPG
color #416.1/n #B0C4DE
# SNRPG
color #416.1/u #B0C4DE
# U4 snRNA
color #416.1/J #E6D900
# U6 snRNA
color #416.1/K #DC143C
# PRPF31
color #416.1/L #DFD570
# U5 snRNA
color #416.1/B #0000CD
# PRPF4
color #416.1/M #E2C496
# PRPF3
color #416.1/N #E1DD1B
# NHP2L1
color #416.1/O #A89264
# CCDC84
color #416.1/R #C7B8A8
# U1 snRNA
color #416.1/P #B66AAE
# ZMAT5
color #416.1/V #67A6C1
# HM1
color #416.1/W #BFA1D9
# C16ORF33
color #416.1/X #A458BB
# C6ORF151
color #416.1/Y #CA7DCA
# PDCD7
color #416.1/Z #A8ABC7
# PRPF8
color #416.1/C #BFC3E8
# SART1
color #416.1/S #D6937B
# USP39
color #416.1/U #B37E6A
# PRPF4
color #416.1/Q #E2C496
# EFTUD2
color #416.1/D #6495ED
# SNRNP200
color #416.1/E #AFEEEE
# PRP8BP
color #416.1/F #E2F3F4
# PRPF6
color #416.1/G #CFA785
# DIM2
color #416.1/H #6A90A0
# DDX23
color #416.1/I #CA9982
# Named selections for subcomplexes using original deposited chain IDs.
# RNA-binding
# selector_meta {"color":"#9CA3AF","family":"Protein/RNP groups","group":"other protein/RNP groups","kind":"subcomplex"}
name pdb_8Y6O_RNA_binding #416.1/V
# RNA/substrate
# selector_meta {"color":"#303030","family":"RNA","group":"pre-mRNA features","kind":"subcomplex"}
name pdb_8Y6O_RNA_substrate #416.1/A
# Sm ring
# selector_meta {"color":"#9CA3AF","family":"Protein/RNP groups","group":"other protein/RNP groups","kind":"subcomplex"}
name pdb_8Y6O_Sm_ring #416.1/h,i,j,k,l,m,n,o,p,q,r,s,t,u
# U11/U12 snRNP
# selector_meta {"color":"#B66AAE","family":"Protein/RNP groups","group":"U1 snRNP groups","kind":"subcomplex"}
name pdb_8Y6O_U11_U12_snRNP #416.1/P
# U4/U6 snRNP
# selector_meta {"color":"#C3BA7A","family":"Protein/RNP groups","group":"U4/U6 groups","kind":"subcomplex"}
name pdb_8Y6O_U4_U6_snRNP #416.1/I,L,M,N,O,Q,U
# U4atac/U6atac snRNP
# selector_meta {"color":"#D8C800","family":"Protein/RNP groups","group":"U4/U6 groups","kind":"subcomplex"}
name pdb_8Y6O_U4atac_U6atac_snRNP #416.1/J,K
# U5 Sm ring
# selector_meta {"color":"#BFC3E8","family":"Protein/RNP groups","group":"U5 snRNP groups","kind":"subcomplex"}
name pdb_8Y6O_U5_Sm_ring #416.1/a,b,c,d,e,f,g
# U5 snRNP
# selector_meta {"color":"#0000CD","family":"Protein/RNP groups","group":"U5 snRNP groups","kind":"subcomplex"}
name pdb_8Y6O_U5_snRNP #416.1/B,C,D,E,F,G,S
# other
# selector_meta {"color":"#9CA3AF","family":"Protein/RNP groups","group":"other protein/RNP groups","kind":"subcomplex"}
name pdb_8Y6O_other #416.1/H,R,W,X,Y,Z
# Named selections for resolved substrate RNA features.
# 5' exon: residues -1-0, five-ss-inference, medium confidence, validation not_applicable
# selector_meta {"color":"#FF8C00","family":"RNA","feature":"exon_5","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name pre_B_8Y6O_5exon #416.1/A:-1-0
# substrate RNA: residues -1-11, component, medium confidence, validation not_applicable
# selector_meta {"color":"#303030","family":"RNA","feature":"substrate","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name pre_B_8Y6O_substrate #416.1/A:-1-11
# 5' splice site: residues 1-10, minor-snrna-basepair, high confidence, validation validated
# selector_meta {"color":"#303030","family":"RNA","feature":"five_prime_splice_site","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name pre_B_8Y6O_5SS #416.1/A:1-10
# intron from 5' splice site: residues 1-11, five-ss-inference, low confidence, validation not_applicable
# selector_meta {"color":"#303030","family":"RNA","feature":"intron","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name pre_B_8Y6O_intron #416.1/A:1-11
# Named selections for resolved snRNA functional regions.
# U11 snRNA 5' splice-site recognition region: residues 1-7, reference-alignment, high confidence
# selector_meta {"color":"#B66AAE","family":"RNA","feature":"U11_5prime_5SS_recognition","group":"snRNA-pre-mRNA regions","group_key":"snRNA_pre_mRNA_regions","kind":"rna_feature"}
name pre_B_8Y6O_U11_5_5SS_recognition #416.1/P:1-7
# U11 snRNA stem-loop 1: residues 11-39;43-45, review-region, low confidence
# selector_meta {"color":"#BF72B7","family":"RNA","feature":"U11_SL1","group":"internal stem loops","group_key":"internal_stem_loops","kind":"rna_feature"}
name pre_B_8Y6O_U11_SL1 #416.1/P:11-39,43-45
# U11 snRNA stem-loop 2: residues 46-95, review-region, low confidence
# selector_meta {"color":"#AD62A6","family":"RNA","feature":"U11_SL2","group":"internal stem loops","group_key":"internal_stem_loops","kind":"rna_feature"}
name pre_B_8Y6O_U11_SL2 #416.1/P:46-95
# U4atac snRNA U4atac/U6atac stem I partner: residues 3-18, reference-alignment, medium confidence
# selector_meta {"color":"#D8C800","family":"RNA","feature":"U4atac_U6_stem_I_partner","group":"snRNA-snRNA interacting regions","group_key":"snRNA_snRNA_regions","kind":"rna_feature"}
name pre_B_8Y6O_U4atac_U6_stem_I_partner #416.1/J:3-18
# U4atac snRNA U4atac/U6atac stem II partner: residues 60-64, reference-alignment, medium confidence
# selector_meta {"color":"#E0CF1A","family":"RNA","feature":"U4atac_U6_stem_II_partner","group":"snRNA-snRNA interacting regions","group_key":"snRNA_snRNA_regions","kind":"rna_feature"}
name pre_B_8Y6O_U4atac_U6_stem_II_partner #416.1/J:60-64
# U4atac snRNA Brr2 loading region: residues 83-96, review-region, low confidence
# selector_meta {"color":"#F0DF2E","family":"RNA","feature":"U4atac_Brr2_loading_region","group":"other snRNA regions","group_key":"other_snRNA_regions","kind":"rna_feature"}
name pre_B_8Y6O_U4atac_Brr2_loading_region #416.1/J:83-96
# U4atac snRNA Sm site: residues 116-122, sequence-motif, medium confidence
# selector_meta {"color":"#F5E85A","family":"RNA","feature":"U4atac_Sm_site","group":"other snRNA regions","group_key":"other_snRNA_regions","kind":"rna_feature"}
name pre_B_8Y6O_U4atac_Sm_site #416.1/J:116-122
# U5 snRNA loop I: residues 38-42, sequence-motif, medium confidence
# selector_meta {"color":"#1B3CD0","family":"RNA","feature":"U5_loop_I","group":"snRNA-pre-mRNA regions","group_key":"snRNA_pre_mRNA_regions","kind":"rna_feature"}
name pre_B_8Y6O_U5_loop_I #416.1/B:38-42
# U6atac snRNA U6atac/U12 helix I partner: residues 23-29, reference-alignment, high confidence
# selector_meta {"color":"#D0183C","family":"RNA","feature":"U6atac_U12_helix_I_partner","group":"snRNA-snRNA interacting regions","group_key":"snRNA_snRNA_regions","kind":"rna_feature"}
name pre_B_8Y6O_U6atac_U12_helix_I_partner #416.1/K:23-29
# U6atac snRNA AGC catalytic triad: residues 26-28, reference-alignment, high confidence
# selector_meta {"color":"#C91236","family":"RNA","feature":"U6atac_AGC_catalytic_triad","group":"catalytic core regions","group_key":"catalytic_core_regions","kind":"rna_feature"}
name pre_B_8Y6O_U6atac_AGC_catalytic_triad #416.1/K:26-28
# U6atac snRNA internal stem-loop: residues 52-58;60-65, reference-alignment, medium confidence
# selector_meta {"color":"#D61A3D","family":"RNA","feature":"U6atac_ISL","group":"internal stem loops","group_key":"internal_stem_loops","kind":"rna_feature"}
name pre_B_8Y6O_U6atac_ISL #416.1/K:52-58,60-65
# RNA feature nucleotide display.
select #416.1 & nucleic
nucleotides sel atoms
select clear
# 5' exon: residues -1-0
color #416.1/A:-1-0 #FF8C00
select #416.1/A:-1-0
nucleotides sel fill
select clear
# 5'SS: residues 1-10
# intron: residues 1-11
# U11 5'SS recog.: residues 1-7
color #416.1/P:1-7 #B66AAE
select #416.1/P:1-7
nucleotides sel fill
select clear
# U11 SL1: residues 11-39;43-45
color #416.1/P:11-39,43-45 #BF72B7
select #416.1/P:11-39,43-45
nucleotides sel fill
select clear
# U11 SL2: residues 46-95
color #416.1/P:46-95 #AD62A6
select #416.1/P:46-95
nucleotides sel fill
select clear
# U4atac/U6atac stem I: residues 3-18
color #416.1/J:3-18 #D8C800
select #416.1/J:3-18
nucleotides sel fill
select clear
# U4atac/U6atac stem II: residues 60-64
color #416.1/J:60-64 #E0CF1A
select #416.1/J:60-64
nucleotides sel fill
select clear
# U4atac Brr2 region: residues 83-96
color #416.1/J:83-96 #F0DF2E
select #416.1/J:83-96
nucleotides sel fill
select clear
# U5 loop I: residues 38-42
color #416.1/B:38-42 #1B3CD0
select #416.1/B:38-42
nucleotides sel fill
select clear
# U6atac/U12 helix I: residues 23-29
color #416.1/K:23-29 #D0183C
select #416.1/K:23-29
nucleotides sel fill
select clear
# U6atac AGC triad: residues 26-28
color #416.1/K:26-28 #C91236
select #416.1/K:26-28
nucleotides sel fill
select clear
# U6atac ISL: residues 52-58;60-65
color #416.1/K:52-58,60-65 #D61A3D
select #416.1/K:52-58,60-65
nucleotides sel fill
select clear
# RNA feature 3D residue labels.
# Labels are created as independent grouped models under #416.2.
# Fetch and run the self-contained RNA label script from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/label_scripts/8y6o_rna_labels.py
# Searchable named selection browser.
# In GUI ChimeraX this opens a small panel for selecting and zooming named selections.
# Fetch and open the self-contained named selection browser from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/selection_browser_scripts/8y6o_selection_browser.py
view
show nucleic
