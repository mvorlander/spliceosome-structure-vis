# SNRPA1
color #387.1/o #58D68D
# U5-Sm SNRPD2
color #387.1/c #B0C4DE
# U2-Sm SNRPD2
color #387.1/h #D5F5E3
# U5-Sm SNRPF
color #387.1/d #B0C4DE
# U2-Sm SNRPF
color #387.1/i #D5F5E3
# U5-Sm SNRPB
color #387.1/a #B0C4DE
# U2-Sm SNRPB
color #387.1/m #D5F5E3
# SNRNP200
color #387.1/D #AFEEEE
# U5-Sm SNRPD3
color #387.1/g #B0C4DE
# U2-Sm SNRPD3
color #387.1/l #D5F5E3
