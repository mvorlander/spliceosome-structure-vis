# U4-Sm SNRPF
color #409.1/4f #F7F0A6
# U5-Sm SNRPF
color #409.1/5f #B0C4DE
# TXNL4A
color #409.1/D #C3BA7A
# U2-Sm SNRPB
color #409.1/2b #D5F5E3
# U4-Sm SNRPB
color #409.1/4b #F7F0A6
# U5-Sm SNRPB
color #409.1/5b #B0C4DE
# U2-Sm SNRPD3
color #409.1/23 #D5F5E3
# U4-Sm SNRPD3
color #409.1/43 #F7F0A6
# U5-Sm SNRPD3
color #409.1/53 #B0C4DE
# U2-Sm SNRPG
color #409.1/2g #D5F5E3
# U4-Sm SNRPG
color #409.1/4g #F7F0A6
# U5-Sm SNRPG
color #409.1/5g #B0C4DE
# U2-Sm SNRPE
color #409.1/2e #D5F5E3
# U4-Sm SNRPE
color #409.1/4e #F7F0A6
# U5-Sm SNRPE
color #409.1/5e #B0C4DE
# U2-Sm SNRPD1
color #409.1/21 #D5F5E3
# U4-Sm SNRPD1
color #409.1/41 #F7F0A6
# U5-Sm SNRPD1
color #409.1/51 #B0C4DE
