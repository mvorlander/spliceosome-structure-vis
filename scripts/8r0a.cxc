# Lightweight ChimeraX script for 8R0A
# Models are downloaded directly by ChimeraX from the PDB.
# Primary maps, when requested, are downloaded directly from EMDB.
# Original deposited chain identifiers are used.

# Shared anchor frame: 8H6L
# Structure group: #409; target model: #409.1; RNA labels: #409.2.

open 8h6l id 409.9 name 8H6L_anchor
open 8r0a id 409.1 name 8R0A
rename #409 pre_B_8r0a_structure

# Align on PRPF8.
matchmaker #409.1/A to #409.9/5B
close #409.9

hide atoms
cartoon
# Default display style.
style (protein|nucleic|solvent) & @@draw_mode=0 stick
cartoon style modeh def arrows t arrowshelix f arrowscale 3 wid 4 thick 3 sides 12 div 20
cartoon style ~(nucleic|strand) x round
cartoon style (nucleic|strand) x rect
cartoon style nucleic x round width 4 thick 4
lighting shadows false
lighting simple
camera ortho
lighting soft intensity 0.2 fillIntensity 0.5 ambientIntensity 1
lighting soft
# window
# windowsize 800 800

# bg and model colors
set bgColor white
style nucleic stick
graphics silhouettes true
cartoon style arrowScale 1.5
color byhetero
# Subunit colors from color_code/subunit_color_code.csv.
# U5 snRNA
color #409.1/5 #0000CD
# pre-mRNA
color #409.1/Z #303030
# pre-mRNA
color #409.1/z #303030
# PRPF8
color #409.1/A #BFC3E8
# SNRNP200
color #409.1/B #AFEEEE
# U2 snRNA
color #409.1/2 #006400
# U4 snRNA
color #409.1/4 #E6D900
# U6 snRNA
color #409.1/6 #DC143C
# SF3A1
color #409.1/7 #55947F
# SF3A2
color #409.1/8 #75A074
# SF3B4
color #409.1/B4 #77B088
# EFTUD2
color #409.1/C #6495ED
# SF3A3
color #409.1/9 #9BCF91
# SF3B2
color #409.1/B2 #49926C
# SF3B5
color #409.1/B5 #92BB8F
