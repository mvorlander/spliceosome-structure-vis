color #409.1/E #E2F3F4
# LSM8
color #409.1/68 #F4A3A8
# LSM4
color #409.1/64 #F4A3A8
# LSM5
color #409.1/65 #F4A3A8
# PRPF3
color #409.1/J #E1DD1B
# PRPF4
color #409.1/K #E2C496
