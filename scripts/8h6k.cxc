# Named selections for resolved substrate RNA features.
# 5' exon: residues 7-48;98-107, five-ss-inference, medium confidence, validation not_applicable
name B_8H6K_5exon #381.1/A:7-48,98-107
# substrate RNA: residues 7-48;98-119, component, medium confidence, validation not_applicable
name B_8H6K_substrate #381.1/A:7-48,98-119
# 5' splice site: residues 108-113, sequence-motif, medium confidence, validation uncertain uncertain validation
name B_8H6K_5SS #381.1/A:108-113
# intron from 5' splice site: residues 108-119, five-ss-inference, low confidence, validation not_applicable
name B_8H6K_intron #381.1/A:108-119
# Named selections for resolved snRNA functional regions.
# U2 snRNA U2/U6 helix I partner: residues 30-55, review-region, low confidence
name B_8H6K_U2_U6_helix_I_partner #381.1/2A:30-55
# U2 snRNA branchpoint pairing region: residues 32-41, sequence-motif-neighborhood, medium confidence
name B_8H6K_U2_branchpoint_pairing_region #381.1/2A:32-41
# U2 snRNA stem IIa: residues 46-65, review-region, low confidence
name B_8H6K_U2_stem_IIa #381.1/2A:46-65
# U2 snRNA Sm site: residues 99-105, sequence-motif, medium confidence
name B_8H6K_U2_Sm_site #381.1/2A:99-105
# U4 snRNA U4/U6 stem I partner: residues 1-18, reference-alignment, high confidence
name B_8H6K_U4_U6_stem_I_partner #381.1/4A:1-18
# U4 snRNA U4/U6 stem II partner: residues 56-63, reference-alignment, high confidence
name B_8H6K_U4_U6_stem_II_partner #381.1/4A:56-63
# U4 snRNA Brr2 loading region: residues 59-63;70-76;83-94, review-region, low confidence
name B_8H6K_U4_Brr2_loading_region #381.1/4A:59-63,70-76,83-94
# U4 snRNA Sm site: residues 118-124, sequence-motif, medium confidence
name B_8H6K_U4_Sm_site #381.1/4A:118-124
# U5 snRNA loop I: residues 38-42, sequence-motif, medium confidence
name B_8H6K_U5_loop_I #381.1/5A:38-42
# U6 snRNA U2/U6 helix I partner: residues 35-60, motif-neighborhood, medium confidence
name B_8H6K_U6_U2_helix_I_partner #381.1/6A:35-60
# U6 snRNA 5' splice-site upstream contact: residues 38-49, motif-neighborhood, medium confidence
name B_8H6K_U6_5SS_upstream_contact #381.1/6A:38-49
# U6 snRNA ACAGAGA box: residues 41-47, sequence-motif, high confidence
name B_8H6K_U6_ACAGAGA_box #381.1/6A:41-47
# U6 snRNA U4/U6 stem II partner: residues 52-61, reference-alignment, high confidence
name B_8H6K_U6_U4_stem_II_partner #381.1/6A:52-61
# U6 snRNA U4/U6 stem I partner: residues 63-74, reference-alignment, high confidence
name B_8H6K_U6_U4_stem_I_partner #381.1/6A:63-74
# U6 snRNA internal stem-loop: residues 85-96;102-105, motif-neighborhood, low confidence
name B_8H6K_U6_ISL #381.1/6A:85-96,102-105
# U6 snRNA AGC catalytic triad: residues 92-94, sequence-motif, medium confidence
name B_8H6K_U6_AGC_catalytic_triad #381.1/6A:92-94
# U6 snRNA LSm site: residues 102-105, terminal-region, low confidence
name B_8H6K_U6_LSm_site #381.1/6A:102-105
# RNA feature nucleotide display.
select #381.1 & nucleic
nucleotides sel atoms
select clear
# 5' exon: residues 7-48;98-107
color #381.1/A:7-48,98-107 #FF8C00
select #381.1/A:7-48,98-107
nucleotides sel fill
select clear
