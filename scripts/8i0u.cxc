color #388.1/Z #FFDAB9
# PPIE
color #388.1/y #FFFFE0
# U5-Sm SNRPB
color #388.1/a #B0C4DE
# U2-Sm SNRPB
color #388.1/m #D5F5E3
# U5-Sm SNRPD1
color #388.1/b #B0C4DE
# U2-Sm SNRPD1
color #388.1/n #D5F5E3
# U5-Sm SNRPD2
color #388.1/c #B0C4DE
# U2-Sm SNRPD2
color #388.1/h #D5F5E3
# EFTUD2
color #388.1/C #6495ED
# U5-Sm SNRPF
color #388.1/d #B0C4DE
# U2-Sm SNRPF
color #388.1/i #D5F5E3
# U5-Sm SNRPE
color #388.1/e #B0C4DE
# U2-Sm SNRPE
color #388.1/j #D5F5E3
# U5-Sm SNRPG
color #388.1/f #B0C4DE
# U2-Sm SNRPG
color #388.1/k #D5F5E3
# U5-Sm SNRPD3
color #388.1/g #B0C4DE
# U2-Sm SNRPD3
color #388.1/l #D5F5E3
# PRPF19
color #388.1/q #FFFFAB
# PRPF19
color #388.1/r #FFFFAB
# PRPF19
color #388.1/s #FFFFAB
# PRPF19
color #388.1/t #FFFFAB
# SF3B1
color #388.1/1 #487957
# SF3B3
color #388.1/3 #6A9064
# SNRPB2
color #388.1/p #DAF7A6
# SF3A3
color #388.1/w #9BCF91
# SF3B2
color #388.1/2 #49926C
# PRP8BP
color #388.1/E #E2F3F4
# SF3B4
color #388.1/4 #77B088
# PHF5A
color #388.1/7 #375A40
# SF3B5
color #388.1/5 #92BB8F
# SNRPA1
color #388.1/o #58D68D
