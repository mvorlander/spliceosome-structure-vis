# Lightweight ChimeraX script for 8I0U
# Models are downloaded directly by ChimeraX from the PDB.
# Primary maps, when requested, are downloaded directly from EMDB.
# Original deposited chain identifiers are used.

# Shared anchor frame: 8H6L
# Structure group: #388; target model: #388.1.

open 8h6l id 388.9 name 8H6L_anchor
open 8i0u id 388.1 name 8I0U
rename #388 Bact_8i0u_structure

# Align on PRPF8.
matchmaker #388.1/A to #388.9/5B
close #388.9

hide atoms
cartoon
# Default display style.
style (protein|nucleic|solvent) & @@draw_mode=0 stick
cartoon style modeh def arrows t arrowshelix f arrowscale 3 wid 4 thick 3 sides 12 div 20
cartoon style ~(nucleic|strand) x round
cartoon style (nucleic|strand) x rect
cartoon style nucleic x round width 4 thick 4
lighting shadows false
lighting simple
camera ortho
lighting soft intensity 0.2 fillIntensity 0.5 ambientIntensity 1
lighting soft
# window
# windowsize 800 800

# bg and model colors
set bgColor white
style nucleic stick
graphics silhouettes true
cartoon style arrowScale 1.5
color byhetero
# Subunit colors from color_code/subunit_color_code.csv.
# PRPF8
color #388.1/A #BFC3E8
# RNF113
color #388.1/K #6C46CE
# CDC5L
color #388.1/L #DAA520
# SYF2
color #388.1/M #FF8C00
# BUD31
color #388.1/N #FFF584
# RBM22
color #388.1/O #DE9A52
# CWC15
color #388.1/P #FFDEAD
# AQR
color #388.1/Q #FFDAB9
# SNW1
color #388.1/R #D49F96
# PPIL1
color #388.1/S #EEE8AA
# PLRG1
color #388.1/T #F4A460
# U5 snRNA
color #388.1/B #0000CD
# SRRM2
color #388.1/U #BDD6F0
# CWC22
color #388.1/V #2C54DD
