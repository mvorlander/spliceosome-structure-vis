nucleotides sel fill
select clear
# RNA feature 3D residue labels.
label #410.1/Z:36 residues text "intron 1-8; 29-43" color #303030 height 5 bgColor transparent
label #410.1/Z:40 residues text "BP region 36-43" color #303030 height 5 bgColor transparent
