# Named selections for resolved substrate RNA features.
# substrate RNA: residues -5,-4,-3,-2,-1,1,2,3,4,5,6,7,8; 29-43, component, medium confidence, validation not_applicable
name pre_B_8R0B_substrate #410.1/Z:29-43|#410.1/z:-5,-4,-3,-2,-1,1,2,3,4,5,6,7,8
# intron: residues 1-8; 29-43, five-ss-inference/splice-site-inference, low/medium confidence, validation not_applicable
name pre_B_8R0B_intron #410.1/Z:29-43|#410.1/z:1-8
# branch point region: residues 36-43, network-scored-motif, high confidence, validation validated
name pre_B_8R0B_branch_region #410.1/Z:36-43
# branch point adenosine: residues 41, network-scored-motif, high confidence, validation validated
name pre_B_8R0B_branch_A #410.1/Z:41
# 5' exon: residues -5--1, five-ss-inference, medium confidence, validation not_applicable
name pre_B_8R0B_5exon #410.1/z:-5--1
# 5' splice site: residues 1-6, sequence-motif, medium confidence, validation uncertain uncertain validation
name pre_B_8R0B_5SS #410.1/z:1-6
# Named selections for resolved snRNA functional regions.
# U2 snRNA U2/U6 helix I partner: residues 29-30, review-region, high confidence
name pre_B_8R0B_U2_U6_helix_I_partner #410.1/2:29-30
# U2 snRNA branchpoint pairing region: residues 32-41, sequence-motif-neighborhood, medium confidence
name pre_B_8R0B_U2_branchpoint_pairing_region #410.1/2:32-41
# U2 snRNA stem IIa: residues 46-65, review-region, low confidence
name pre_B_8R0B_U2_stem_IIa #410.1/2:46-65
# U2 snRNA Sm site: residues 99-105, sequence-motif, medium confidence
name pre_B_8R0B_U2_Sm_site #410.1/2:99-105
# U4 snRNA U4/U6 stem I partner: residues 1-18, reference-alignment, high confidence
name pre_B_8R0B_U4_U6_stem_I_partner #410.1/4:1-18
# U4 snRNA U4/U6 stem II partner: residues 56-64, reference-alignment, high confidence
name pre_B_8R0B_U4_U6_stem_II_partner #410.1/4:56-64
# U4 snRNA Brr2 loading region: residues 60-80;85-95, review-region, low confidence
name pre_B_8R0B_U4_Brr2_loading_region #410.1/4:60-80,85-95
# U4 snRNA Sm site: residues 119-125, sequence-motif, medium confidence
name pre_B_8R0B_U4_Sm_site #410.1/4:119-125
# U5 snRNA loop I: residues 38-42, sequence-motif, medium confidence
name pre_B_8R0B_U5_loop_I #410.1/5:38-42
# U6 snRNA U2/U6 helix I partner: residues 35-60, motif-neighborhood, medium confidence
name pre_B_8R0B_U6_U2_helix_I_partner #410.1/6:35-60
# U6 snRNA 5' splice-site upstream contact: residues 38-49, motif-neighborhood, medium confidence
name pre_B_8R0B_U6_5SS_upstream_contact #410.1/6:38-49
# U6 snRNA ACAGAGA box: residues 41-47, sequence-motif, high confidence
name pre_B_8R0B_U6_ACAGAGA_box #410.1/6:41-47
# U6 snRNA U4/U6 stem II partner: residues 52-61, reference-alignment, high confidence
name pre_B_8R0B_U6_U4_stem_II_partner #410.1/6:52-61
# U6 snRNA U4/U6 stem I partner: residues 63-74, reference-alignment, high confidence
name pre_B_8R0B_U6_U4_stem_I_partner #410.1/6:63-74
# U6 snRNA internal stem-loop: residues 85-96;102-106, motif-neighborhood, low confidence
name pre_B_8R0B_U6_ISL #410.1/6:85-96,102-106
# U6 snRNA AGC catalytic triad: residues 92-94, sequence-motif, medium confidence
name pre_B_8R0B_U6_AGC_catalytic_triad #410.1/6:92-94
# U6 snRNA LSm site: residues 102-106, terminal-region, low confidence
name pre_B_8R0B_U6_LSm_site #410.1/6:102-106
# RNA feature nucleotide display.
select #410.1 & nucleic
nucleotides sel atoms
select clear
# intron: residues 1-8; 29-43
# BP region: residues 36-43
# BP-A: residues 41
# 5' exon: residues -5--1
color #410.1/z:-5--1 #FF8C00
select #410.1/z:-5--1
nucleotides sel fill
select clear
# 5'SS: residues 1-6
# U2/U6 helix I: residues 29-30
color #410.1/2:29-30 #047857
select #410.1/2:29-30
nucleotides sel fill
select clear
# U2 BP pairing: residues 32-41
color #410.1/2:32-41 #0B6E2D
select #410.1/2:32-41
nucleotides sel fill
select clear
# U2 stem IIa: residues 46-65
color #410.1/2:46-65 #167A38
select #410.1/2:46-65
nucleotides sel fill
select clear
# U4/U6 stem I: residues 1-18
