label #410.1/2:30 residues text "U2/U6 helix I 29-30" color #047857 height 5 bgColor transparent
label #410.1/2:36 residues text "U2 BP pairing 32-41" color #0B6E2D height 5 bgColor transparent
label #410.1/2:56 residues text "U2 stem IIa 46-65" color #167A38 height 5 bgColor transparent
label #410.1/4:10 residues text "U4/U6 stem I 1-18" color #D8C800 height 5 bgColor transparent
label #410.1/4:60 residues text "U4/U6 stem II 56-64" color #E0CF1A height 5 bgColor transparent
