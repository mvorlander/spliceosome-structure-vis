label #356.1/2:38 residues text "U2/U6 helix I 32-45;48-55" color #047857 height 5 bgColor transparent
label #356.1/2:36 residues text "U2 BP pairing 32-41" color #0B6E2D height 5 bgColor transparent
label #356.1/2:56 residues text "U2 stem IIa 48-64;68-73;79-80" color #167A38 height 5 bgColor transparent
label #356.1/5:40 residues text "U5 loop I 38-42" color #1B3CD0 height 5 bgColor transparent
label #356.1/6:16 residues text "U6 5' terminal SL 1-30" color #DC143C height 5 bgColor transparent
label #356.1/6:40 residues text "U2/U6 helix I 35-46;58-60" color #D0183C height 5 bgColor transparent
label #356.1/6:42 residues text "U6 5'SS contact 38-46" color #E01842 height 5 bgColor transparent
