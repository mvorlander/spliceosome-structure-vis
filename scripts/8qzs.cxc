nucleotides sel fill
select clear
# U6 5'SS contact: residues 38-49
color #406.1/6:38-49 #E01842
select #406.1/6:38-49
nucleotides sel fill
select clear
# U6 ACAGAGA: residues 41-47
color #406.1/6:41-47 #DC143C
select #406.1/6:41-47
nucleotides sel fill
select clear
# U4/U6 stem II: residues 52-61
color #406.1/6:52-61 #E01842
select #406.1/6:52-61
nucleotides sel fill
select clear
# U4/U6 stem I: residues 63-74
color #406.1/6:63-74 #D9183E
select #406.1/6:63-74
