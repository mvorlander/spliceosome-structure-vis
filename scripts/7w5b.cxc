# U2-Sm SNRPB
color #376.1/i #D5F5E3
# EFTUD2
color #376.1/C #6495ED
# PPIE
color #376.1/y #FFFFE0
# U5-Sm SNRPD3
color #376.1/a #B0C4DE
# U2-Sm SNRPD3
color #376.1/h #D5F5E3
# U5-Sm SNRPD1
color #376.1/c #B0C4DE
# U2-Sm SNRPD1
color #376.1/j #D5F5E3
# U5-Sm SNRPD2
color #376.1/d #B0C4DE
# U2-Sm SNRPD2
color #376.1/k #D5F5E3
# U5-Sm SNRPF
color #376.1/f #B0C4DE
# U2-Sm SNRPF
color #376.1/m #D5F5E3
# U5-Sm SNRPE
color #376.1/e #B0C4DE
# U2-Sm SNRPE
color #376.1/l #D5F5E3
# U5-Sm SNRPG
color #376.1/g #B0C4DE
# U2-Sm SNRPG
color #376.1/n #D5F5E3
# PRPF19
color #376.1/q #FFFFAB
# PRPF19
color #376.1/r #FFFFAB
# PRPF19
color #376.1/s #FFFFAB
# PRPF19
color #376.1/t #FFFFAB
# SNRPA1
color #376.1/o #58D68D
# SNRPB2
color #376.1/p #DAF7A6
# SNRNP200
color #376.1/D #AFEEEE
# SLU7
color #376.1/1 #5A338B
# MAGOH
color #376.1/v #EAA439
# RBM8A
color #376.1/w #EB6841
# EIF4A3
color #376.1/u #F1D8BC
