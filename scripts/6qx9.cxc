# U2 snRNA branchpoint pairing region: chain 2, residues 33-38, sequence-motif, medium confidence
name r_6QX9_U2_branchpoint_pairing_region_2 #348.1/2:33-38
# U2 snRNA stem IIa: chain 2, residues 46-65, review-region, low confidence
name r_6QX9_U2_stem_IIa_2 #348.1/2:46-65
# U2 snRNA Sm site: chain 2, residues 99-105, sequence-motif, medium confidence
name r_6QX9_U2_Sm_site_2 #348.1/2:99-105
# U4 snRNA U4/U6 stem I partner: chain 4, residues 0-24, review-region, low confidence
name r_6QX9_U4_U6_stem_I_partner_4 #348.1/4:0-24
# U4 snRNA U4/U6 stem II partner: chain 4, residues 44-52;55-70;73-74, review-region, low confidence
