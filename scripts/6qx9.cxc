# Named selections for resolved substrate RNA features.
# 5' exon: chain I, residues -1-0, five-ss-inference, medium confidence
name s_6QX9_sub_exon_5_M #348.1/I:-1-0
# substrate RNA: chain I, residues -1-8;88-102, component, medium confidence
name s_6QX9_sub_substrate_M #348.1/I:-1-8,88-102
# 5' splice site: chain I, residues 1-6, sequence-motif, medium confidence
name s_6QX9_sub_five_prime_splice_site_M #348.1/I:1-6
# intron from 5' splice site: chain I, residues 1-8;88-102, five-ss-inference, low confidence
name s_6QX9_sub_intron_M #348.1/I:1-8,88-102
# Named selections for resolved snRNA functional regions.
# U1 snRNA 5' splice-site recognition region: chain 1, residues 1-10, review-region, medium confidence
name r_6QX9_U1_5prime_5SS_recognition_1 #348.1/1:1-10
# U1 snRNA stem-loop 1: chain 1, residues 11-45, review-region, low confidence
name r_6QX9_U1_SL1_1 #348.1/1:11-45
# U1 snRNA stem-loop 2: chain 1, residues 46-95, review-region, low confidence
name r_6QX9_U1_SL2_1 #348.1/1:46-95
