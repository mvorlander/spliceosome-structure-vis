select #348.1/2:32-41
nucleotides sel fill
select clear
# U2 stem IIa: residues 46-65
color #348.1/2:46-65 #167A38
select #348.1/2:46-65
nucleotides sel fill
select clear
# U4/U6 stem I: residues 1-18
color #348.1/4:1-18 #D8C800
select #348.1/4:1-18
nucleotides sel fill
select clear
# U4/U6 stem II: residues 56-64
color #348.1/4:56-64 #E0CF1A
select #348.1/4:56-64
nucleotides sel fill
select clear
# U4 Brr2 region: residues 59-70;73-80;85-94
