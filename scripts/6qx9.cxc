select #348.1/5:38
nucleotides sel fill
select clear
# U2/U6 helix I: residues 35-36;47-60
color #348.1/6:35-36,47-60 #D0183C
select #348.1/6:35-36,47-60
nucleotides sel fill
select clear
# U6 5'SS contact: residues 47-49
color #348.1/6:47-49 #E01842
select #348.1/6:47-49
nucleotides sel fill
select clear
# U6 ACAGAGA: residues 47
color #348.1/6:47 #DC143C
select #348.1/6:47
nucleotides sel fill
select clear
# U4/U6 stem II: residues 52-61
color #348.1/6:52-61 #E01842
select #348.1/6:52-61
nucleotides sel fill
select clear
# U4/U6 stem I: residues 63-74
color #348.1/6:63-74 #D9183E
select #348.1/6:63-74
nucleotides sel fill
select clear
# U6 ISL: residues 85-95;102-106
color #348.1/6:85-95,102-106 #D61A3D
select #348.1/6:85-95,102-106
nucleotides sel fill
select clear
# U6 AGC triad: residues 92-94
color #348.1/6:92-94 #C91236
