# Named selections for resolved substrate RNA features.
# 5' exon: residues -1-0, five-ss-inference, medium confidence, validation not_applicable
name pre_B_6QX9_5exon #348.1/I:-1-0
# substrate RNA: residues -1-8;88-102, component, medium confidence, validation not_applicable
name pre_B_6QX9_substrate #348.1/I:-1-8,88-102
# 5' splice site: residues 1-6, sequence-motif, medium confidence, validation uncertain uncertain validation
name pre_B_6QX9_5SS #348.1/I:1-6
# intron from 5' splice site: residues 1-8;88-102, five-ss-inference, medium confidence, validation not_applicable
name pre_B_6QX9_intron #348.1/I:1-8,88-102
# branch point region: residues 95-102, network-scored-motif, high confidence, validation validated
name pre_B_6QX9_branch_region #348.1/I:95-102
# branch point adenosine: residues 100, network-scored-motif, high confidence, validation validated
name pre_B_6QX9_branch_A #348.1/I:100
# Named selections for resolved snRNA functional regions.
# U1 snRNA 5' splice-site recognition region: residues 1-10, review-region, medium confidence
name pre_B_6QX9_U1_5_5SS_recognition #348.1/1:1-10
# U1 snRNA stem-loop 1: residues 11-45, review-region, low confidence
name pre_B_6QX9_U1_SL1 #348.1/1:11-45
# U1 snRNA stem-loop 2: residues 46-95, review-region, low confidence
name pre_B_6QX9_U1_SL2 #348.1/1:46-95
# U2 snRNA branchpoint pairing region: residues 32-41, sequence-motif-neighborhood, medium confidence
name pre_B_6QX9_U2_branchpoint_pairing_region #348.1/2:32-41
# U2 snRNA stem IIa: residues 46-65, review-region, low confidence
name pre_B_6QX9_U2_stem_IIa #348.1/2:46-65
# U2 snRNA Sm site: residues 99-105, sequence-motif, medium confidence
name pre_B_6QX9_U2_Sm_site #348.1/2:99-105
# U4 snRNA U4/U6 stem I partner: residues 1-18, reference-alignment, high confidence
name pre_B_6QX9_U4_U6_stem_I_partner #348.1/4:1-18
# U4 snRNA U4/U6 stem II partner: residues 56-64, reference-alignment, high confidence
name pre_B_6QX9_U4_U6_stem_II_partner #348.1/4:56-64
# U4 snRNA Brr2 loading region: residues 59-70;73-80;85-94, review-region, low confidence
name pre_B_6QX9_U4_Brr2_loading_region #348.1/4:59-70,73-80,85-94
# U4 snRNA Sm site: residues 118-124, sequence-motif, medium confidence
name pre_B_6QX9_U4_Sm_site #348.1/4:118-124
# U5 snRNA loop I: residues 38, sequence-motif, medium confidence
name pre_B_6QX9_U5_loop_I #348.1/5:38
# U6 snRNA U2/U6 helix I partner: residues 35-36;47-60, motif-neighborhood, medium confidence
name pre_B_6QX9_U6_U2_helix_I_partner #348.1/6:35-36,47-60
# U6 snRNA 5' splice-site upstream contact: residues 47-49, motif-neighborhood, medium confidence
name pre_B_6QX9_U6_5SS_upstream_contact #348.1/6:47-49
# U6 snRNA ACAGAGA box: residues 47, sequence-motif, high confidence
name pre_B_6QX9_U6_ACAGAGA_box #348.1/6:47
# U6 snRNA U4/U6 stem II partner: residues 52-61, reference-alignment, high confidence
name pre_B_6QX9_U6_U4_stem_II_partner #348.1/6:52-61
# U6 snRNA U4/U6 stem I partner: residues 63-74, reference-alignment, high confidence
name pre_B_6QX9_U6_U4_stem_I_partner #348.1/6:63-74
# U6 snRNA internal stem-loop: residues 85-95;102-106, motif-neighborhood, low confidence
name pre_B_6QX9_U6_ISL #348.1/6:85-95,102-106
# U6 snRNA AGC catalytic triad: residues 92-94, sequence-motif, medium confidence
name pre_B_6QX9_U6_AGC_catalytic_triad #348.1/6:92-94
# U6 snRNA LSm site: residues 102-106, terminal-region, low confidence
name pre_B_6QX9_U6_LSm_site #348.1/6:102-106
# RNA feature nucleotide display.
select #348.1 & nucleic
nucleotides sel atoms
select clear
# 5' exon: residues -1-0
color #348.1/I:-1-0 #FF8C00
select #348.1/I:-1-0
nucleotides sel fill
select clear
# 5'SS: residues 1-6
# intron: residues 1-8;88-102
# BP region: residues 95-102
# BP-A: residues 100
# U1 5'SS recog.: residues 1-10
color #348.1/1:1-10 #B66AAE
select #348.1/1:1-10
nucleotides sel fill
select clear
# U1 SL1: residues 11-45
color #348.1/1:11-45 #BF72B7
select #348.1/1:11-45
nucleotides sel fill
select clear
# U1 SL2: residues 46-95
