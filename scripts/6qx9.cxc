# U4 snRNA Brr2 loading region: chain 4, residues 59-70;73-80;85-94, review-region, low confidence
name r_6QX9_U4_Brr2_loading_region_4 #348.1/4:59-70,73-80,85-94
# U4 snRNA Sm site: chain 4, residues 118-124, sequence-motif, medium confidence
name r_6QX9_U4_Sm_site_4 #348.1/4:118-124
# U5 snRNA loop I 5' exon contact side: chain 5, residues 35-38, review-region, low confidence
name r_6QX9_U5_loop_I_5exon_contact_5 #348.1/5:35-38
# U5 snRNA loop I: chain 5, residues 38, sequence-motif, medium confidence
name r_6QX9_U5_loop_I_5 #348.1/5:38
# U5 snRNA loop I 3' exon contact side: chain 5, residues 44-50, review-region, low confidence
name r_6QX9_U5_loop_I_3exon_contact_5 #348.1/5:44-50
# U6 snRNA U2/U6 helix I partner: chain 6, residues 35-36;47-60, review-region, low confidence
