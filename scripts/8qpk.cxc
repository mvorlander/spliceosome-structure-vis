# Lightweight ChimeraX script for 8QPK
# Models are downloaded directly by ChimeraX from the PDB.
# Primary maps, when requested, are downloaded directly from EMDB.
# Original deposited chain identifiers are used.

# Shared anchor frame: 8H6L
# Structure group: #404; target model: #404.1; RNA labels: #404.2.

open 8h6l id 404.9 name 8H6L_anchor
open 8qpk id 404.1 name 8QPK
rename #404 pre_B_8qpk_structure

# Align on PRPF8.
matchmaker #404.1/A to #404.9/5B
close #404.9

hide atoms
cartoon
# Default display style.
style (protein|nucleic|solvent) & @@draw_mode=0 stick
cartoon style modeh def arrows t arrowshelix f arrowscale 3 wid 4 thick 3 sides 12 div 20
cartoon style ~(nucleic|strand) x round
cartoon style (nucleic|strand) x rect
cartoon style nucleic x round width 4 thick 4
lighting shadows false
lighting simple
camera ortho
lighting soft intensity 0.2 fillIntensity 0.5 ambientIntensity 1
lighting soft
# window
# windowsize 800 800

# bg and model colors
set bgColor white
style nucleic stick
graphics silhouettes true
cartoon style arrowScale 1.5
color byhetero
# Subunit colors from color_code/subunit_color_code.csv.
# DDX23
color #404.1/G #CA9982
# U4 snRNA
color #404.1/4 #E6D900
# SNRNP27
color #404.1/X #F4E7D2
# pre-mRNA
color #404.1/z #303030
# U6 snRNA
color #404.1/6 #DC143C
# PRPF6
color #404.1/N #CFA785
# SNRNP200
color #404.1/B #AFEEEE
# SF3A1
color #404.1/7 #55947F
# TXNL4A
color #404.1/D #C3BA7A
# PRPF31
color #404.1/L #DFD570
# PRPF8
color #404.1/A #BFC3E8
# RBM42
color #404.1/R #44A0A7
# USP39
color #404.1/U #B37E6A
# SART1
color #404.1/S #D6937B
# EFTUD2
color #404.1/C #6495ED
# U5 snRNA
color #404.1/5 #0000CD
# Named selections for subcomplexes using original deposited chain IDs.
# RNA-binding
# selector_meta {"color":"#9CA3AF","family":"Protein/RNP groups","group":"other protein/RNP groups","kind":"subcomplex"}
name pdb_8QPK_RNA_binding #404.1/R
# RNA/substrate
# selector_meta {"color":"#303030","family":"RNA","group":"pre-mRNA features","kind":"subcomplex"}
name pdb_8QPK_RNA_substrate #404.1/z
# U2/SF3B
# selector_meta {"color":"#6DBE70","family":"Protein/RNP groups","group":"U2/SF3B groups","kind":"subcomplex"}
name pdb_8QPK_U2_SF3B #404.1/7
# U4 snRNP
# selector_meta {"color":"#D8C800","family":"Protein/RNP groups","group":"U4 snRNP groups","kind":"subcomplex"}
name pdb_8QPK_U4_snRNP #404.1/4
# U4/U6 snRNP
# selector_meta {"color":"#C3BA7A","family":"Protein/RNP groups","group":"U4/U6 groups","kind":"subcomplex"}
name pdb_8QPK_U4_U6_snRNP #404.1/D,G,L,U
# U5 snRNP
# selector_meta {"color":"#0000CD","family":"Protein/RNP groups","group":"U5 snRNP groups","kind":"subcomplex"}
name pdb_8QPK_U5_snRNP #404.1/5,A,B,C,N,S,X
# U6 snRNP
# selector_meta {"color":"#DC143C","family":"Protein/RNP groups","group":"U6 snRNP groups","kind":"subcomplex"}
name pdb_8QPK_U6_snRNP #404.1/6
# Named selections for resolved substrate RNA features.
# 5' exon: residues -3--1, five-ss-inference, medium confidence, validation not_applicable
# selector_meta {"color":"#FF8C00","family":"RNA","feature":"exon_5","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name pre_B_8QPK_5exon #404.1/z:-3--1
# substrate RNA: residues -3,-2,-1,1,2,3,4,5,6,7,8, component, medium confidence, validation not_applicable
# selector_meta {"color":"#303030","family":"RNA","feature":"substrate","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name pre_B_8QPK_substrate #404.1/z:-3,-2,-1,1,2,3,4,5,6,7,8
# 5' splice site: residues 1-6, sequence-motif, medium confidence, validation uncertain uncertain validation
# selector_meta {"color":"#303030","family":"RNA","feature":"five_prime_splice_site","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name pre_B_8QPK_5SS #404.1/z:1-6
# intron from 5' splice site: residues 1-8, five-ss-inference, low confidence, validation not_applicable
# selector_meta {"color":"#303030","family":"RNA","feature":"intron","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name pre_B_8QPK_intron #404.1/z:1-8
# Named selections for resolved snRNA functional regions.
# U4 snRNA U4/U6 stem I partner: residues 1-18, reference-alignment, high confidence
# selector_meta {"color":"#D8C800","family":"RNA","feature":"U4_U6_stem_I_partner","group":"snRNA-snRNA interacting regions","group_key":"snRNA_snRNA_regions","kind":"rna_feature"}
name pre_B_8QPK_U4_U6_stem_I_partner #404.1/4:1-18
# U4 snRNA U4/U6 stem II partner: residues 56-64, reference-alignment, high confidence
# selector_meta {"color":"#E0CF1A","family":"RNA","feature":"U4_U6_stem_II_partner","group":"snRNA-snRNA interacting regions","group_key":"snRNA_snRNA_regions","kind":"rna_feature"}
name pre_B_8QPK_U4_U6_stem_II_partner #404.1/4:56-64
# U4 snRNA Brr2 loading region: residues 60-70;73-80, review-region, low confidence
# selector_meta {"color":"#F0DF2E","family":"RNA","feature":"U4_Brr2_loading_region","group":"other snRNA regions","group_key":"other_snRNA_regions","kind":"rna_feature"}
name pre_B_8QPK_U4_Brr2_loading_region #404.1/4:60-70,73-80
# U5 snRNA loop I: residues 38-42, sequence-motif, medium confidence
# selector_meta {"color":"#1B3CD0","family":"RNA","feature":"U5_loop_I","group":"snRNA-pre-mRNA regions","group_key":"snRNA_pre_mRNA_regions","kind":"rna_feature"}
name pre_B_8QPK_U5_loop_I #404.1/5:38-42
# U6 snRNA U2/U6 helix I partner: residues 35-36;40-60, motif-neighborhood, medium confidence
# selector_meta {"color":"#D0183C","family":"RNA","feature":"U6_U2_helix_I_partner","group":"snRNA-snRNA interacting regions","group_key":"snRNA_snRNA_regions","kind":"rna_feature"}
name pre_B_8QPK_U6_U2_helix_I_partner #404.1/6:35-36,40-60
# U6 snRNA 5' splice-site upstream contact: residues 40-49, motif-neighborhood, medium confidence
# selector_meta {"color":"#E01842","family":"RNA","feature":"U6_5SS_upstream_contact","group":"other snRNA regions","group_key":"other_snRNA_regions","kind":"rna_feature"}
name pre_B_8QPK_U6_5SS_upstream_contact #404.1/6:40-49
# U6 snRNA ACAGAGA box: residues 41-47, sequence-motif, high confidence
# selector_meta {"color":"#DC143C","family":"RNA","feature":"U6_ACAGAGA_box","group":"other snRNA regions","group_key":"other_snRNA_regions","kind":"rna_feature"}
name pre_B_8QPK_U6_ACAGAGA_box #404.1/6:41-47
# U6 snRNA U4/U6 stem II partner: residues 52-61, reference-alignment, high confidence
# selector_meta {"color":"#E01842","family":"RNA","feature":"U6_U4_stem_II_partner","group":"other snRNA regions","group_key":"other_snRNA_regions","kind":"rna_feature"}
name pre_B_8QPK_U6_U4_stem_II_partner #404.1/6:52-61
# U6 snRNA U4/U6 stem I partner: residues 63-74, reference-alignment, high confidence
# selector_meta {"color":"#D9183E","family":"RNA","feature":"U6_U4_stem_I_partner","group":"other snRNA regions","group_key":"other_snRNA_regions","kind":"rna_feature"}
name pre_B_8QPK_U6_U4_stem_I_partner #404.1/6:63-74
# RNA feature nucleotide display.
select #404.1 & nucleic
nucleotides sel atoms
select clear
# 5' exon: residues -3--1
color #404.1/z:-3--1 #FF8C00
select #404.1/z:-3--1
nucleotides sel fill
select clear
# 5'SS: residues 1-6
# intron: residues 1-8
# U4/U6 stem I: residues 1-18
color #404.1/4:1-18 #D8C800
select #404.1/4:1-18
nucleotides sel fill
select clear
# U4/U6 stem II: residues 56-64
color #404.1/4:56-64 #E0CF1A
select #404.1/4:56-64
nucleotides sel fill
select clear
# U4 Brr2 region: residues 60-70;73-80
color #404.1/4:60-70,73-80 #F0DF2E
select #404.1/4:60-70,73-80
nucleotides sel fill
select clear
# U5 loop I: residues 38-42
color #404.1/5:38-42 #1B3CD0
select #404.1/5:38-42
nucleotides sel fill
select clear
# U2/U6 helix I: residues 35-36;40-60
color #404.1/6:35-36,40-60 #D0183C
select #404.1/6:35-36,40-60
nucleotides sel fill
select clear
# U6 5'SS contact: residues 40-49
color #404.1/6:40-49 #E01842
select #404.1/6:40-49
nucleotides sel fill
select clear
# U6 ACAGAGA: residues 41-47
color #404.1/6:41-47 #DC143C
select #404.1/6:41-47
nucleotides sel fill
select clear
# U4/U6 stem II: residues 52-61
color #404.1/6:52-61 #E01842
select #404.1/6:52-61
nucleotides sel fill
select clear
# U4/U6 stem I: residues 63-74
color #404.1/6:63-74 #D9183E
select #404.1/6:63-74
nucleotides sel fill
select clear
# RNA feature 3D residue labels.
# Labels are created as independent grouped models under #404.2.
# Fetch and run the self-contained RNA label script from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/label_scripts/8qpk_rna_labels.py
# Searchable named selection browser.
# In GUI ChimeraX this opens a small panel for selecting, zooming, and toggling RNA labels.
# Fetch and open the self-contained named selection browser from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/selection_browser_scripts/8qpk_selection_browser.py
view
show nucleic
