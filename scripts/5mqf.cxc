# Lightweight ChimeraX script for 5MQF
# Models are downloaded directly by ChimeraX from the PDB.
# Primary maps, when requested, are downloaded directly from EMDB.
# Original deposited chain identifiers are used.

# Shared anchor frame: 8H6L
# Structure group: #315; target model: #315.1; RNA labels: #315.2.

open 8h6l id 315.9 name 8H6L_anchor
open 5mqf id 315.1 name 5MQF
rename #315 Cstar_5mqf_structure

# Align on PRPF8.
matchmaker #315.1/A to #315.9/5B
close #315.9

# Remove implausibly long deposited covalent bonds before styling.
# Fetch and run the implausible-bond pruning helper from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/prune_implausible_bonds.py

hide atoms
cartoon
# Default display style.
style (protein|nucleic|solvent) & @@draw_mode=0 stick
cartoon style modeh def arrows t arrowshelix f arrowscale 3 wid 4 thick 3 sides 12 div 20
cartoon style ~(nucleic|strand) x round
cartoon style (nucleic|strand) x rect
cartoon style nucleic x round width 4 thick 4
lighting shadows false
lighting simple
camera ortho
lighting soft intensity 0.2 fillIntensity 0.5 ambientIntensity 1
lighting soft

# bg and model colors
set bgColor white
style nucleic stick
graphics silhouettes true
cartoon style arrowScale 1.5
color byhetero
# Subunit colors from color_code/subunit_color_code.csv.
# PRPF8
color #315.1/A #BFC3E8
# EFTUD2
color #315.1/B #6495ED
# SNW1
color #315.1/C #D49F96
# PLRG1
color #315.1/D #F4A460
# PRPF17
color #315.1/E #FFF7C9
# PRP8BP
color #315.1/F #E2F3F4
# PRPF19
color #315.1/G #FFFFAB
# PRPF19
color #315.1/H #FFFFAB
# PRPF19
color #315.1/I #FFFFAB
# PRPF19
color #315.1/J #FFFFAB
# BCAS2
color #315.1/K #FFDAB9
# CDC5L
color #315.1/L #DAA520
# SYF1
color #315.1/M #FF957B
# SYF2
color #315.1/N #FF8C00
# CRNKL1
color #315.1/O #FFC388
# RBM22
color #315.1/P #DE9A52
# BUD31
color #315.1/Q #FFF584
# CWC15
color #315.1/R #FFDEAD
# SRRM2
color #315.1/S #BDD6F0
# CWC22
color #315.1/T #2C54DD
# AQR
color #315.1/U #FFDAB9
# PPIL1
color #315.1/V #EEE8AA
# SNRPA1
color #315.1/W #58D68D
# SNRPB2
color #315.1/X #DAF7A6
# SNRPD2
color #315.1/a #B0C4DE
# U2-Sm SNRPD2
color #315.1/h #D5F5E3
# SNRPF
color #315.1/b #B0C4DE
# U2-Sm SNRPF
color #315.1/i #D5F5E3
# SNRPE
color #315.1/c #B0C4DE
# U2-Sm SNRPE
color #315.1/j #D5F5E3
# SNRPG
color #315.1/d #B0C4DE
# U2-Sm SNRPG
color #315.1/k #D5F5E3
# SNRPD3
color #315.1/e #B0C4DE
# U2-Sm SNRPD3
color #315.1/l #D5F5E3
# SNRPB
color #315.1/f #B0C4DE
# U2-Sm SNRPB
color #315.1/m #D5F5E3
# SNRPD1
color #315.1/g #B0C4DE
# U2-Sm SNRPD1
color #315.1/n #D5F5E3
# PPIE
color #315.1/o #FFFFE0
# EIF4A3
color #315.1/p #F1D8BC
# DHX8
color #315.1/q #900C3F
# INTRON
color #315.1/Y #303030
# INTRON
color #315.1/Z #303030
# U2 snRNA
color #315.1/2 #71C562
# U5 snRNA
color #315.1/5 #4F9FD3
# U6 snRNA
color #315.1/6 #EF4444
# Named selections for subcomplexes using original deposited chain IDs.
# EJC/mRNP
# selector_meta {"color":"#EAA439","family":"Protein/RNP groups","group":"EJC/mRNP groups","kind":"subcomplex"}
name pdb_5MQF_EJC_mRNP #315.1/T,p
# NTC/NTR related
# selector_meta {"color":"#F4BF67","family":"Protein/RNP groups","group":"NTC/NTR groups","kind":"subcomplex"}
name pdb_5MQF_NTC_NTR_related #315.1/C,M,N,O,P,Q,U,V,o
# NTC/PRP19
# selector_meta {"color":"#F4BF67","family":"Protein/RNP groups","group":"NTC/NTR groups","kind":"subcomplex"}
name pdb_5MQF_NTC_PRP19 #315.1/D,G,H,I,J,K,L,R
# RNA/substrate
# selector_meta {"color":"#303030","family":"RNA","group":"pre-mRNA features","kind":"subcomplex"}
name pdb_5MQF_RNA_substrate #315.1/Y,Z
# SR proteins
# selector_meta {"color":"#9CA3AF","family":"Protein/RNP groups","group":"other protein/RNP groups","kind":"subcomplex"}
name pdb_5MQF_SR_proteins #315.1/S
# Second step factors
# selector_meta {"color":"#9CA3AF","family":"Protein/RNP groups","group":"other protein/RNP groups","kind":"subcomplex"}
name pdb_5MQF_Second_step_factors #315.1/E,q
# Sm ring
# selector_meta {"color":"#9CA3AF","family":"Protein/RNP groups","group":"other protein/RNP groups","kind":"subcomplex"}
name pdb_5MQF_Sm_ring #315.1/a,b,c,d,e,f,g
# U2 Sm ring
# selector_meta {"color":"#BFE6BF","family":"Protein/RNP groups","group":"U2/SF3B groups","kind":"subcomplex"}
name pdb_5MQF_U2_Sm_ring #315.1/h,i,j,k,l,m,n
# U2 snRNP
# selector_meta {"color":"#2F8B4D","family":"Protein/RNP groups","group":"U2/SF3B groups","kind":"subcomplex"}
name pdb_5MQF_U2_snRNP #315.1/2,W,X
# U5 snRNP
# selector_meta {"color":"#0000CD","family":"Protein/RNP groups","group":"U5 snRNP groups","kind":"subcomplex"}
name pdb_5MQF_U5_snRNP #315.1/5,A,B,F
# U6 snRNP
# selector_meta {"color":"#DC143C","family":"Protein/RNP groups","group":"U6 snRNP groups","kind":"subcomplex"}
name pdb_5MQF_U6_snRNP #315.1/6
# Named selections for resolved substrate RNA features.
# substrate RNA: residues 47-58; 59-67;135-157, component, medium confidence, validation not_applicable
# selector_meta {"color":"#303030","family":"RNA","feature":"substrate","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name Cstar_5MQF_substrate #315.1/Y:59-67,135-157|#315.1/Z:47-58
# 5' splice site: residues 59-64, network-scored-motif, medium confidence, validation uncertain uncertain validation
# selector_meta {"color":"#303030","family":"RNA","feature":"five_prime_splice_site","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name Cstar_5MQF_5SS #315.1/Y:59-64
# intron: residues 59-67;135-157, splice-site-inference, medium confidence, validation not_applicable
# selector_meta {"color":"#303030","family":"RNA","feature":"intron","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name Cstar_5MQF_intron #315.1/Y:59-67,135-157
# branch point region: residues 150-156, network-scored-motif, high confidence, validation validated
# selector_meta {"color":"#303030","family":"RNA","feature":"branch_point_region","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name Cstar_5MQF_branch_region #315.1/Y:150-156
# branch point adenosine: residues 155, network-scored-motif, high confidence, validation validated
# selector_meta {"color":"#303030","family":"RNA","feature":"branch_point_adenosine","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name Cstar_5MQF_branch_A #315.1/Y:155
# 5' exon: residues 47-58, splice-site-inference, medium confidence, validation not_applicable
# selector_meta {"color":"#FF8C00","family":"RNA","feature":"exon_5","group":"pre-mRNA features","group_key":"pre_mRNA_features","kind":"rna_feature"}
name Cstar_5MQF_5exon #315.1/Z:47-58
# Named selections for resolved snRNA functional regions.
# U2 snRNA U2/U6 helix I partner: residues 26-30, review-region, high confidence
# selector_meta {"color":"#047857","family":"RNA","feature":"U2_U6_helix_I_partner","group":"snRNA-snRNA interacting regions","group_key":"snRNA_snRNA_regions","kind":"rna_feature"}
name Cstar_5MQF_U2_U6_helix_I_partner #315.1/2:26-30
# U2 snRNA branchpoint pairing region: residues 32-41, sequence-motif-neighborhood, medium confidence
# selector_meta {"color":"#0B6E2D","family":"RNA","feature":"U2_branchpoint_pairing_region","group":"snRNA-pre-mRNA regions","group_key":"snRNA_pre_mRNA_regions","kind":"rna_feature"}
name Cstar_5MQF_U2_branchpoint_pairing_region #315.1/2:32-41
# U2 snRNA stem IIa: residues 46-60, review-region, low confidence
# selector_meta {"color":"#167A38","family":"RNA","feature":"U2_stem_IIa","group":"internal stem loops","group_key":"internal_stem_loops","kind":"rna_feature"}
name Cstar_5MQF_U2_stem_IIa #315.1/2:46-60
# U2 snRNA Sm site: residues 99-105, sequence-motif, medium confidence
# selector_meta {"color":"#2F8B4D","family":"RNA","feature":"U2_Sm_site","group":"other snRNA regions","group_key":"other_snRNA_regions","kind":"rna_feature"}
name Cstar_5MQF_U2_Sm_site #315.1/2:99-105
# U5 snRNA loop I: residues 38-42, sequence-motif, medium confidence
# selector_meta {"color":"#1B3CD0","family":"RNA","feature":"U5_loop_I","group":"snRNA-pre-mRNA regions","group_key":"snRNA_pre_mRNA_regions","kind":"rna_feature"}
name Cstar_5MQF_U5_loop_I #315.1/5:38-42
# U6 snRNA 5' terminal stem-loop: residues 1-28, reference-alignment, high confidence
# selector_meta {"color":"#DC143C","family":"RNA","feature":"U6_5prime_terminal_stem_loop","group":"internal stem loops","group_key":"internal_stem_loops","kind":"rna_feature"}
name Cstar_5MQF_U6_5_terminal_stem_loop #315.1/6:1-28
# U6 snRNA U2/U6 helix I partner: residues 36-60, motif-neighborhood, medium confidence
# selector_meta {"color":"#D0183C","family":"RNA","feature":"U6_U2_helix_I_partner","group":"snRNA-snRNA interacting regions","group_key":"snRNA_snRNA_regions","kind":"rna_feature"}
name Cstar_5MQF_U6_U2_helix_I_partner #315.1/6:36-60
# U6 snRNA 5' splice-site upstream contact: residues 38-49, motif-neighborhood, medium confidence
# selector_meta {"color":"#E01842","family":"RNA","feature":"U6_5SS_upstream_contact","group":"other snRNA regions","group_key":"other_snRNA_regions","kind":"rna_feature"}
name Cstar_5MQF_U6_5SS_upstream_contact #315.1/6:38-49
# U6 snRNA ACAGAGA box: residues 41-47, sequence-motif, high confidence
# selector_meta {"color":"#DC143C","family":"RNA","feature":"U6_ACAGAGA_box","group":"other snRNA regions","group_key":"other_snRNA_regions","kind":"rna_feature"}
name Cstar_5MQF_U6_ACAGAGA_box #315.1/6:41-47
# U6 snRNA internal stem-loop: residues 79-96, motif-neighborhood, low confidence
# selector_meta {"color":"#D61A3D","family":"RNA","feature":"U6_ISL","group":"internal stem loops","group_key":"internal_stem_loops","kind":"rna_feature"}
name Cstar_5MQF_U6_ISL #315.1/6:79-96
# U6 snRNA AGC catalytic triad: residues 92-94, sequence-motif, medium confidence
# selector_meta {"color":"#C91236","family":"RNA","feature":"U6_AGC_catalytic_triad","group":"catalytic core regions","group_key":"catalytic_core_regions","kind":"rna_feature"}
name Cstar_5MQF_U6_AGC_catalytic_triad #315.1/6:92-94
# RNA feature nucleotide display.
select #315.1 & nucleic
nucleotides sel atoms
select clear
# 5'SS: residues 59-64
# intron: residues 59-67;135-157
# BP region: residues 150-156
# BP-A: residues 155
# 5' exon: residues 47-58
color #315.1/Z:47-58 #FF8C00
select #315.1/Z:47-58
nucleotides sel fill
select clear
# U2/U6 helix I: residues 26-30
color #315.1/2:26-30 #047857
select #315.1/2:26-30
nucleotides sel fill
select clear
# U2 BP pairing: residues 32-41
color #315.1/2:32-41 #0B6E2D
select #315.1/2:32-41
nucleotides sel fill
select clear
# U2 stem IIa: residues 46-60
color #315.1/2:46-60 #167A38
select #315.1/2:46-60
nucleotides sel fill
select clear
# U5 loop I: residues 38-42
color #315.1/5:38-42 #1B3CD0
select #315.1/5:38-42
nucleotides sel fill
select clear
# U6 5' terminal SL: residues 1-28
color #315.1/6:1-28 #DC143C
select #315.1/6:1-28
nucleotides sel fill
select clear
# U2/U6 helix I: residues 36-60
color #315.1/6:36-60 #D0183C
select #315.1/6:36-60
nucleotides sel fill
select clear
# U6 5'SS contact: residues 38-49
color #315.1/6:38-49 #E01842
select #315.1/6:38-49
nucleotides sel fill
select clear
# U6 ACAGAGA: residues 41-47
color #315.1/6:41-47 #DC143C
select #315.1/6:41-47
nucleotides sel fill
select clear
# U6 ISL: residues 79-96
color #315.1/6:79-96 #D61A3D
select #315.1/6:79-96
nucleotides sel fill
select clear
# U6 AGC triad: residues 92-94
color #315.1/6:92-94 #C91236
select #315.1/6:92-94
nucleotides sel fill
select clear
# RNA feature 3D residue labels.
# Labels are created as independent grouped models under #315.2.
# Fetch and run the self-contained RNA label script from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/label_scripts/5mqf_rna_labels.py
# Searchable named selection browser.
# In GUI ChimeraX this opens a small panel for selecting, zooming, and toggling RNA labels.
# Fetch and open the self-contained named selection browser from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/selection_browser_scripts/5mqf_selection_browser.py
view
show nucleic
