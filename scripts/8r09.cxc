color #408.1/B4 #77B088
# Named selections for resolved substrate RNA features.
# substrate RNA: residues -3,-2,-1,1,2,3,4,5,6,7,8; 29-43, component, medium confidence, validation not_applicable
name pre_B_8R09_substrate #408.1/Z:29-43|#408.1/z:-3,-2,-1,1,2,3,4,5,6,7,8
# intron: residues 1-8; 29-43, five-ss-inference/splice-site-inference, low/medium confidence, validation not_applicable
name pre_B_8R09_intron #408.1/Z:29-43|#408.1/z:1-8
# branch point region: residues 35-43, network-scored-motif, high confidence, validation validated
name pre_B_8R09_branch_region #408.1/Z:35-43
# branch point adenosine: residues 41, network-scored-motif, high confidence, validation validated
name pre_B_8R09_branch_A #408.1/Z:41
# 5' exon: residues -3--1, five-ss-inference, medium confidence, validation not_applicable
name pre_B_8R09_5exon #408.1/z:-3--1
# 5' splice site: residues 1-6, sequence-motif, medium confidence, validation uncertain uncertain validation
name pre_B_8R09_5SS #408.1/z:1-6
# Named selections for resolved snRNA functional regions.
# U2 snRNA U2/U6 helix I partner: residues 29-30, review-region, high confidence
name pre_B_8R09_U2_U6_helix_I_partner #408.1/2:29-30
# U2 snRNA branchpoint pairing region: residues 32-41, sequence-motif-neighborhood, medium confidence
name pre_B_8R09_U2_branchpoint_pairing_region #408.1/2:32-41
# U2 snRNA stem IIa: residues 46-65, review-region, low confidence
name pre_B_8R09_U2_stem_IIa #408.1/2:46-65
# U2 snRNA Sm site: residues 99-105, sequence-motif, medium confidence
name pre_B_8R09_U2_Sm_site #408.1/2:99-105
# U4 snRNA U4/U6 stem I partner: residues 1-18, reference-alignment, high confidence
name pre_B_8R09_U4_U6_stem_I_partner #408.1/4:1-18
# U4 snRNA U4/U6 stem II partner: residues 56-64, reference-alignment, high confidence
name pre_B_8R09_U4_U6_stem_II_partner #408.1/4:56-64
# U4 snRNA Brr2 loading region: residues 60-80;85-95, review-region, low confidence
name pre_B_8R09_U4_Brr2_loading_region #408.1/4:60-80,85-95
# U4 snRNA Sm site: residues 119-125, sequence-motif, medium confidence
name pre_B_8R09_U4_Sm_site #408.1/4:119-125
# U5 snRNA loop I: residues 38-42, sequence-motif, medium confidence
name pre_B_8R09_U5_loop_I #408.1/5:38-42
# U6 snRNA U2/U6 helix I partner: residues 35-60, motif-neighborhood, medium confidence
name pre_B_8R09_U6_U2_helix_I_partner #408.1/6:35-60
# U6 snRNA 5' splice-site upstream contact: residues 38-49, motif-neighborhood, medium confidence
name pre_B_8R09_U6_5SS_upstream_contact #408.1/6:38-49
# U6 snRNA ACAGAGA box: residues 41-47, sequence-motif, high confidence
name pre_B_8R09_U6_ACAGAGA_box #408.1/6:41-47
# U6 snRNA U4/U6 stem II partner: residues 52-61, reference-alignment, high confidence
name pre_B_8R09_U6_U4_stem_II_partner #408.1/6:52-61
# U6 snRNA U4/U6 stem I partner: residues 63-74, reference-alignment, high confidence
name pre_B_8R09_U6_U4_stem_I_partner #408.1/6:63-74
# U6 snRNA internal stem-loop: residues 85-96;102-106, motif-neighborhood, low confidence
name pre_B_8R09_U6_ISL #408.1/6:85-96,102-106
# U6 snRNA AGC catalytic triad: residues 92-94, sequence-motif, medium confidence
name pre_B_8R09_U6_AGC_catalytic_triad #408.1/6:92-94
# U6 snRNA LSm site: residues 102-106, terminal-region, low confidence
name pre_B_8R09_U6_LSm_site #408.1/6:102-106
# RNA feature nucleotide display.
select #408.1 & nucleic
nucleotides sel atoms
select clear
# intron: residues 1-8; 29-43
# BP region: residues 35-43
# BP-A: residues 41
# 5' exon: residues -3--1
color #408.1/z:-3--1 #FF8C00
select #408.1/z:-3--1
nucleotides sel fill
select clear
# 5'SS: residues 1-6
# U2/U6 helix I: residues 29-30
color #408.1/2:29-30 #047857
select #408.1/2:29-30
nucleotides sel fill
select clear
# U2 BP pairing: residues 32-41
color #408.1/2:32-41 #0B6E2D
select #408.1/2:32-41
nucleotides sel fill
select clear
# U2 stem IIa: residues 46-65
color #408.1/2:46-65 #167A38
select #408.1/2:46-65
nucleotides sel fill
select clear
# U4/U6 stem I: residues 1-18
color #408.1/4:1-18 #D8C800
select #408.1/4:1-18
nucleotides sel fill
select clear
# U4/U6 stem II: residues 56-64
color #408.1/4:56-64 #E0CF1A
select #408.1/4:56-64
nucleotides sel fill
select clear
# U4 Brr2 region: residues 60-80;85-95
color #408.1/4:60-80,85-95 #F0DF2E
select #408.1/4:60-80,85-95
nucleotides sel fill
select clear
# U5 loop I: residues 38-42
color #408.1/5:38-42 #1B3CD0
select #408.1/5:38-42
nucleotides sel fill
select clear
# U2/U6 helix I: residues 35-60
color #408.1/6:35-60 #D0183C
select #408.1/6:35-60
nucleotides sel fill
select clear
# U6 5'SS contact: residues 38-49
color #408.1/6:38-49 #E01842
select #408.1/6:38-49
nucleotides sel fill
select clear
# U6 ACAGAGA: residues 41-47
color #408.1/6:41-47 #DC143C
select #408.1/6:41-47
nucleotides sel fill
select clear
# U4/U6 stem II: residues 52-61
color #408.1/6:52-61 #E01842
select #408.1/6:52-61
nucleotides sel fill
select clear
# U4/U6 stem I: residues 63-74
color #408.1/6:63-74 #D9183E
select #408.1/6:63-74
nucleotides sel fill
select clear
# U6 ISL: residues 85-96;102-106
color #408.1/6:85-96,102-106 #D61A3D
select #408.1/6:85-96,102-106
nucleotides sel fill
select clear
# U6 AGC triad: residues 92-94
color #408.1/6:92-94 #C91236
select #408.1/6:92-94
nucleotides sel fill
select clear
# RNA feature 3D residue labels.
# Labels are created as independent grouped models under #408.2.
# Fetch and run the self-contained RNA label script from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/label_scripts/8r09_rna_labels.py
# Searchable named selection browser.
# In GUI ChimeraX this opens a small panel for selecting and zooming named selections.
# Fetch and open the self-contained named selection browser from GitHub.
open https://raw.githubusercontent.com/mvorlander/spliceosome-structure-vis/main/scripts/selection_browser_scripts/8r09_selection_browser.py
view
show nucleic
