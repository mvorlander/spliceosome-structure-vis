color #408.1/M #A89264
# TXNL4A
color #408.1/D #C3BA7A
# U5 snRNA
color #408.1/5 #0000CD
# pre-mRNA
color #408.1/z #303030
# SF3A1
color #408.1/7 #55947F
# U4 snRNA
color #408.1/4 #E6D900
