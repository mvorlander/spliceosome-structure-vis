color #408.1/23 #D5F5E3
# U4-Sm SNRPD3
color #408.1/43 #F7F0A6
# U5-Sm SNRPD3
color #408.1/53 #B0C4DE
# U2-Sm SNRPG
color #408.1/2g #D5F5E3
# U4-Sm SNRPG
color #408.1/4g #F7F0A6
# U5-Sm SNRPG
color #408.1/5g #B0C4DE
# U2-Sm SNRPE
color #408.1/2e #D5F5E3
# U4-Sm SNRPE
color #408.1/4e #F7F0A6
# U5-Sm SNRPE
color #408.1/5e #B0C4DE
# U2-Sm SNRPD1
color #408.1/21 #D5F5E3
# U4-Sm SNRPD1
color #408.1/41 #F7F0A6
