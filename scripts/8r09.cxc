# Lightweight ChimeraX script for 8R09
# Models are downloaded directly by ChimeraX from the PDB.
# Primary maps, when requested, are downloaded directly from EMDB.
# Original deposited chain identifiers are used.

# Shared anchor frame: 8H6L
# Structure group: #408; target model: #408.1; RNA labels: #408.2.

open 8h6l id 408.9 name 8H6L_anchor
open 8r09 id 408.1 name 8R09
rename #408 pre_B_8r09_structure

# Align on PRPF8.
matchmaker #408.1/A to #408.9/5B
close #408.9

hide atoms
cartoon
# Default display style.
style (protein|nucleic|solvent) & @@draw_mode=0 stick
cartoon style modeh def arrows t arrowshelix f arrowscale 3 wid 4 thick 3 sides 12 div 20
cartoon style ~(nucleic|strand) x round
cartoon style (nucleic|strand) x rect
cartoon style nucleic x round width 4 thick 4
lighting shadows false
lighting simple
camera ortho
lighting soft intensity 0.2 fillIntensity 0.5 ambientIntensity 1
lighting soft
# window
# windowsize 800 800

# bg and model colors
set bgColor white
style nucleic stick
graphics silhouettes true
cartoon style arrowScale 1.5
color byhetero
# Subunit colors from color_code/subunit_color_code.csv.
# LSM6
color #408.1/66 #F4A3A8
# pre-mRNA
color #408.1/Z #303030
# SF3A2
color #408.1/8 #75A074
# SF3A3
color #408.1/9 #9BCF91
# SF3B2
color #408.1/B2 #49926C
# SF3B5
color #408.1/B5 #92BB8F
# U2 snRNA
color #408.1/2 #006400
# SF3B3
color #408.1/B3 #6A9064
# PHF5A
color #408.1/BP #375A40
# SF3B1
color #408.1/B1 #487957
# SF3B6
color #408.1/B6 #ADCEA0
# LSM7
color #408.1/67 #F4A3A8
# U2-Sm SNRPD2
color #408.1/22 #D5F5E3
